---
// Props with defaults
const {
  badge = "OUR METHOD",
  title = "Step-by-Step",
  titleHighlight = "Process"
} = Astro.props;

const steps = [
  {
    number: "01",
    title: "In-Depth Website Audit",
    description: "We assess your website's structure, technical health, and content quality to uncover areas of improvement."
  },
  {
    number: "02",
    title: "Custom Strategy Development",
    description: "We build a detailed roadmap aligned with your business goals -from improving local visibility to capturing a global audience."
  },
  {
    number: "03",
    title: "Execution & Optimization",
    description: "We implement SEO enhancements, create targeted content, and build high-quality backlinks to strengthen your online presence."
  },
  {
    number: "04",
    title: "Continuous Performance Monitoring",
    description: "SEO is dynamic, and so are we. We analyze results, refine strategies, and ensure consistent progress over time."
  }
];
---

<div class="bg-[#0d0f1a] py-16 px-4">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-12">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-bold uppercase tracking-widest mb-4 text-[#f0622a] border border-[rgba(240,98,42,0.15)]" style="background:linear-gradient(135deg,rgba(240,98,42,0.1),rgba(240,98,42,0.05))">
        {badge}
      </span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-2" style="font-family: 'Outfit', sans-serif; font-weight: 800;">
        {title} <span class="text-[#f0622a]">{titleHighlight}</span>
      </h2>
    </div>

    <!-- Process Steps - 2 Column Grid -->
    <div class="process-grid">
      {steps.map((step) => (
        <div
          class="process-card"
        >
          <div class="process-number">
            {step.number}
          </div>

          <div class="process-copy">
            <h3 class="text-xl font-bold text-white">
              {step.title}
            </h3>

            <p class="text-[#d0d4e8] leading-relaxed text-base">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</div>

<style>
  .process-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 18px;
    overflow: hidden;
  }

  .process-card {
    display: grid;
    grid-template-columns: 76px 1fr;
    gap: 1.35rem;
    background: #111421;
    padding: clamp(1.35rem, 3vw, 2.25rem);
    min-height: 190px;
  }

  .process-number {
    color: #f0622a;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 0.85;
    font-weight: 900;
    letter-spacing: -0.08em;
    opacity: 0.9;
  }

  .process-copy h3 {
    margin: 0 0 0.85rem;
    line-height: 1.2;
  }

  .process-copy p {
    margin: 0;
  }

  .process-card:nth-child(2),
  .process-card:nth-child(3) {
    background: #0f121f;
  }

  @media (max-width: 768px) {
    .process-grid {
      grid-template-columns: 1fr;
    }

    .process-card {
      grid-template-columns: 60px 1fr;
      min-height: auto;
    }
  }
</style>
