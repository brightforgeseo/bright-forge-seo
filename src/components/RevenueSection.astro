---
// Props with defaults
const {
  badge = "",
  title = "REVENUE BOOSTING SEO",
  subtitle = "Generate More Leads",
  description = "More traffic is a win, but the right traffic truly drives your bottom line. Our SEO focus zeros in on prospects actively seeking the products or services you provide, laying the groundwork for meaningful conversions."
} = Astro.props;

const features = [
  {
    title: "Attract Buyers, Not Just Browsers",
    description: "We target search terms with commercial intent — people actively looking to purchase or enquire. This means higher conversion rates and better return on your SEO investment."
  },
  {
    title: "Reduce Customer Acquisition Costs",
    description: "Organic traffic compounds over time. Unlike paid ads that stop the moment you pause spending, SEO builds a sustainable pipeline that lowers your cost per lead month after month."
  },
  {
    title: "Outperform Competitors in Search",
    description: "We identify where your competitors are winning and build strategies to overtake them — capturing market share in the searches that matter most to your revenue."
  },
  {
    title: "Track What Matters to Your Bottom Line",
    description: "We measure success by leads generated, revenue influenced, and ROI delivered — not vanity metrics. You'll always know how SEO connects to your business goals."
  }
];
---

<div class="bg-[#0d0f1a] py-16 px-4">
  <div class="max-w-7xl mx-auto">

    <!-- Decorative dots -->
    <div class="flex gap-2 mb-8">
      <div class="w-3 h-3 bg-[#f0622a] rounded-full"></div>
      <div class="w-3 h-3 bg-[#f0622a] rounded-full"></div>
      <div class="w-3 h-3 bg-[#f0622a] rounded-full"></div>
    </div>

    <!-- Main heading -->
    <div class="mb-8">
      <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-4" style="font-family: 'Syne', sans-serif; font-weight: 800;">
        {title}
      </h2>
      <h3 class="text-3xl md:text-4xl font-bold text-white mb-6" style="font-family: 'Syne', sans-serif; font-weight: 800;">
        {subtitle}
      </h3>
    </div>

    <!-- Description -->
    <p class="text-lg text-[#c5c9de] leading-relaxed mb-12 max-w-4xl">
      {description}
    </p>

    <!-- Feature list with left border and hover effects -->
    <div class="space-y-4 max-w-4xl">
      {features.map((feature) => (
        <div
          class="revenue-card border-l-4 border-[#f0622a] pl-6 p-6 bg-[#131627] transition-all duration-300 hover:shadow-xl hover:scale-105 cursor-pointer rounded-lg"
        >
          <h4 class="text-xl font-bold text-white mb-3">
            {feature.title}
          </h4>
          <p class="text-[#c5c9de] leading-relaxed">
            {feature.description}
          </p>
        </div>
      ))}
    </div>

  </div>
</div>

<script>
  // Add hover effects with JavaScript for better browser support
  document.addEventListener('DOMContentLoaded', () => {
    const featureCards = document.querySelectorAll('.revenue-card');

    featureCards.forEach(card => {
      card.addEventListener('mouseenter', function() {
        this.style.backgroundColor = 'rgba(240,98,42,0.08)';
        this.style.transform = 'scale(1.02)';
      });

      card.addEventListener('mouseleave', function() {
        this.style.backgroundColor = '#131627';
        this.style.transform = 'scale(1)';
      });
    });
  });
</script>
