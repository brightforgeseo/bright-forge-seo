---
/**
 * 3D wireframe globe background for hero sections.
 * Renders a slowly rotating globe with connection points using Three.js.
 */
---

<canvas class="hero-globe-canvas" aria-hidden="true"></canvas>

<style>
  .hero-globe-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }
</style>

<script>
  import * as THREE from 'three';

  function initGlobe(canvas: HTMLCanvasElement) {
    // Walk up to find the section element for dimensions
    let section: HTMLElement | null = canvas.parentElement;
    while (section && section.tagName !== 'SECTION') {
      section = section.parentElement;
    }
    if (!section) {
      console.warn('[HeroGlobe] No parent section found');
      return;
    }

    let width = section.clientWidth;
    let height = section.clientHeight;

    if (!width || !height) {
      setTimeout(() => {
        canvas.dataset.initialized = '';
        initGlobe(canvas);
      }, 100);
      return;
    }

    // Renderer
    let renderer: THREE.WebGLRenderer;
    try {
      renderer = new THREE.WebGLRenderer({
        canvas,
        alpha: true,
        antialias: true,
      });
    } catch (e) {
      console.warn('[HeroGlobe] WebGL not available:', e);
      return;
    }

    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(width, height);

    // Scene & Camera
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 100);
    camera.position.z = 3.2;

    // Brand colors
    const orange = new THREE.Color(0xf0622a);
    const dimWhite = new THREE.Color(0x3a3f5c);

    // Globe group
    const globe = new THREE.Group();
    scene.add(globe);

    // Wireframe sphere
    const sphereGeo = new THREE.SphereGeometry(1, 36, 18);
    const wireframe = new THREE.LineSegments(
      new THREE.WireframeGeometry(sphereGeo),
      new THREE.LineBasicMaterial({ color: dimWhite, transparent: true, opacity: 0.25 })
    );
    globe.add(wireframe);

    // Latitude rings
    for (let i = 1; i < 6; i++) {
      const phi = (i / 6) * Math.PI;
      const ringRadius = Math.sin(phi);
      const ringY = Math.cos(phi);
      const ringGeo = new THREE.RingGeometry(ringRadius - 0.002, ringRadius + 0.002, 64);
      const ring = new THREE.Mesh(
        ringGeo,
        new THREE.MeshBasicMaterial({ color: dimWhite, transparent: true, opacity: 0.15, side: THREE.DoubleSide })
      );
      ring.position.y = ringY;
      ring.rotation.x = Math.PI / 2;
      globe.add(ring);
    }

    // Connection points
    const cities = [
      { lat: 14.5, lng: 121 },    // Manila
      { lat: 35.7, lng: 139.7 },  // Tokyo
      { lat: 37.8, lng: -122.4 }, // San Francisco
      { lat: 51.5, lng: -0.1 },   // London
      { lat: -33.9, lng: 151.2 }, // Sydney
      { lat: 1.35, lng: 103.8 },  // Singapore
      { lat: 55.75, lng: 37.6 },  // Moscow
      { lat: 22.3, lng: 114.2 },  // Hong Kong
      { lat: 48.9, lng: 2.35 },   // Paris
      { lat: -23.5, lng: -46.6 }, // São Paulo
      { lat: 25.2, lng: 55.3 },   // Dubai
      { lat: 40.7, lng: -74 },    // New York
    ];

    function toVec3(lat: number, lng: number, r: number): THREE.Vector3 {
      const phi = (90 - lat) * (Math.PI / 180);
      const theta = (lng + 180) * (Math.PI / 180);
      return new THREE.Vector3(
        -r * Math.sin(phi) * Math.cos(theta),
        r * Math.cos(phi),
        r * Math.sin(phi) * Math.sin(theta)
      );
    }

    const dotGeo = new THREE.SphereGeometry(0.025, 8, 8);
    const haloGeo = new THREE.SphereGeometry(0.05, 8, 8);

    cities.forEach((c) => {
      const pos = toVec3(c.lat, c.lng, 1.01);
      const dot = new THREE.Mesh(dotGeo, new THREE.MeshBasicMaterial({ color: orange }));
      dot.position.copy(pos);
      globe.add(dot);

      const halo = new THREE.Mesh(haloGeo, new THREE.MeshBasicMaterial({ color: orange, transparent: true, opacity: 0.3 }));
      halo.position.copy(pos);
      globe.add(halo);
    });

    // Connection arcs
    const links = [[0,1],[0,5],[0,7],[2,11],[2,1],[3,8],[3,6],[4,5],[10,6],[9,11]];
    links.forEach(([a, b]) => {
      const vA = toVec3(cities[a].lat, cities[a].lng, 1.01);
      const vB = toVec3(cities[b].lat, cities[b].lng, 1.01);
      const mid = new THREE.Vector3().addVectors(vA, vB).multiplyScalar(0.5);
      mid.normalize().multiplyScalar(1 + vA.distanceTo(vB) * 0.2);

      const curve = new THREE.QuadraticBezierCurve3(vA, mid, vB);
      const geo = new THREE.BufferGeometry().setFromPoints(curve.getPoints(32));
      globe.add(new THREE.Line(geo, new THREE.LineBasicMaterial({ color: orange, transparent: true, opacity: 0.2 })));
    });

    // Atmosphere glow — simple scaled translucent sphere instead of custom shader
    const atmosGeo = new THREE.SphereGeometry(1.12, 32, 32);
    const atmosMat = new THREE.MeshBasicMaterial({
      color: 0xf0622a,
      transparent: true,
      opacity: 0.06,
      side: THREE.BackSide,
    });
    globe.add(new THREE.Mesh(atmosGeo, atmosMat));

    // Tilt
    globe.rotation.x = 0.3;
    globe.rotation.z = -0.1;

    // Animation
    let animId: number;
    let time = 0;

    function animate() {
      animId = requestAnimationFrame(animate);
      time += 0.001;
      globe.position.x = Math.sin(time * 0.7) * 1.2;
      globe.position.y = Math.sin(time * 1.4) * 0.4;
      globe.position.z = Math.cos(time * 0.5) * 0.3;
      globe.rotation.y += 0.0015;
      renderer.render(scene, camera);
    }

    animate();
    console.log('[HeroGlobe] Running ✓', width, 'x', height);

    // Resize
    function onResize() {
      width = section!.clientWidth;
      height = section!.clientHeight;
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
      renderer.setSize(width, height);
    }
    window.addEventListener('resize', onResize);

    // Cleanup
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animId);
      window.removeEventListener('resize', onResize);
      renderer.dispose();
    }, { once: true });
  }

  function init() {
    const canvases = document.querySelectorAll<HTMLCanvasElement>('.hero-globe-canvas');
    console.log('[HeroGlobe] Found', canvases.length, 'canvas(es)');
    canvases.forEach((canvas) => {
      if (!canvas.dataset.initialized) {
        canvas.dataset.initialized = 'true';
        try {
          initGlobe(canvas);
        } catch (e) {
          console.error('[HeroGlobe] Init failed:', e);
        }
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:after-swap', init);
</script>
