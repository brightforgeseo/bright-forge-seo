---
/**
 * 3D-style static network globe for the homepage hero.
 * Desktop only, no Three.js, no canvas, no mobile request.
 */
---

<div class="hero-globe-fallback" aria-hidden="true">
  <picture class="original-globe">
    <source media="(min-width: 1025px)" srcset="/images/hero-globe-network-v2.svg" />
    <img
      src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw=="
      alt=""
      width="900"
      height="620"
      loading="eager"
      decoding="async"
    />
  </picture>
</div>

<style>
  .hero-globe-fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
    opacity: 0.98;
    overflow: hidden;
  }

  .hero-globe-fallback::before {
    content: '';
    position: absolute;
    right: -11%;
    top: -14%;
    width: min(78vw, 62rem);
    aspect-ratio: 1.05;
    border-radius: 999px;
    background: radial-gradient(ellipse at 62% 38%, rgba(255, 122, 53, 0.36) 0%, rgba(240, 98, 42, 0.20) 36%, rgba(196, 78, 22, 0.08) 58%, transparent 74%);
    filter: blur(18px);
    transform: translateX(10%);
  }

  .original-globe {
    position: absolute;
    right: clamp(-6.5rem, -5vw, -3.5rem);
    top: clamp(-5.25rem, -6vw, -2.75rem);
    width: min(66vw, 54rem);
    height: auto;
    display: block;
  }

  .original-globe img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 1024px) {
    .hero-globe-fallback {
      display: none;
    }
  }
</style>
