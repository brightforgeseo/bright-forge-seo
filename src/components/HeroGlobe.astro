---
/**
 * 3D-style static network globe for the homepage hero.
 * Desktop only, no Three.js, no canvas, no mobile request.
 */
---

<div class="hero-globe-fallback" aria-hidden="true">
  <picture class="original-globe">
    <source media="(min-width: 1025px)" srcset="/images/hero-globe-network-v2.svg" />
    <img
      src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw=="
      alt=""
      width="900"
      height="620"
      loading="eager"
      decoding="async"
    />
  </picture>
</div>

<style>
  .hero-globe-fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
    opacity: 0.98;
    overflow: hidden;
  }

  .hero-globe-fallback::before {
    content: '';
    position: absolute;
    right: 7%;
    top: 7%;
    width: min(48vw, 38rem);
    aspect-ratio: 1;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(240, 98, 42, 0.28) 0%, rgba(240, 98, 42, 0.14) 34%, transparent 68%);
    filter: blur(10px);
    transform: translateX(8%);
  }

  .original-globe {
    position: absolute;
    right: clamp(3rem, 5vw, 5rem);
    top: clamp(1rem, 3vw, 2.5rem);
    width: min(44vw, 36rem);
    height: auto;
    display: block;
  }

  .original-globe img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 1024px) {
    .hero-globe-fallback {
      display: none;
    }
  }
</style>
