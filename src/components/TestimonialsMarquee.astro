<script is:inline>
(function() {
  var allPages = document.querySelectorAll('.tm-page');
  var prevBtn = document.querySelector('.tm-prev');
  var nextBtn = document.querySelector('.tm-next');
  var dots = document.querySelectorAll('.tm-dot');
  if (!allPages.length) return;

  var current = 0;
  var total = allPages.length;

  function show(idx) {
    current = idx;
    allPages.forEach(function(p, i) {
      if (i === current) {
        p.classList.add('active');
        p.style.animation = 'none';
        void p.getAnimations();
        requestAnimationFrame(function() { p.style.animation = ''; });
      } else {
        p.classList.remove('active');
      }
    });
    dots.forEach(function(d, i) {
      d.className = 'tm-dot' + (i === current ? ' active' : '');
    });
    prevBtn.disabled = current <= 0;
    nextBtn.disabled = current >= total - 1;
  }

  prevBtn.addEventListener('click', function() {
    if (current > 0) show(current - 1);
  });

  nextBtn.addEventListener('click', function() {
    if (current < total - 1) show(current + 1);
  });

  dots.forEach(function(dot) {
    dot.addEventListener('click', function() {
      show(parseInt(this.dataset.dot));
    });
  });

  show(0);
})();
</script>
