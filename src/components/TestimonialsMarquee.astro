<section class="testimonials-section">
  <div class="testimonials-wrapper">

    <!-- Header -->
    <div class="tm-header">
      <div class="tm-header-left">
        <div class="tm-eyebrow">Client testimonials</div>
        <h2 class="tm-title">What our clients<br><span>say about us</span></h2>
      </div>
      <div class="tm-header-right">
        <div class="tm-rating-badge">
          <div class="tm-stars">
            {[...Array(5)].map(() => (
              <svg class="tm-star" viewBox="0 0 20 20" fill="currentColor"><path d={starPath}/></svg>
            ))}
          </div>
          <span class="tm-rating-text"><strong>5.0</strong> on Google</span>
        </div>
        <div class="tm-slider-nav">
          <button class="tm-slider-btn tm-prev" aria-label="Previous reviews">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="tm-slider-btn tm-next" aria-label="Next reviews">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Pages -->
    <div class="tm-pages">
      {pages.map((group, pageIdx) => (
        <div class={`tm-page ${pageIdx === 0 ? 'active' : ''}`} data-page={pageIdx}>
          <!-- Top featured card -->
          <a href={group[0].reviewLink} target="_blank" rel="noopener noreferrer" class="tm-card tm-featured">
            <div>
              <div class="tm-card-stars">
                {[...Array(5)].map(() => (
                  <svg class="tm-card-star" viewBox="0 0 20 20"><path d={starPath}/></svg>
                ))}
              </div>
              <div class="tm-quote-mark">&ldquo;</div>
              <p class="tm-review-text tm-featured-text">{group[0].quote}</p>
            </div>
            <div class="tm-author">
              <div class={`tm-avatar ${group[0].avatarClass}`}>{group[0].initial}</div>
              <div class="tm-author-info">
                <div class="tm-author-name">{group[0].name}</div>
                <div class="tm-author-meta">{group[0].meta}</div>
              </div>
              <svg class="tm-google-badge" viewBox="0 0 24 24" fill="none">
                {googleBadgePaths.map((p) => <path d={p.d} fill={p.fill}/>)}
              </svg>
            </div>
          </a>

          <!-- Bottom 3-card grid -->
          {group.length > 1 && (
            <div class="tm-grid">
              {group.slice(1).map((t) => (
                <a href={t.reviewLink} target="_blank" rel="noopener noreferrer" class="tm-card">
                  <div>
                    <div class="tm-card-stars">
                      {[...Array(5)].map(() => (
                        <svg class="tm-card-star" viewBox="0 0 20 20"><path d={starPath}/></svg>
                      ))}
                    </div>
                    <div class="tm-quote-mark">&ldquo;</div>
                    <p class="tm-review-text">{t.quote}</p>
                  </div>
                  <div class="tm-author">
                    <div class={`tm-avatar ${t.avatarClass}`}>{t.initial}</div>
                    <div class="tm-author-info">
                      <div class="tm-author-name">{t.name}</div>
                      <div class="tm-author-meta">{t.meta}</div>
                    </div>
                    <svg class="tm-google-badge" viewBox="0 0 24 24" fill="none">
                      {googleBadgePaths.map((p) => <path d={p.d} fill={p.fill}/>)}
                    </svg>
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Dots -->
    <div class="tm-dots">
      {pages.map((_, i) => (
        <button class={`tm-dot ${i === 0 ? 'active' : ''}`} data-dot={i} aria-label={`Page ${i + 1}`}></button>
      ))}
    </div>

  </div>
</section>

<style>
  .testimonials-section {
    background: #0d0f1a;
    padding: 6rem 24px;
    position: relative;
    overflow: hidden;
  }

  .testimonials-section::before {
    content: '';
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 600px;
    background: radial-gradient(ellipse, rgba(240,98,42,0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .testimonials-wrapper {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
  }

  /* Header */
  .tm-header {
    margin-bottom: 64px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .tm-header-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .tm-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #f0622a;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tm-eyebrow::before {
    content: '';
    display: block;
    width: 28px;
    height: 1.5px;
    background: #f0622a;
  }

  .tm-title {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(36px, 5vw, 60px);
    font-weight: 800;
    line-height: 1.08;
    color: #ffffff;
    letter-spacing: -0.02em;
  }

  .tm-title span {
    color: #f0622a;
  }

  .tm-rating-badge {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #131627;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 100px;
    padding: 12px 20px;
    white-space: nowrap;
  }

  .tm-stars {
    display: flex;
    gap: 3px;
  }

  .tm-star {
    width: 14px;
    height: 14px;
    color: #f5b327;
  }

  .tm-rating-text {
    font-size: 13px;
    font-weight: 500;
    color: #e8eaf2;
  }

  .tm-rating-text strong {
    color: #ffffff;
  }

  /* Nav arrows */
  .tm-slider-nav {
    display: flex;
    gap: 8px;
  }

  .tm-slider-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #131627;
    border: 1px solid rgba(255,255,255,0.1);
    color: #e0e3ef;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .tm-slider-btn:hover {
    background: #1a1e32;
    border-color: rgba(240,98,42,0.4);
    color: #f0622a;
  }

  .tm-slider-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  /* Pages */
  .tm-pages {
    position: relative;
  }

  .tm-page {
    display: none;
    animation: tmPageIn 0.45s cubic-bezier(0.23,1,0.32,1) forwards;
  }

  .tm-page.active {
    display: block;
  }

  @keyframes tmPageIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Grid */
  .tm-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  /* Cards */
  .tm-card {
    background: #131627;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 20px;
    padding: 36px 32px 28px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 28px;
    position: relative;
    overflow: hidden;
    transition: transform 0.35s cubic-bezier(0.23,1,0.32,1), border-color 0.25s ease, box-shadow 0.35s ease;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .tm-card:hover {
    transform: translateY(-4px);
    border-color: rgba(240,98,42,0.3);
    box-shadow: 0 24px 48px rgba(0,0,0,0.4), 0 0 0 1px rgba(240,98,42,0.12);
