  .av-ri { background: linear-gradient(135deg, #ef4444, #f0622a); }
  .av-l { background: linear-gradient(135deg, #10b981, #34d399); }
  .av-m { background: linear-gradient(135deg, #8b5cf6, #c084fc); }
  .av-k { background: linear-gradient(135deg, #0ea5e9, #38bdf8); }
  .av-g { background: linear-gradient(135deg, #f59e0b, #fbbf24); }
  .av-u { background: linear-gradient(135deg, #14b8a6, #5eead4); }
  .av-d { background: linear-gradient(135deg, #ec4899, #f472b6); }
  .av-a { background: linear-gradient(135deg, #8b5cf6, #a78bfa); }
  .av-s { background: linear-gradient(135deg, #3b82f6, #60a5fa); }
  .av-t { background: linear-gradient(135deg, #22c55e, #4ade80); }

  .tm-author-name {
