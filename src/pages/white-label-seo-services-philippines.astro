---
import MainLayout from '../layouts/MainLayout.astro';
import LegacyHeader from '../components/LegacyHeader.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';
import Hero from '../components/Hero.astro';
import ButtonPrimary from '../components/ButtonPrimary.astro';
import ButtonSecondary from '../components/ButtonSecondary.astro';

const faqs = [
  {
    question: 'How does white label SEO outsourcing work?',
    answer: 'Your agency keeps the client relationship. We work behind the scenes on SEO strategy, audits, technical fixes, content direction, reporting, and campaign support. Deliverables can be prepared under your brand, and we do not contact your clients unless you explicitly ask us to join a call or support a handover.'
  },
  {
    question: 'Can reports use our agency branding?',
    answer: 'Yes. White label reporting can be prepared for client presentation with your agency name, tone, and preferred structure. We can also provide internal notes for your team so you understand the evidence, priorities, and next steps before anything reaches the client.'
  },
  {
    question: 'Do you work directly with our clients?',
    answer: 'Not by default. Our normal role is behind-the-scenes SEO support. If you want us to support a technical call, discovery session, or handover, we agree the rules first so your client relationship stays protected.'
  },
  {
    question: 'What SEO work can you handle for agency partners?',
    answer: 'We can support SEO audits, keyword research, technical SEO, on-page SEO, content briefs, content optimisation, local SEO, internal linking, link quality review, AI search readiness, and monthly client reporting. Scope is agreed per client so delivery stays practical.'
  },
  {
    question: 'Is this the same as hiring a cheap offshore SEO VA?',
    answer: 'No. A VA can be useful for task support, but white label SEO delivery needs strategy, prioritisation, QA, and judgement. We focus on work your agency can confidently present to clients, with evidence behind recommendations and senior SEO review before delivery.'
  },
  {
    question: 'Do you offer white label link building?',
    answer: 'We can support link strategy, prospect review, outreach direction, and quality control. We do not sell spam link packages, fake authority, or risky shortcuts that could damage your client relationships.'
  },
  {
    question: 'How quickly can a white label SEO partnership start?',
    answer: 'For a simple audit or advisory project, we can usually scope the work quickly once we have the site, market, access requirements, and client objectives. For ongoing monthly fulfilment, we start with a short onboarding process so reporting, communication, and responsibilities are clear.'
  },
  {
    question: 'Can you support agencies outside the Philippines?',
    answer: 'Yes. Bright Forge is based in the Philippines and can support agencies serving clients in the Philippines, Australia, the UK, the US, Singapore, and other English-language markets.'
  }
];
---

<MainLayout
  title="SEO Outsourcing Philippines for Agencies | White Label SEO"
  description="White label SEO outsourcing from the Philippines for agencies that need strategy, fulfilment, QA, and client-ready reporting under their own brand."
  canonical="https://brightforge.com.ph/white-label-seo-services-philippines/"
  type="service"
  faqs={faqs}
>
  <LegacyHeader slot="header" />

  <Hero
    badgeIcon="fas fa-handshake"
    badgeText="White Label SEO Partners"
    title="SEO Outsourcing Philippines for Agencies That Need Reliable White Label Delivery"
    breadcrumbCurrent="White Label SEO Services Philippines"
  >
    <Fragment slot="story">
      <p>We support agencies, consultants, web teams, and marketing providers with behind-the-scenes SEO strategy, fulfilment, quality control, and client-ready reporting.</p>
      <p>You keep the client relationship. We help make the SEO work accurate, explainable, commercially useful, and safe to put your name on.</p>
      <p>Our white label SEO outsourcing from the Philippines is built for agencies that need senior SEO judgement, practical delivery, and clear communication without hiring a full in-house team.</p>
    </Fragment>

    <Fragment slot="actions">
      <ButtonPrimary href="/contact/" text="Discuss a White Label Partnership" />
      <ButtonSecondary href="#what-we-handle" text="See What We Can Handle" />
    </Fragment>

    <Fragment slot="visual">
      <div class="partnership-visual" aria-label="White label SEO delivery workflow">
        <div class="workflow-node agency">
          <span>Agency</span>
          <strong>Owns client relationship</strong>
        </div>
        <div class="workflow-line"></div>
        <div class="workflow-node forge">
          <span>Bright Forge</span>
          <strong>Handles SEO delivery</strong>
        </div>
        <div class="workflow-line"></div>
        <div class="workflow-node client">
          <span>Client</span>
          <strong>Receives branded reports</strong>
        </div>
      </div>
    </Fragment>
  </Hero>

  <section class="proof-strip" aria-label="White label SEO proof points">
    <div class="container">
      <div class="proof-grid">
        <div><strong>Senior SEO review</strong><span>Before client delivery</span></div>
        <div><strong>White label reports</strong><span>Prepared for your brand</span></div>
        <div><strong>No client poaching</strong><span>Your relationship stays yours</span></div>
        <div><strong>Flexible support</strong><span>Audit, monthly, or overflow</span></div>
      </div>
    </div>
  </section>

  <section class="section dark" id="who-for">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Who this is for</p>
        <h2>SEO outsourcing for agencies that need depth without payroll drag</h2>
        <p class="lead">This page is not for businesses looking for a cheap SEO package. It is for agency teams that already own client trust and need a reliable SEO partner behind them.</p>
      </div>
      <div class="card-grid small">
        <article class="card"><h3>Web design agencies</h3><p>Add technical SEO, content SEO, and launch support without turning your studio into an SEO department.</p></article>
        <article class="card"><h3>PPC and social agencies</h3><p>Keep clients longer by adding organic search strategy alongside paid acquisition.</p></article>
        <article class="card"><h3>Freelancers and consultants</h3><p>Bring in SEO depth when client requirements move beyond your delivery capacity.</p></article>
        <article class="card"><h3>Overloaded SEO teams</h3><p>Use us for audits, overflow work, reporting, and specialist review when internal capacity is tight.</p></article>
      </div>
    </div>
  </section>

  <section class="section darker" id="what-we-handle">
    <div class="container">
      <div class="section-head centered">
        <p class="eyebrow">What we handle</p>
        <h2>White label SEO services your agency can safely resell</h2>
        <p>We focus on work that improves client visibility and gives your team clear evidence, priorities, and next steps.</p>
      </div>

      <div class="service-grid">
        <article class="service-card"><i class="fas fa-search"></i><h3>SEO audits</h3><p>Technical, content, search intent, indexation, competitor, and conversion checks with prioritised fixes.</p></article>
        <article class="service-card"><i class="fas fa-sitemap"></i><h3>Technical SEO</h3><p>Crawlability, internal linking, schema, page speed guidance, redirects, canonicals, and migration support.</p></article>
        <article class="service-card"><i class="fas fa-key"></i><h3>Keyword research</h3><p>Buyer-led keyword maps, content opportunities, page targeting, and practical search demand analysis.</p></article>
        <article class="service-card"><i class="fas fa-pen-nib"></i><h3>Content SEO</h3><p>AI Prompts, content optimisation, gap analysis, editorial review, briefs, and page rewrites built for ranking and conversion.</p></article>
        <article class="service-card"><i class="fas fa-map-marker-alt"></i><h3>Local SEO</h3><p>Google Business Profile checks, local landing page improvements, citation direction, and local SERP analysis.</p></article>
        <article class="service-card"><i class="fas fa-link"></i><h3>Link quality support</h3><p>Backlink audits, prospect review, link risk checks, and white-hat outreach direction. No spam packages.</p></article>
        <article class="service-card"><i class="fas fa-chart-line"></i><h3>Client reporting</h3><p>Monthly updates written for stakeholders, with rankings, traffic, work completed, issues, and next priorities.</p></article>
        <article class="service-card"><i class="fas fa-robot"></i><h3>AI search readiness</h3><p>Entity clarity, answer-ready page structure, schema, llms.txt guidance, and AI visibility recommendations.</p></article>
      </div>
    </div>
  </section>

  <section class="section dark" id="process">
    <div class="container">
      <div class="section-head centered">
        <p class="eyebrow">How the partnership works</p>
        <h2>A clean operating model for outsourced SEO delivery</h2>
        <p>The process is designed to protect your client relationship, reduce rework, and keep everyone clear on scope.</p>
      </div>

      <div class="timeline">
        <article><span>01</span><h3>Partnership fit</h3><p>We review your agency model, client type, preferred communication style, and the SEO support you need.</p></article>
        <article><span>02</span><h3>Scope and access</h3><p>We agree deliverables, timelines, data access, reporting format, and how requests should be handled.</p></article>
        <article><span>03</span><h3>SEO review</h3><p>We audit the site, market, competitors, content, technical setup, and search opportunities before making recommendations.</p></article>
        <article><span>04</span><h3>Delivery and QA</h3><p>Work is checked for accuracy, impact, client-readiness, and risk before it is sent back to your team.</p></article>
        <article><span>05</span><h3>White label report</h3><p>You receive a clear report your agency can present, plus optional internal notes for your own team.</p></article>
        <article><span>06</span><h3>Next-month priorities</h3><p>Ongoing support focuses on what matters next, not activity for the sake of a monthly retainer.</p></article>
      </div>
    </div>
  </section>

  <section class="section split-section">
    <div class="container split-grid">
      <div class="panel bright">
        <p class="eyebrow">What your client sees</p>
        <h2>Clear SEO work presented under your agency brand</h2>
        <ul class="check-list">
          <li>Branded SEO reports and summaries</li>
          <li>Plain-English explanation of what changed and why</li>
          <li>Ranking, traffic, conversion, and visibility movement</li>
          <li>Completed work, current blockers, and next priorities</li>
          <li>Technical notes your developers can act on</li>
          <li>Recommendations supported by evidence, not tool screenshots alone</li>
        </ul>
      </div>
      <div class="panel dark-panel">
        <p class="eyebrow">What your agency gets</p>
        <h2>Behind-the-scenes SEO judgement and delivery support</h2>
        <ul class="check-list">
          <li>Scope clarity before work starts</li>
          <li>Strategic notes for your account team</li>
          <li>Senior SEO review before client delivery</li>
          <li>Optional talking points for client calls</li>
          <li>Practical prioritisation by impact and effort</li>
          <li>A partner who will not contact or poach your clients</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section darker" id="standards">
    <div class="container two-col reversed">
      <div class="standards-card">
        <h3>Our delivery standards</h3>
        <ul>
          <li>Every major recommendation needs evidence.</li>
          <li>Reports should be useful to clients, not padded with SEO theatre.</li>
          <li>Technical fixes should include priority, impact, and implementation notes.</li>
          <li>Content recommendations should match search intent and conversion intent.</li>
          <li>AI-assisted drafts need human editorial review before client use.</li>
          <li>Risky tactics are called out, not hidden in monthly activity logs.</li>
        </ul>
      </div>
      <div>
        <p class="eyebrow">Why agencies trust specialist SEO outsourcing</p>
        <h2>Cheaper fulfilment is easy to find. Client-safe SEO delivery is harder.</h2>
        <p class="lead">The danger with SEO outsourcing is not just bad rankings. It is poor judgement reaching your client under your name. Our role is to help your agency deliver work that is commercially sound, technically accurate, and easy to explain.</p>
        <p>We are not trying to replace your account team. We give them stronger SEO substance, clearer priorities, and work they can confidently take back to the client.</p>
      </div>
    </div>
  </section>

  <section class="section dark comparison-section">
    <div class="container">
      <div class="section-head centered">
        <p class="eyebrow">Choosing a delivery model</p>
        <h2>SEO outsourcing Philippines vs other fulfilment options</h2>
      </div>

      <div class="comparison-grid">
        <article><h3>Hiring in-house</h3><p>Best when SEO is a core long-term department. Expensive if client demand is still uneven or project-based.</p></article>
        <article><h3>Hiring a freelancer</h3><p>Flexible, but quality and availability can vary. Often limited when technical, content, reporting, and strategy all collide.</p></article>
        <article><h3>Using a BPO team</h3><p>Useful for repeatable tasks, but not always strong on senior SEO judgement, prioritisation, or client-facing explanations.</p></article>
        <article class="highlight"><h3>Working with Bright Forge</h3><p>Designed for agencies that need strategic SEO support, fulfilment, QA, and white label reporting without adding fixed payroll.</p></article>
      </div>
    </div>
  </section>

  <section class="section darker no-section">
    <div class="container two-col">
      <div>
        <p class="eyebrow">What we will not do</p>
        <h2>No spam. No fake guarantees. No client poaching.</h2>
        <p class="lead">White label SEO only works when the partner is safe. These are the lines we will not cross.</p>
      </div>
      <div class="no-grid">
        <div>No spam link packages</div>
        <div>No fake ranking guarantees</div>
        <div>No recycled AI content dumps</div>
        <div>No vague activity reports</div>
        <div>No direct client contact without approval</div>
        <div>No pretending every task has equal SEO value</div>
      </div>
    </div>
  </section>

  <section class="section dark engagement-section">
    <div class="container">
      <div class="section-head centered">
        <p class="eyebrow">Engagement models</p>
        <h2>Flexible SEO outsourcing support for different agency needs</h2>
      </div>

      <div class="engagement-grid">
        <article><h3>One-off audit support</h3><p>Use us for technical audits, content audits, migration reviews, ranking drops, or pre-sales SEO diagnostics.</p></article>
        <article><h3>Monthly white label SEO</h3><p>Ongoing support for retained clients, including reporting, optimisation, and next-step planning.</p></article>
        <article><h3>Overflow fulfilment</h3><p>Bring us in when your internal team is busy, launching, hiring, or dealing with too many client deadlines.</p></article>
        <article><h3>Specialist review</h3><p>Use us as a senior SEO check before recommendations, reports, or technical findings go to a client.</p></article>
      </div>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container narrow">
      <div class="section-head centered">
        <p class="eyebrow">White label SEO FAQs</p>
        <h2>Questions agencies ask before outsourcing SEO</h2>
      </div>

      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container narrow cta-box">
      <p class="eyebrow">Ready to talk?</p>
      <h2>Discuss white label SEO outsourcing for your agency</h2>
      <p>Tell us what your agency needs to deliver, where the pressure points are, and what level of behind-the-scenes SEO support would make client work easier.</p>
      <div class="cta-actions">
        <a href="/contact/" class="cta-primary">Discuss a White Label Partnership</a>
        <a href="/seo-services-philippines/" class="cta-secondary">View SEO Services</a>
      </div>
    </div>
  </section>

  <ContactSection slot="contact" />
  <Footer slot="footer" />
</MainLayout>

<style>
.container {
  width: min(1180px, calc(100% - 2rem));
  margin: 0 auto;
}

.narrow {
  width: min(900px, calc(100% - 2rem));
}

.partnership-visual {
  position: relative;
  display: grid;
  gap: 1.1rem;
  max-width: 480px;
  margin: 0 auto;
  padding: 1.5rem;
  border: 1px solid rgba(255, 107, 53, 0.25);
  border-radius: 28px;
  background: linear-gradient(145deg, rgba(19, 22, 39, 0.96), rgba(13, 15, 26, 0.92));
  box-shadow: 0 25px 80px rgba(0, 0, 0, 0.35);
}

.workflow-node {
  padding: 1.2rem;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.workflow-node span {
  display: block;
  color: #ff8a5c;
  font-size: 0.82rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 0.35rem;
}

.workflow-node strong {
  display: block;
  color: #fff;
  font-size: 1.05rem;
}

.workflow-line {
  height: 26px;
  width: 2px;
  background: linear-gradient(#ff6b35, transparent);
  margin-left: 1.2rem;
}

.proof-strip {
  background: #0d0f1a;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  padding: 1.5rem 0;
}

.proof-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
}

.proof-grid div {
  padding: 1.1rem;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.045);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.proof-grid strong,
.proof-grid span {
  display: block;
}

.proof-grid strong {
  color: #fff;
  margin-bottom: 0.25rem;
}

.proof-grid span {
  color: #cfd3e6;
  font-size: 0.92rem;
}

.section {
  padding: 5.5rem 0;
}

.dark {
  background: #131627;
}

.darker {
  background: #0d0f1a;
}

.two-col,
.split-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
  gap: 3rem;
  align-items: center;
}

.reversed {
  grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
}

.eyebrow {
  color: #ff8a5c;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-size: 0.82rem;
  margin-bottom: 0.85rem;
}

h2 {
  color: #fff;
  font-size: clamp(2rem, 4vw, 3.2rem);
  line-height: 1.05;
  margin-bottom: 1.25rem;
}

h3 {
  color: #fff;
  font-size: 1.2rem;
  margin-bottom: 0.75rem;
}

p,
li {
  color: #d0d4e8;
  line-height: 1.75;
}

.lead {
  font-size: 1.15rem;
  color: #e4e7f5;
}

.section-head {
  max-width: 820px;
  margin-bottom: 3rem;
}

.centered {
  text-align: center;
  margin-left: auto;
  margin-right: auto;
}

.card-grid,
.service-grid,
.timeline,
.comparison-grid,
.engagement-grid {
  display: grid;
  gap: 1.25rem;
}

.card-grid.small {
  grid-template-columns: repeat(2, 1fr);
}

.card,
.service-card,
.timeline article,
.comparison-grid article,
.engagement-grid article,
.panel,
.standards-card,
.faq-item {
  background: rgba(255, 255, 255, 0.055);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 22px;
  padding: 1.5rem;
}

.service-grid {
  grid-template-columns: repeat(4, 1fr);
}

.service-card i {
  display: inline-grid;
  place-items: center;
  width: 46px;
  height: 46px;
  margin-bottom: 1rem;
  border-radius: 14px;
  color: #fff;
  background: linear-gradient(135deg, #ff6b35, #ff9f1c);
}

.timeline {
  grid-template-columns: repeat(3, 1fr);
}

.timeline span {
  display: inline-block;
  color: #ff8a5c;
  font-weight: 800;
  margin-bottom: 0.9rem;
}

.split-section {
  background: linear-gradient(135deg, #0d0f1a, #171b31);
}

.panel.bright {
  background: linear-gradient(135deg, rgba(255, 107, 53, 0.18), rgba(255, 159, 28, 0.08));
  border-color: rgba(255, 107, 53, 0.28);
}

.dark-panel {
  background: rgba(13, 15, 26, 0.8);
}

.check-list,
.standards-card ul {
  list-style: none;
  padding: 0;
  margin: 1.25rem 0 0;
}

.check-list li,
.standards-card li {
  position: relative;
  padding-left: 1.75rem;
  margin-bottom: 0.8rem;
}

.check-list li::before,
.standards-card li::before {
  content: '✓';
  position: absolute;
  left: 0;
  color: #ff8a5c;
  font-weight: 800;
}

.standards-card {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.035));
}

.comparison-grid {
  grid-template-columns: repeat(4, 1fr);
}

.comparison-grid .highlight {
  border-color: rgba(255, 107, 53, 0.45);
  background: linear-gradient(145deg, rgba(255, 107, 53, 0.16), rgba(255, 255, 255, 0.04));
}

.no-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}

.no-grid div {
  padding: 1.1rem;
  border-radius: 16px;
  color: #fff;
  background: rgba(255, 255, 255, 0.055);
  border: 1px solid rgba(255, 107, 53, 0.18);
}

.engagement-grid {
  grid-template-columns: repeat(4, 1fr);
}

.faq-section {
  background: #131627;
}

.faq-list {
  display: grid;
  gap: 1rem;
}

.faq-item summary {
  cursor: pointer;
  color: #fff;
  font-weight: 700;
  font-size: 1.08rem;
}

.faq-item p {
  margin-top: 1rem;
}

.cta-section {
  padding: 5rem 0;
  background: #0d0f1a;
}

.cta-box {
  text-align: center;
  padding: 3rem;
  border-radius: 28px;
  background: linear-gradient(135deg, rgba(255, 107, 53, 0.18), rgba(255, 159, 28, 0.08));
  border: 1px solid rgba(255, 107, 53, 0.28);
}

.cta-actions {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 1rem;
  margin-top: 2rem;
}

.cta-primary,
.cta-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48px;
  padding: 0.85rem 1.4rem;
  border-radius: 999px;
  font-weight: 800;
  text-decoration: none;
}

.cta-primary {
  color: #0d0f1a;
  background: #fff;
}

.cta-secondary {
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.35);
}

@media (max-width: 980px) {
  .proof-grid,
  .service-grid,
  .timeline,
  .comparison-grid,
  .engagement-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .two-col,
  .split-grid,
  .reversed {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 640px) {
  .section {
    padding: 4rem 0;
  }

  .proof-grid,
  .service-grid,
  .timeline,
  .comparison-grid,
  .engagement-grid,
  .card-grid.small,
  .no-grid {
    grid-template-columns: 1fr;
  }

  .cta-box {
    padding: 2rem 1.25rem;
  }
}
</style>
