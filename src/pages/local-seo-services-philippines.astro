---
import MainLayout from '../layouts/MainLayout.astro';
import LegacyHeader from '../components/LegacyHeader.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';
import Hero from '../components/Hero.astro';
import ButtonPrimary from '../components/ButtonPrimary.astro';
import ButtonSecondary from '../components/ButtonSecondary.astro';

const proofItems = [
  {
    title: 'Google Business Profile first',
    copy: 'We treat your GBP as a commercial asset, not a directory listing. Categories, services, photos, posts, reviews, Q&A and tracking all need to support enquiries.'
  },
  {
    title: 'Local search plus conversion',
    copy: 'Local SEO should lead to calls, direction requests, form fills and booked jobs. Rankings are useful only when the page and profile help people choose you.'
  },
  {
    title: 'Clean local signals',
    copy: 'We fix inconsistent NAP data, weak location pages, thin service pages, duplicate listings and citation gaps that make local trust harder to build.'
  }
];

const serviceBlocks = [
  {
    title: 'Google Business Profile optimisation',
    copy: 'We review categories, services, business description, opening hours, service areas, products, photos, posts, Q&A, tracking links and profile completeness. The goal is a profile that is accurate, active and built around how customers search.'
  },
  {
    title: 'Google Maps and local pack strategy',
    copy: 'We identify the search terms, locations and competitor profiles that matter, then improve the signals that influence map visibility: relevance, proximity, prominence, reviews, landing pages and business data consistency.'
  },
  {
    title: 'Citation and NAP cleanup',
    copy: 'We check whether your business name, address, phone number, website and core details are consistent across important local platforms, directories and data sources. Messy citations weaken trust and waste effort.'
  },
  {
    title: 'Review growth and response systems',
    copy: 'We help build ethical review collection and response processes. No fake reviews, no spam, no risky shortcuts. Local trust comes from real customer feedback handled professionally.'
  },
  {
    title: 'Location and service page support',
    copy: 'We improve the pages connected to your local visibility, including city pages, service pages and contact pages. GBP traffic often leaks if the landing page is weak, slow, generic or unclear.'
  },
  {
    title: 'Local SEO tracking and reporting',
    copy: 'We track the metrics that matter: local rankings, GBP actions, calls, website clicks, direction requests, form enquiries, Search Console visibility and changes in qualified lead flow.'
  }
];

const fitBlocks = [
  {
    title: 'Service-area businesses',
    copy: 'Plumbers, clinics, repair companies, trades, consultants, legal services, cleaning companies and other businesses that need calls or enquiries from a defined location.'
  },
  {
    title: 'Physical locations',
    copy: 'Shops, offices, clinics, showrooms, gyms, restaurants, schools and customer-facing locations that need stronger visibility in Maps and near-me searches.'
  },
  {
    title: 'Multi-location brands',
    copy: 'Businesses with several branches that need consistent GBP management, location-page structure, review standards and reporting across each location.'
  },
  {
    title: 'Growing businesses with messy local data',
    copy: 'Companies with duplicate listings, old phone numbers, moved addresses, inconsistent citations, weak reviews or location pages that do not convert.'
  }
];

const processSteps = [
  {
    label: '01',
    title: 'Local visibility audit',
    copy: 'We review your GBP, local rankings, competitors, citations, reviews, landing pages, tracking and service-area signals. This separates real blockers from cosmetic profile tweaks.'
  },
  {
    label: '02',
    title: 'Profile and signal cleanup',
    copy: 'We correct business data, optimise categories and services, clean up listing issues, improve profile content and make sure the public information matches the website.'
  },
  {
    label: '03',
    title: 'Page and proof improvements',
    copy: 'We strengthen the pages that support local search, including service pages, location pages, internal links, trust signals, photos, reviews and clear enquiry paths.'
  },
  {
    label: '04',
    title: 'Ongoing local growth',
    copy: 'We monitor rankings, GBP actions, reviews, competitor changes, citation health and enquiry quality, then adjust the campaign around the locations and services that matter most.'
  }
];

const signals = [
  'Correct primary and secondary GBP categories',
  'Accurate business name, address, phone and opening hours',
  'Service areas that match how the business actually operates',
  'Strong service descriptions and product or service entries',
  'Fresh photos that show real people, premises, work or results',
  'Review requests and responses handled without spam or scripts',
  'Citation consistency across useful local platforms',
  'Location or service pages that match GBP intent',
  'Tracking for calls, forms, clicks and direction requests',
  'Internal links from relevant service and contact pages'
];

const faqs = [
  { question: 'What are local SEO services?', answer: 'Local SEO services improve how a business appears in Google Maps, Google Business Profile, local pack results and location-based organic searches. The work includes GBP optimisation, local landing pages, citation cleanup, review strategy, local content, tracking and ongoing performance improvements.' },
  { question: 'Is local SEO only for businesses with a physical shop?', answer: 'No. Local SEO also matters for service-area businesses such as trades, clinics, legal services, repair companies, consultants and home service providers. The strategy changes depending on whether customers visit you, you visit them, or both.' },
  { question: 'How long does local SEO take?', answer: 'Some Google Business Profile improvements can show within weeks, especially if the listing is incomplete or inconsistent. Competitive local rankings usually take two to six months depending on the market, location, reviews, website strength and competitor activity.' },
  { question: 'What is included in Google Business Profile optimisation?', answer: 'GBP optimisation can include category review, service setup, business description improvements, service-area checks, photo guidance, posts, Q&A, review response standards, tracking links, duplicate listing checks and alignment between the profile and website.' },
  { question: 'Can local SEO help us appear in Google Maps?', answer: 'Yes, that is one of the main goals. Google Maps visibility depends on relevance, proximity and prominence, so we improve the profile, reviews, citations, landing pages and local signals that help Google understand when your business is a strong result.' },
  { question: 'Do reviews affect local SEO?', answer: 'Reviews influence trust, conversion and local visibility. We do not recommend fake reviews or risky shortcuts. The right approach is a consistent review request process, professional responses and clear internal ownership so real customers are encouraged to leave useful feedback.' },
  { question: 'Do we need separate location pages?', answer: 'Usually, yes, if you serve multiple important areas or have more than one branch. Location pages should be useful, specific and connected to real services, not doorway pages created only to stuff city names into the site.' },
  { question: 'How do you measure local SEO performance?', answer: 'We measure local rankings, Google Business Profile actions, calls, website clicks, direction requests, form enquiries, Search Console visibility and landing-page performance. The goal is not just map visibility; it is more qualified local enquiries.' }
];
---

<MainLayout
  title="Local SEO Services Philippines | Google Maps & GBP"
  description="Local SEO services in the Philippines for Google Business Profile, Google Maps visibility, reviews, citations, local pages and enquiry growth."
  keywords="local SEO services Philippines, local SEO Philippines, Google Business Profile optimization Philippines, Google Maps SEO Philippines, local SEO agency Philippines"
  faqs={faqs}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://brightforge.com.ph/'
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Local SEO Services Philippines',
          item: 'https://brightforge.com.ph/local-seo-services-philippines/'
        }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: 'Local SEO Services Philippines',
      url: 'https://brightforge.com.ph/local-seo-services-philippines/',
      inLanguage: 'en',
      description: 'Local SEO services for Google Business Profile, Google Maps visibility, reviews, citations, local landing pages and enquiry growth.',
      publisher: {
        '@type': 'Organization',
        name: 'Bright Forge SEO',
        url: 'https://brightforge.com.ph/'
      },
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: serviceBlocks.map((item, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: item.title,
          description: item.copy
        }))
      }
    })} />
  </Fragment>

  <LegacyHeader slot="header" />

  <Hero
    badgeIcon="fas fa-map-marker-alt"
    badgeText="Local SEO Services"
    title="Local SEO Services Philippines for <span>Google Maps, GBP and Local Leads</span>"
    breadcrumbCurrent="Local SEO Services Philippines"
  >
    <Fragment slot="story">
      <p>Local SEO is not just about showing up on a map. It is about helping nearby customers find the right business, trust it quickly and take the next step, whether that means calling, booking, visiting, asking for directions or sending an enquiry.</p>
      <p>Bright Forge provides local SEO services in the Philippines for businesses that need stronger Google Business Profile performance, cleaner local signals, better location pages and more qualified enquiries from the areas they actually serve.</p>
    </Fragment>

    <Fragment slot="actions">
      <ButtonPrimary href="/contact/" text="Get a Local SEO Audit" />
      <ButtonSecondary href="#local-work" text="See What We Fix" />
    </Fragment>

    <Fragment slot="stats">
      <div class="hero-stats">
        <div class="stat"><strong>GBP</strong><span>Profile accuracy, services, photos, posts, Q&A and tracking.</span></div>
        <div class="stat"><strong>Maps</strong><span>Local pack visibility for the services and areas that matter.</span></div>
        <div class="stat"><strong>Leads</strong><span>Calls, forms, direction requests and website actions, not vanity traffic.</span></div>
      </div>
    </Fragment>
  </Hero>

  <section class="intro-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="intro-layout">
        <div class="intro-copy">
          <span class="eyebrow">Why local SEO matters</span>
          <h2>Local customers make quick decisions from search results</h2>
          <p>When someone searches for a nearby service, they usually compare a small set of businesses. The Google Business Profile, review quality, map position, photos, services, website and call path all influence that decision before the visitor reads a long sales page.</p>
          <p>That is why local SEO needs more than citation submissions. The business information must be accurate, the profile must be active, the website must support the same services and locations, and the enquiry path must be clear.</p>
        </div>
        <aside class="local-panel" aria-label="Local SEO commercial outcomes">
          <h3>Local SEO should support real actions</h3>
          <ul>
            <li>More qualified calls from target service areas</li>
            <li>Better visibility in Google Maps and local pack results</li>
            <li>Cleaner trust signals across business listings</li>
            <li>Stronger conversion paths from GBP to website</li>
            <li>More useful reviews and professional responses</li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <section class="proof-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="proof-grid">
        {proofItems.map((item) => (
          <article class="proof-card">
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="local-work" class="services-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-heading narrow">
        <span class="eyebrow">What we fix</span>
        <h2>Local SEO services built around Maps visibility, trust and enquiries</h2>
        <p>The work starts with the places customers actually see: your Google Business Profile, map results, review profile, service pages, location pages and local citations.</p>
      </div>
      <div class="service-list">
        {serviceBlocks.map((service) => (
          <article class="service-item">
            <h3>{service.title}</h3>
            <p>{service.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="fit-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="fit-layout">
        <div class="fit-copy">
          <span class="eyebrow">Who this is for</span>
          <h2>Best fit for businesses where location affects buying decisions</h2>
          <p>Local SEO is strongest when customers choose based on area, availability, reviews, trust and convenience. That includes both walk-in businesses and service-area companies that travel to customers.</p>
          <p>It is not a shortcut for weak service, fake reviews or low-effort city pages. The campaign has to reflect how the business really operates.</p>
        </div>
        <div class="fit-grid">
          {fitBlocks.map((fit) => (
            <article class="fit-card">
              <h3>{fit.title}</h3>
              <p>{fit.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="signals-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="signals-layout">
        <div class="signals-copy">
          <span class="eyebrow">Local trust signals</span>
          <h2>The small details decide whether local SEO works</h2>
          <p>Most local SEO failures are not caused by one dramatic issue. They are usually caused by weak signals stacking up: an incomplete profile, old phone numbers, thin service pages, no review process, generic photos, poor tracking and inconsistent business information.</p>
        </div>
        <div class="signals-list">
          {signals.map((signal) => <span>{signal}</span>)}
        </div>
      </div>
    </div>
  </section>

  <section class="process-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-heading">
        <span class="eyebrow">How we work</span>
        <h2>A local SEO process that starts with diagnosis, not guesswork</h2>
      </div>
      <div class="process-grid">
        {processSteps.map((step) => (
          <article class="process-card">
            <span>{step.label}</span>
            <h3>{step.title}</h3>
            <p>{step.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="max-w-5xl mx-auto px-6">
      <div class="cta-panel">
        <span class="eyebrow">Next step</span>
        <h2>Find out what is holding back your local visibility</h2>
        <p>We can review your Google Business Profile, local search footprint, citations, reviews, landing pages and tracking, then show where the biggest local SEO opportunities are.</p>
        <div class="cta-actions">
          <ButtonPrimary href="/contact/" text="Get a Local SEO Audit" />
          <ButtonSecondary href="/seo-services-philippines/" text="View SEO Services" />
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="max-w-5xl mx-auto px-6">
      <div class="section-heading">
        <span class="eyebrow">Questions</span>
        <h2>Local SEO questions businesses usually ask before investing</h2>
      </div>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <ContactSection />
  <Footer slot="footer" />
</MainLayout>

<style>
.hero-stats {
  display: grid;
  gap: 1rem;
  margin-top: 2rem;
}

.stat {
  background: rgba(13, 15, 26, 0.82);
  border: 1px solid rgba(240, 98, 42, 0.28);
  border-radius: 18px;
  padding: 1.25rem;
}

.stat strong {
  display: block;
  color: #ffffff;
  font-size: 1.1rem;
  margin-bottom: 0.35rem;
}

.stat span {
  color: #d0d4e8;
  line-height: 1.55;
}

.intro-section,
.services-section,
.signals-section,
.faq-section {
  background: #131627;
  padding: 5rem 0;
}

.proof-section,
.fit-section,
.process-section,
.cta-section {
  background: #0d0f1a;
  padding: 5rem 0;
}

.intro-layout,
.fit-layout,
.signals-layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(320px, 0.82fr);
  gap: 4rem;
  align-items: start;
}

.intro-copy h2,
.fit-copy h2,
.signals-copy h2,
.section-heading h2,
.cta-panel h2 {
  color: #ffffff;
  font-size: clamp(2rem, 4vw, 3.2rem);
  line-height: 1.1;
  margin: 0.75rem 0 1.25rem;
  font-weight: 850;
}

.intro-copy p,
.fit-copy p,
.signals-copy p,
.section-heading p,
.cta-panel p {
  color: #d0d4e8;
  font-size: 1.05rem;
  line-height: 1.75;
  margin-bottom: 1rem;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  color: #f0622a;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  font-size: 0.78rem;
}

.local-panel {
  background: linear-gradient(145deg, rgba(240, 98, 42, 0.12), rgba(13, 15, 26, 0.92));
  border: 1px solid rgba(240, 98, 42, 0.28);
  border-radius: 24px;
  padding: 2rem;
  position: sticky;
  top: 2rem;
}

.local-panel h3 {
  color: #ffffff;
  font-size: 1.45rem;
  margin-bottom: 1rem;
}

.local-panel ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  gap: 0.9rem;
}

.local-panel li {
  color: #e8eaf2;
  line-height: 1.55;
  padding-left: 1.45rem;
  position: relative;
}

.local-panel li::before {
  content: '';
  width: 0.5rem;
  height: 0.5rem;
  border-radius: 999px;
  background: #f0622a;
  position: absolute;
  left: 0;
  top: 0.55rem;
}

.proof-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}

.proof-card,
.service-item,
.fit-card,
.process-card,
.faq-list details {
  background: #131627;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 20px;
  padding: 1.6rem;
}

.proof-card h3,
.service-item h3,
.fit-card h3,
.process-card h3 {
  color: #ffffff;
  font-size: 1.2rem;
  margin-bottom: 0.75rem;
}

.proof-card p,
.service-item p,
.fit-card p,
.process-card p,
.faq-list p {
  color: #d0d4e8;
  line-height: 1.68;
  margin: 0;
}

.section-heading {
  text-align: center;
  max-width: 850px;
  margin: 0 auto 3rem;
}

.section-heading.narrow {
  max-width: 760px;
}

.service-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
}

.service-item {
  border-left: 4px solid #f0622a;
}

.fit-grid {
  display: grid;
  gap: 1rem;
}

.signals-list {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
}

.signals-list span {
  color: #ffffff;
  background: rgba(240, 98, 42, 0.11);
  border: 1px solid rgba(240, 98, 42, 0.24);
  border-radius: 999px;
  padding: 0.8rem 1rem;
  line-height: 1.4;
}

.process-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
}

.process-card span {
  color: #f0622a;
  font-size: 0.85rem;
  font-weight: 900;
  letter-spacing: 0.14em;
}

.cta-panel {
  background: linear-gradient(145deg, rgba(240, 98, 42, 0.18), rgba(19, 22, 39, 0.96));
  border: 1px solid rgba(240, 98, 42, 0.32);
  border-radius: 28px;
  padding: clamp(2rem, 5vw, 4rem);
  text-align: center;
}

.cta-actions {
  display: flex;
  justify-content: center;
  gap: 1rem;
  flex-wrap: wrap;
  margin-top: 2rem;
}

.faq-list {
  display: grid;
  gap: 1rem;
}

.faq-list summary {
  color: #ffffff;
  cursor: pointer;
  font-weight: 750;
  font-size: 1.05rem;
  line-height: 1.45;
}

.faq-list details[open] summary {
  color: #f0622a;
  margin-bottom: 0.9rem;
}

@media (max-width: 1024px) {
  .intro-layout,
  .fit-layout,
  .signals-layout,
  .service-list,
  .process-grid,
  .proof-grid {
    grid-template-columns: 1fr 1fr;
  }

  .local-panel {
    position: static;
  }
}

@media (max-width: 760px) {
  .intro-section,
  .services-section,
  .signals-section,
  .faq-section,
  .proof-section,
  .fit-section,
  .process-section,
  .cta-section {
    padding: 3.5rem 0;
  }

  .intro-layout,
  .fit-layout,
  .signals-layout,
  .service-list,
  .process-grid,
  .proof-grid {
    grid-template-columns: 1fr;
  }

  .cta-actions {
    flex-direction: column;
    align-items: stretch;
  }
}
</style>
