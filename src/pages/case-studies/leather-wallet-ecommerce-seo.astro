---
import MainLayout from "../../layouts/MainLayout.astro";
import LegacyHeader from "../../components/LegacyHeader.astro";
import Footer from "../../components/Footer.astro";
import Hero from "../../components/Hero.astro";
import ButtonPrimary from "../../components/ButtonPrimary.astro";
import ButtonSecondary from "../../components/ButtonSecondary.astro";

const canonical = "https://brightforge.com.ph/case-studies/leather-wallet-ecommerce-seo/";
const image = "/images/case-studies/leather-wallet-ecommerce-seo.webp";
const metrics = [
  {
    "label": "Organic clicks",
    "before": "15.2k",
    "after": "22.7k",
    "change": "+49.3%"
  },
  {
    "label": "Impressions",
    "before": "485k",
    "after": "500k",
    "change": "+3.1%"
  },
  {
    "label": "Average CTR",
    "before": "3.1%",
    "after": "4.5%",
    "change": "+1.4pp"
  },
  {
    "label": "Average position",
    "before": "15.2",
    "after": "13.8",
    "change": "Modest lift"
  }
];
const workstreams = [
  {
    "title": "Snippet and title testing",
    "text": "We tightened titles and meta descriptions around leather quality, wallet style, gift intent and clearer commercial hooks."
  },
  {
    "title": "Product and category alignment",
    "text": "Priority pages were reviewed for headings, product language, descriptive copy and search intent match."
  },
  {
    "title": "Internal link improvement",
    "text": "Supporting pages and category paths were used to reinforce the products and collections most likely to earn commercial clicks."
  },
  {
    "title": "Structured ecommerce signals",
    "text": "Product and category signals were checked so search engines could better understand what each page offered."
  },
  {
    "title": "Search Console monitoring",
    "text": "The campaign was judged from query, page and CTR movement, not from a fixed list of generic ecommerce tasks."
  }
];
const results = [
  {
    "metric": "Organic clicks",
    "before": "15.2k",
    "after": "22.7k",
    "change": "+49.3%",
    "note": "The site earned 7.5k more clicks during the comparison period."
  },
  {
    "metric": "Impressions",
    "before": "485k",
    "after": "500k",
    "change": "+3.1%",
    "note": "Visibility expanded only slightly, so this was not mainly a reach story."
  },
  {
    "metric": "Average CTR",
    "before": "3.1%",
    "after": "4.5%",
    "change": "+1.4pp",
    "note": "The stronger snippet and page alignment helped turn existing impressions into more traffic."
  },
  {
    "metric": "Average position",
    "before": "15.2",
    "after": "13.8",
    "change": "Modest lift",
    "note": "The average ranking improved, but the portfolio still sat mostly beyond the first page."
  }
];
const constraints = [
  {
    "title": "Crowded ecommerce results",
    "text": "The brand had to compete with marketplaces, retailer category pages and other direct-to-consumer leather goods brands."
  },
  {
    "title": "CTR was the real lever",
    "text": "Impressions only grew slightly, so the main opportunity was converting existing visibility into more visits."
  },
  {
    "title": "Product intent varied",
    "text": "Searchers used style, material, gift and quality language, not one neat keyword cluster."
  },
  {
    "title": "Ranking movement was modest",
    "text": "Average position improved from 15.2 to 13.8, which is useful but still not a first-page dominance story."
  }
];
const lessons = [
  "CTR gains need context. A higher click-through rate matters most when the traffic lands on pages that can sell or move users to the next step.",
  "Product SEO is not just writing descriptions. Page structure, snippet language, internal links and commercial proof all affect how the page performs.",
  "Second-page improvements are useful, but they should be framed honestly. The next commercial upside usually comes from pushing the strongest pages onto page one.",
  "Search Console can show whether the issue is visibility, CTR, ranking depth or page mismatch. Each problem needs a different fix."
];
const faqs = [
  {
    "question": "What was the main result in this leather wallet SEO case study?",
    "answer": "Organic clicks increased from 15.2k to 22.7k, a 49.3% lift. CTR also improved from 3.1% to 4.5%, while impressions rose only slightly."
  },
  {
    "question": "Was this mainly a ranking improvement?",
    "answer": "Not mainly. Average position improved from 15.2 to 13.8, but the strongest story is better click capture from existing visibility rather than a dramatic ranking jump."
  },
  {
    "question": "What SEO work helped the ecommerce pages perform better?",
    "answer": "The work focused on snippets, page relevance, product and category language, internal links, ecommerce signals and Search Console monitoring."
  },
  {
    "question": "Why does CTR matter for ecommerce SEO?",
    "answer": "If a page already appears for useful searches, a better title, description and page match can bring more qualified shoppers to the site without waiting for every ranking to move."
  },
  {
    "question": "Can this approach work for other ecommerce stores?",
    "answer": "Yes, when the store already has visibility or useful product demand. The exact plan should still begin with a crawl, keyword mapping and Search Console review."
  },
  {
    "question": "Does Bright Forge guarantee the same ecommerce SEO result?",
    "answer": "No. Results depend on the market, site quality, product demand, competition and implementation. Case studies show the kind of thinking involved, not a guaranteed outcome."
  }
];
const caseStudySchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Leather Wallet SEO Case Study",
  "description": "How ecommerce SEO helped a leather wallet brand increase organic clicks by 49% by improving snippets, product relevance and page quality.",
  "image": "https://brightforge.com.ph/images/case-studies/leather-wallet-ecommerce-seo.webp",
  "author": {
    "@type": "Organization",
    "name": "Bright Forge SEO",
    "url": "https://brightforge.com.ph/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Bright Forge SEO",
    "logo": {
      "@type": "ImageObject",
      "url": "https://brightforge.com.ph/images/header-logo-360w.webp"
    }
  },
  "mainEntityOfPage": "https://brightforge.com.ph/case-studies/leather-wallet-ecommerce-seo/",
  "articleSection": "SEO Case Studies",
  "about": [
    "Ecommerce SEO",
    "On-page SEO",
    "Content SEO",
    "Product SEO"
  ]
};
---

<MainLayout
  title="Leather Wallet SEO Case Study | Bright Forge"
  description="How ecommerce SEO helped a leather wallet brand increase organic clicks by 49% by improving snippets, product relevance and page quality."
  canonical={canonical}
  image={image}
  type="article"
  author={{ name: "Bright Forge SEO", url: "https://brightforge.com.ph/" }}
  article={{ section: "SEO Case Studies", tags: [
  "Ecommerce SEO",
  "On-page SEO",
  "Content SEO",
  "Product SEO"
] }}
  breadcrumbs={[
    { name: "Home", url: "https://brightforge.com.ph/" },
    { name: "Case Studies", url: "https://brightforge.com.ph/case-studies/" },
    { name: "Leather Wallet SEO", url: canonical }
  ]}
  faqs={faqs}
>
  <Fragment slot="head"><script type="application/ld+json" set:html={JSON.stringify(caseStudySchema)} /></Fragment>
  <LegacyHeader slot="header" />
  <Hero title="Leather Wallet SEO Case Study" breadcrumbCurrent="Leather Wallet SEO">
    <Fragment slot="story">
      <div class="case-meta"><span>Leather goods ecommerce</span><span>Direct-to-consumer retail</span><span>3 month comparison</span></div>
      <p class="hero-subtitle">How a leather goods ecommerce brand increased organic clicks by 49.3% while average position only moved from 15.2 to 13.8.</p>
      <p>This was not a story about one magic keyword. The useful lesson is how stronger snippets, clearer product relevance and better page alignment helped the site capture more clicks from visibility it already had.</p>
    </Fragment>
    <Fragment slot="actions"><ButtonPrimary href="#results" text="View Results" /><ButtonSecondary href="/contact/" text="Request an SEO Review" /></Fragment>
  </Hero>
  <main class="case-study-page">
    <section class="proof-strip"><div class="case-container"><div class="proof-grid">{metrics.map((metric) => (<article class="proof-card"><span class="proof-label">{metric.label}</span><strong>{metric.change}</strong><span>{metric.before} to {metric.after}</span></article>))}</div></div></section>
    <section class="overview-section"><div class="case-container overview-grid"><div><p class="eyebrow">The short version</p><h2>Better click capture from a competitive ecommerce SERP</h2><p>The leather wallet market is crowded with marketplaces, established brands and product-led direct competitors. The site already had visibility, but it needed stronger reasons for searchers to click and clearer signals around product quality, material, gift intent and category relevance.</p><p>Clicks increased from 15.2k to 22.7k, while impressions only rose from 485k to 500k. That points to a CTR-led improvement, not a huge expansion in reach. The average position improved, but it stayed on page two territory, so the case study needs to be honest about what moved.</p></div><aside class="case-summary-card"><h3>Campaign snapshot</h3><dl><div><dt>Industry</dt><dd>Leather goods ecommerce</dd></div><div><dt>Market type</dt><dd>Direct-to-consumer retail</dd></div><div><dt>Timeframe</dt><dd>3 month comparison</dd></div><div><dt>Main KPI</dt><dd>Organic clicks from Google Search</dd></div><div><dt>Primary work</dt><dd>Snippet improvement, product page relevance, internal links and ecommerce SEO QA</dd></div></dl></aside></div></section>
    <section class="visual-proof-section"><div class="case-container"><div class="case-image-card"><img src={image} alt="Search Console comparison for a leather wallet ecommerce SEO campaign" loading="eager" decoding="async" /></div><p class="image-note">Search Console metrics used in this case study: 15.2k to 22.7k clicks, 485k to 500k impressions, CTR 3.1% to 4.5% and average position 15.2 to 13.8.</p></div></section>
    <section class="content-section" id="challenge"><div class="case-container two-column"><div><p class="eyebrow">Starting problem</p><h2>The site had visibility, but the SERP message was not doing enough work</h2></div><div><p>A leather wallet buyer may be comparing material, design, delivery, durability, gift suitability and price before clicking. If title tags and descriptions look generic, the page can lose the click even when it appears for a useful query.</p><p>The challenge was to improve click capture and product relevance without pretending that the site had suddenly taken over page one. The SEO work needed to sharpen how product and category pages were understood and presented in search.</p></div></div></section>
    <section class="constraints-section"><div class="case-container"><p class="eyebrow">Constraints</p><h2>Why this was not a simple SEO win</h2><div class="constraint-grid">{constraints.map((item) => (<article><h3>{item.title}</h3><p>{item.text}</p></article>))}</div></div></section>
    <section class="work-section" id="work"><div class="case-container"><p class="eyebrow">What changed</p><h2>The work focused on search snippets, product relevance and ecommerce page quality</h2><div class="work-grid">{workstreams.map((item, index) => (<article class="work-item"><span>{String(index + 1).padStart(2, "0")}</span><h3>{item.title}</h3><p>{item.text}</p></article>))}</div></div></section>
    <section class="results-section" id="results"><div class="case-container"><p class="eyebrow">What moved</p><h2>Clicks rose faster than impressions, which makes CTR the important story</h2><div class="result-grid">{results.map((result) => (<article class="result-card"><div><span class="proof-label">{result.metric}</span><strong>{result.change}</strong></div><div class="before-after"><div><span>Before</span><strong>{result.before}</strong></div><div><span>After</span><strong>{result.after}</strong></div></div><p>{result.note}</p></article>))}</div></div></section>
    <section class="commercial-section"><div class="case-container commercial-card"><div><p class="eyebrow">Commercial meaning</p><h2>The useful win was more qualified visits from the same search market</h2><p>A CTR-led improvement can be commercially valuable for ecommerce because it increases the number of shoppers reaching product and category pages without needing the whole keyword set to jump to the top three.</p><p>The next phase should still focus on first-page movement, authority and stronger category depth. The 49.3% click lift is useful proof, but not a reason to stop improving the ranking base.</p></div><div class="case-summary-card"><h3>What matters here</h3><p>This case supports ecommerce, on-page and content SEO conversations where the site has visibility but weak snippet appeal or unclear product-page relevance.</p></div></div></section>
    <section class="lessons-section"><div class="case-container"><p class="eyebrow">Lessons</p><h2>What ecommerce brands should take from this</h2><div class="lesson-grid">{lessons.map((lesson) => (<article><p>{lesson}</p></article>))}</div></div></section>
    <section class="related-services-section"><div class="case-container"><p class="eyebrow">Related services</p><h2>Where this kind of work fits</h2><div class="service-link-grid"><a href="/technical-seo-services-philippines/"><span>Technical SEO</span>Fix crawl, structure, performance and indexation issues.</a><a href="/on-page-seo-services-philippines/"><span>On-page SEO</span>Improve page relevance, snippets and conversion paths.</a><a href="/content-seo-services-philippines/"><span>SEO content</span>Turn search intent into stronger pages and supporting content.</a></div></div></section>
    <section class="faq-section"><div class="case-container faq-layout"><div><p class="eyebrow">FAQ</p><h2>Questions this case study should answer</h2></div><div class="faq-list">{faqs.map((faq) => (<details class="faq-item"><summary>{faq.question}</summary><p>{faq.answer}</p></details>))}</div></div></section>
    <section class="case-cta-section"><div class="case-container"><div class="case-cta-card"><h2>Want to know what is holding your search traffic back?</h2><p>We can review the pages, queries and technical signals that matter before recommending any rewrite, content plan or link activity.</p><div class="cta-actions"><ButtonPrimary href="/contact/" text="Request an SEO Review" /><ButtonSecondary href="/case-studies/" text="View More Case Studies" /></div></div></div></section>
  </main>
  <Footer slot="footer" />
</MainLayout>

<style>
.case-study-page { background: #0d0f1a; color: #fff; }
.case-container { width: min(100% - 40px, 1120px); margin: 0 auto; }
.case-meta { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 18px; }
.case-meta span { padding: 8px 12px; border-radius: 999px; background: rgba(255,255,255,.1); color: rgba(255,255,255,.82); font-size: .86rem; font-weight: 800; }
.hero-subtitle { color: #fff; font-weight: 900; font-size: clamp(1.15rem, 2vw, 1.45rem); }
.proof-strip, .overview-section, .visual-proof-section, .content-section, .constraints-section, .work-section, .results-section, .commercial-section, .lessons-section, .related-services-section, .faq-section, .case-cta-section { padding: 78px 0; content-visibility: visible !important; }
.proof-grid, .constraint-grid, .work-grid, .result-grid, .lesson-grid, .service-link-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 18px; }
.proof-card, .case-summary-card, .case-image-card, .constraint-grid article, .work-item, .result-card, .lesson-grid article, .service-link-grid a, .faq-item, .case-cta-card { border: 1px solid rgba(255,255,255,.1); background: rgba(255,255,255,.045); border-radius: 24px; box-shadow: 0 18px 48px rgba(0,0,0,.18); }
.proof-card { padding: 24px; }
.proof-label, .eyebrow { display: block; color: #f0622a; font-size: .78rem; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; margin-bottom: 10px; }
.proof-card strong { display: block; color: #fff; font-size: clamp(2rem, 4vw, 3rem); line-height: 1; margin-bottom: 8px; }
.proof-card span:last-child { color: rgba(255,255,255,.68); }
.overview-section, .constraints-section, .results-section, .lessons-section, .faq-section { background: #111421; }
.overview-grid, .two-column, .commercial-card, .faq-layout { display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(300px, .9fr); gap: clamp(30px, 5vw, 60px); align-items: start; }
h2 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); line-height: 1.05; margin: 0 0 22px; }
h3 { color: #fff; font-size: 1.15rem; margin: 0 0 10px; }
p, li, dd { color: rgba(255,255,255,.74); font-size: 1.02rem; line-height: 1.72; }
a { color: #f0622a; }
.case-summary-card, .constraint-grid article, .work-item, .result-card, .lesson-grid article, .service-link-grid a { padding: 24px; }
.case-summary-card dl { display: grid; gap: 14px; margin: 0; }
.case-summary-card div { display: grid; gap: 4px; padding-bottom: 14px; border-bottom: 1px solid rgba(255,255,255,.08); }
dt { color: rgba(255,255,255,.5); font-weight: 900; text-transform: uppercase; font-size: .75rem; letter-spacing: .08em; }
.case-image-card { overflow: hidden; padding: 10px; background: rgba(255,255,255,.07); }
.case-image-card img { width: 100%; border-radius: 18px; display: block; }
.image-note { font-size: .92rem; margin-top: 14px; color: rgba(255,255,255,.62); }
.work-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.work-item span { display: inline-grid; place-items: center; width: 42px; height: 42px; border-radius: 14px; color: #fff; background: rgba(240,98,42,.25); font-weight: 900; margin-bottom: 18px; }
.result-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.result-card strong { color: #f0622a; font-size: 1.7rem; }
.before-after { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; margin: 18px 0; }
.before-after div { padding: 14px; border-radius: 16px; background: rgba(0,0,0,.2); }
.before-after span { display: block; color: rgba(255,255,255,.48); font-size: .75rem; font-weight: 900; text-transform: uppercase; margin-bottom: 6px; }
.commercial-card { padding: clamp(32px, 5vw, 58px); border-radius: 32px; background: linear-gradient(145deg, rgba(240,98,42,.14), rgba(255,255,255,.04)); }
.lesson-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.service-link-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
.service-link-grid a { color: inherit; text-decoration: none; }
.service-link-grid span { display: block; color: #fff; font-weight: 900; margin-bottom: 8px; }
.faq-list { display: grid; gap: 14px; }
.faq-item { overflow: hidden; }
.faq-item summary { cursor: pointer; padding: 22px 24px; color: #fff; font-weight: 900; list-style: none; }
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item p { padding: 0 24px 24px; margin: 0; }
.case-cta-card { text-align: center; padding: clamp(36px, 6vw, 68px); background: radial-gradient(circle at top left, rgba(240,98,42,.22), rgba(255,255,255,.045)); }
.cta-actions { display: flex; justify-content: center; flex-wrap: wrap; gap: 14px; margin-top: 28px; }
@media (max-width: 920px) { .proof-grid, .constraint-grid, .work-grid, .result-grid, .lesson-grid, .service-link-grid, .overview-grid, .two-column, .commercial-card, .faq-layout { grid-template-columns: 1fr; } }
</style>

