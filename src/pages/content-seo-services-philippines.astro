---
import MainLayout from '../layouts/MainLayout.astro';
import LegacyHeader from '../components/LegacyHeader.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';
import Hero from '../components/Hero.astro';
import ButtonPrimary from '../components/ButtonPrimary.astro';
import ButtonSecondary from '../components/ButtonSecondary.astro';

const contentFaqs = [
  {
    question: "What is included in SEO content writing services?",
    answer: "Our SEO content writing services include keyword research, search intent mapping, content outlines, page structure, copywriting, metadata, internal linking guidance, FAQ planning and optimisation recommendations for blogs, service pages, landing pages and existing content."
  },
  {
    question: "Do you only write new content or can you improve existing pages?",
    answer: "We do both. New content helps build topical authority, but existing pages often have faster gains. We use ranking and Google Search Console data to identify pages that need stronger headings, clearer search intent, better internal links, fresher information or sharper conversion copy."
  },
  {
    question: "Can you work with our in-house writers or marketing team?",
    answer: "Yes. We can create SEO content outlines, review drafts, improve page structure and guide your team on keyword targeting, internal links, EEAT signals and editorial standards while your writers keep control of brand voice."
  },
  {
    question: "Do you use AI for SEO content?",
    answer: "We use AI carefully as a workflow tool, not as a replacement for SEO judgement or editorial review. Strategy, search intent, structure, fact checking, brand fit and final edits stay human-led, because generic AI content is exactly what most websites need to avoid."
  },
  {
    question: "How long does content SEO take to work?",
    answer: "It depends on the site, competition and authority behind the page. Content refreshes can sometimes move faster because Google already knows the URL. New content usually needs more time, internal links and supporting authority before it becomes a reliable source of traffic or enquiries."
  },
  {
    question: "How do you measure content SEO performance?",
    answer: "We track rankings, impressions, clicks, landing page performance, enquiries where tracking is available, internal link impact and whether the content is supporting the right commercial pages. The aim is not just more articles, it is more useful visibility that helps the business grow."
  }
];
---

<MainLayout
  title="SEO Content Writing Services Philippines | Bright Forge SEO"
  description="SEO content writing and optimisation for Philippine businesses, built around search intent, page quality, internal links and enquiries."
  canonical="https://brightforge.com.ph/content-seo-services-philippines/"
  type="service"
  faqs={contentFaqs}
>
  <LegacyHeader slot="header" />

  <Hero
    badgeIcon="fas fa-pen-nib"
    badgeText="SEO Content Writing"
    title="SEO Content Writing Services Philippines"
    breadcrumbCurrent="SEO Content Writing Services"
  >
    <Fragment slot="story">
      <p>SEO content should do more than fill a blog. We plan, write and improve content that targets the right searches, supports your service pages, builds topical authority and helps turn organic traffic into enquiries.</p>

      <p>Bright Forge SEO works with businesses that need content led by search intent, not guesswork. That means clear keyword mapping, practical content outlines, stronger page structure, better internal links, useful FAQs and copy that gives buyers a reason to act.</p>
    </Fragment>

    <Fragment slot="actions">
      <ButtonPrimary href="/contact/" text="Get a Free Content SEO Audit" />
      <ButtonSecondary href="#approach" text="See How We Work" />
    </Fragment>

    <Fragment slot="visual">
      <div class="hero-image-container strategy-panel">
        <p class="panel-kicker">Content that earns its place</p>
        <div class="strategy-flow">
          <div><span>01</span><strong>Search intent</strong><small>What the buyer actually needs</small></div>
          <div><span>02</span><strong>Page mapping</strong><small>Where each topic should live</small></div>
          <div><span>03</span><strong>Content outline</strong><small>Structure, links, proof and CTA</small></div>
          <div><span>04</span><strong>Performance refresh</strong><small>Rankings, clicks and enquiries</small></div>
        </div>
      </div>
    </Fragment>
  </Hero>

  <section class="proof-strip-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="proof-strip">
        <div>
          <strong>Built for commercial search</strong>
          <span>Service pages, blogs, location pages, guides and refreshes mapped to buyer intent.</span>
        </div>
        <div>
          <strong>SEO plus CRO</strong>
          <span>Content planned around rankings, internal links, trust signals and enquiry paths.</span>
        </div>
        <div>
          <strong>Human-edited output</strong>
          <span>AI can help the workflow, but strategy, fact checking and final polish stay human-led.</span>
        </div>
      </div>
    </div>
  </section>

  <section class="why-content-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="editorial-layout">
        <div class="editorial-copy">
          <p class="eyebrow">Why content SEO matters</p>
          <h2>Better content gives Google a reason to rank you and buyers a reason to trust you</h2>
          <p>Most business content fails because it is written around what the company wants to say, not what the buyer is trying to solve. Good SEO content connects those two things. It answers the search properly, proves the business can help and points visitors towards the next sensible action.</p>
          <p>We use keyword research, SERP review, competitor checks and page-level performance data to decide what should be written, what should be improved and what should be left alone. That is how content becomes a growth asset rather than another monthly deliverable.</p>
        </div>
        <div class="editorial-panel">
          <h3>What we look for first</h3>
          <ul>
            <li>Pages ranking but not earning clicks</li>
            <li>Topics with commercial search intent</li>
            <li>Thin service pages that need supporting content</li>
            <li>Old articles losing impressions or relevance</li>
            <li>Internal link gaps between blogs and money pages</li>
            <li>FAQs and answer blocks that can support AI search readiness</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="services" class="services-section-new">
    <div class="max-w-7xl mx-auto px-4">
      <div class="services-layout">
        <div class="services-content">
          <p class="eyebrow">What is included</p>
          <h2>SEO content services built around <span>search intent and revenue pages</span></h2>

          <div class="service-list">
            <div class="service-item">
              <h3>SEO Content Strategy</h3>
              <p>We map topics to real searches, buyer stages and priority pages, so content supports the pages that need to rank and convert. That includes topic clusters, content calendars, keyword grouping and search intent review.</p>
            </div>

            <div class="service-item">
              <h3>SEO Content Writing</h3>
              <p>We write service pages, blog posts, landing pages, local pages, FAQs and supporting guides with clear structure, useful headings, natural keyword coverage and conversion-focused calls to action.</p>
            </div>

            <div class="service-item">
              <h3>Content Optimisation</h3>
              <p>We improve existing pages using ranking data, Google Search Console signals and on-page checks. That can include rewritten sections, metadata, H1 and H2 changes, answer blocks, internal links, freshness updates and stronger proof.</p>
            </div>

            <div class="service-item">
              <h3>Content Outlines and Editorial QA</h3>
              <p>If your team writes in-house, we can handle the SEO layer. We create content outlines, review drafts, check search intent, tighten headings, add internal link direction and make sure the finished page has a real job to do.</p>
            </div>

            <div class="service-item">
              <h3>AI Search Ready Content</h3>
              <p>We structure content so services, locations, proof, FAQs and entity signals are easy for search engines and AI answer systems to understand. This is still SEO-first, with <a href="/ai-search-optimization-services-philippines/">AI search readiness</a> handled as an extra layer rather than a replacement for fundamentals.</p>
            </div>
          </div>
        </div>

        <div class="services-visual">
          <div class="visual-card evidence-card">
            <div class="visual-icon">
              <i class="fas fa-route"></i>
            </div>
            <h3>From keyword to enquiry</h3>
            <p class="visual-description">A useful content plan does not start with article titles. It starts with the pages that need more visibility, the questions buyers ask before they enquire and the internal links needed to move authority through the site.</p>
            <a href="/keyword-research-services/">See our keyword research approach</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="buyer-fit-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="buyer-fit-layout">
        <div>
          <p class="eyebrow">Who this suits</p>
          <h2>For businesses that need content with a commercial job, not another pile of blog posts</h2>
        </div>
        <div class="buyer-fit-list">
          <p><strong>Service businesses</strong> that need stronger pages, better local visibility and more enquiry-led content.</p>
          <p><strong>Ecommerce and product-led brands</strong> that need category, guide and comparison content to support buying decisions.</p>
          <p><strong>In-house marketing teams</strong> that already write content but need SEO outlines, structure and quality control.</p>
          <p><strong>Agencies and partners</strong> that need reliable white-label SEO content without generic filler.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="approach" class="process-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="section-header">
        <p class="eyebrow">Our process</p>
        <h2>How we turn content into <span>search assets</span></h2>
        <p>Every page needs a clear purpose before anyone starts writing. We decide the target, structure and proof first, then build the content around that plan.</p>
      </div>

      <div class="process-grid">
        <div class="process-box orange-bg">
          <div class="process-box-icon">
            <i class="fas fa-search"></i>
          </div>
          <h3>Audit</h3>
          <p>We review current rankings, page quality, Search Console signals, internal links and content gaps.</p>
        </div>

        <div class="process-box white-bg">
          <div class="process-box-icon">
            <i class="fas fa-map-signs"></i>
          </div>
          <h3>Map</h3>
          <p>We match keywords and topics to the right pages, so blogs do not compete with service pages.</p>
        </div>

        <div class="process-box white-bg">
          <div class="process-box-icon">
            <i class="fas fa-clipboard-list"></i>
          </div>
          <h3>Outline</h3>
          <p>We define search intent, headings, internal links, proof points, FAQs and the conversion angle.</p>
        </div>

        <div class="process-box orange-bg">
          <div class="process-box-icon">
            <i class="fas fa-pen-fancy"></i>
          </div>
          <h3>Write</h3>
          <p>We create useful, readable content with SEO structure and enough commercial clarity to earn enquiries.</p>
        </div>

        <div class="process-box orange-bg">
          <div class="process-box-icon">
            <i class="fas fa-link"></i>
          </div>
          <h3>Connect</h3>
          <p>We add internal link direction so supporting content passes relevance to your priority pages.</p>
        </div>

        <div class="process-box white-bg">
          <div class="process-box-icon">
            <i class="fas fa-chart-line"></i>
          </div>
          <h3>Improve</h3>
          <p>We track rankings, impressions, clicks and leads, then refresh the content when the data says it needs work.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="benefits-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="benefits-layout">
        <div class="proof-panel">
          <p class="eyebrow">Why Bright Forge</p>
          <h2>Senior SEO thinking before the first draft</h2>
          <p>Content quality is not just grammar. It is whether the page deserves to rank, whether it answers the query better than the current SERP, whether it supports the right commercial page and whether the visitor knows what to do next.</p>
          <p>That is why we treat content as part of the SEO system: <a href="/keyword-research-services/">keyword research</a>, <a href="/on-page-seo-services-philippines/">on-page SEO</a>, internal links, <a href="/technical-seo-services-philippines/">technical foundations</a>, proof, reporting and conversion paths all need to work together.</p>
          <div class="proof-links">
            <a href="/seo-services-philippines/">Explore SEO services</a>
            <a href="/on-page-seo-services-philippines/">View on-page SEO</a>
            <a href="/case-studies/">See case studies</a>
            <a href="/case-studies/bridal-dress-designer-seo/">View content-led case study</a>
          </div>
        </div>

        <div class="benefits-grid">
          <div class="benefit-card">
            <div class="benefit-icon">
              <i class="fas fa-layer-group"></i>
            </div>
            <h3>Topic clusters</h3>
            <p>Content planned around connected themes, not random articles that never support the money pages.</p>
          </div>

          <div class="benefit-card">
            <div class="benefit-icon">
              <i class="fas fa-user-check"></i>
            </div>
            <h3>Buyer-led copy</h3>
            <p>Pages built around questions, objections, proof and decision points, not vague traffic promises.</p>
          </div>

          <div class="benefit-card">
            <div class="benefit-icon">
              <i class="fas fa-sync-alt"></i>
            </div>
            <h3>Content refreshes</h3>
            <p>Existing pages improved when rankings stall, clicks drop, facts age or the SERP changes.</p>
          </div>

          <div class="benefit-card">
            <div class="benefit-icon">
              <i class="fas fa-chart-pie"></i>
            </div>
            <h3>Useful reporting</h3>
            <p>We report on the content signals that matter: rankings, impressions, clicks, links, enquiries and next actions.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="next-steps-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="next-steps-card">
        <div>
          <p class="eyebrow">What happens after you enquire</p>
          <h2>We start with the content that can move the needle fastest</h2>
          <p>We review your current pages, rankings and content gaps, then show where new content, page refreshes or internal linking fixes can make the biggest difference. If there is a quick win hiding in existing content, we will usually find that before recommending a new calendar.</p>
        </div>
        <ol>
          <li>Review current rankings and page quality</li>
          <li>Identify content gaps and underperforming pages</li>
          <li>Map content to commercial priorities</li>
          <li>Build a practical content SEO roadmap</li>
        </ol>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="max-w-4xl mx-auto px-4">
      <div class="section-header">
        <h2>Frequently Asked <span>Questions</span></h2>
      </div>

      <div class="faq-container">
        {contentFaqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-question">
              <span>{faq.question}</span>
              <i class="fas fa-chevron-down"></i>
            </summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="content-cta-section">
    <div class="max-w-5xl mx-auto px-4">
      <div class="content-cta-card">
        <p class="eyebrow">Ready to improve your content?</p>
        <h2>Get a free content SEO audit</h2>
        <p>We will review your current content, identify the pages with the clearest upside and show what should be created, improved or consolidated first.</p>
        <div class="cta-actions">
          <ButtonPrimary href="/contact/" text="Request Your Free Audit" />
          <ButtonSecondary href="mailto:seo@brightforgeseo.com" text="Email the Team" />
        </div>
      </div>
    </div>
  </section>

  <ContactSection />
  <Footer slot="footer" />
</MainLayout>

<style>

:global(body .hero-visual),
:global(body .hero-image-container),
:global(body .strategy-panel) {
  display: flex !important;
  visibility: visible !important;
}

:global(body .hero-visual *),
:global(body .hero-image-container *),
:global(body .strategy-panel *) {
  display: revert !important;
  visibility: visible !important;
}

:global(body .hero-image-container.strategy-panel) {
  display: block !important;
}

:global(body .strategy-flow),
:global(body .strategy-flow div) {
  display: grid !important;
}

.proof-strip-section,
.why-content-section,
.services-section-new,
.buyer-fit-section,
.process-section,
.benefits-section,
.next-steps-section,
.faq-section,
.content-cta-section,
:global(body .contact-cta-section) {
  content-visibility: visible !important;
  contain: none !important;
}

.service-item a,
.proof-panel a,
.content-cta-card a {
  color: #f9b089;
  font-weight: 800;
  text-decoration: underline;
  text-underline-offset: 5px;
}

.hero-image-container {
  position: relative;
  width: 100%;
  max-width: 520px;
}

.strategy-panel {
  background: rgba(13, 15, 26, 0.72);
  border: 1px solid rgba(255, 255, 255, 0.18);
  border-radius: 28px;
  padding: 32px;
  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
  backdrop-filter: blur(18px);
}

.panel-kicker,
.eyebrow {
  color: #f0622a;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  font-size: 0.78rem;
  font-weight: 800;
  margin-bottom: 14px;
}

.strategy-flow {
  display: grid;
  gap: 16px;
}

.strategy-flow div {
  display: grid;
  grid-template-columns: auto 1fr;
  grid-template-rows: auto auto;
  column-gap: 14px;
  padding: 18px;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 18px;
}

.strategy-flow span {
  grid-row: 1 / span 2;
  color: #f9b089;
  font-weight: 900;
}

.strategy-flow strong {
  color: #ffffff;
  font-size: 1rem;
}

.strategy-flow small {
  color: #d0d4e8;
  line-height: 1.5;
}

.section-header {
  text-align: center;
  margin-bottom: 60px;
}

.section-header h2,
.editorial-copy h2,
.services-content h2,
.buyer-fit-layout h2,
.proof-panel h2,
.next-steps-card h2,
.content-cta-card h2 {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 16px;
  line-height: 1.2;
}

.section-header h2 span,
.services-content h2 span {
  background: linear-gradient(135deg, #f0622a, #d4510e);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.section-header p {
  font-size: 1.1rem;
  color: #d0d4e8;
  max-width: 720px;
  margin: 0 auto;
  line-height: 1.7;
}

.proof-strip-section {
  padding: 34px 0;
  background: #0d0f1a;
}

.proof-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}

.proof-strip div {
  background: #131627;
  border: 1px solid rgba(240, 98, 42, 0.18);
  border-radius: 18px;
  padding: 22px;
}

.proof-strip strong {
  display: block;
  color: #ffffff;
  font-size: 1.05rem;
  margin-bottom: 8px;
}

.proof-strip span {
  color: #d0d4e8;
  line-height: 1.6;
}

.why-content-section,
.benefits-section,
.next-steps-section {
  padding: 100px 0;
  background: linear-gradient(135deg, #0d0f1a 0%, #131627 100%);
}

.editorial-layout,
.buyer-fit-layout,
.benefits-layout,
.next-steps-card {
  display: grid;
  grid-template-columns: 1.05fr 0.95fr;
  gap: 60px;
  align-items: start;
}

.editorial-copy p,
.proof-panel p,
.next-steps-card p,
.content-cta-card p {
  color: #d0d4e8;
  font-size: 1.08rem;
  line-height: 1.8;
  margin-bottom: 18px;
}

.editorial-panel,
.proof-panel,
.next-steps-card,
.content-cta-card {
  background: #131627;
  border: 1px solid rgba(240, 98, 42, 0.16);
  border-radius: 24px;
  padding: 38px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.16);
}

.editorial-panel h3 {
  color: #ffffff;
  font-size: 1.5rem;
  margin-bottom: 20px;
}

.editorial-panel ul {
  list-style: none;
  margin: 0;
  padding: 0;
}

.editorial-panel li {
  color: #d0d4e8;
  line-height: 1.7;
  padding: 12px 0 12px 28px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  position: relative;
}

.editorial-panel li:before {
  content: "";
  position: absolute;
  left: 0;
  top: 22px;
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #f0622a;
}

.services-section-new,
.process-section,
.faq-section,
.content-cta-section {
  padding: 100px 0;
  background: #131627;
}

.services-layout {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 60px;
  align-items: start;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 30px;
}

.service-item {
  padding-left: 30px;
  border-left: 4px solid #f0622a;
  transition: all 0.3s ease;
}

.service-item:hover {
  border-left-color: #d4510e;
  transform: translateX(10px);
}

.service-item h3 {
  font-size: 1.5rem;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12px;
}

.service-item p,
.buyer-fit-list p,
.benefit-card p {
  color: #d0d4e8;
  line-height: 1.7;
  font-size: 1.02rem;
}

.services-visual {
  position: sticky;
  top: 120px;
}

.visual-card {
  background: linear-gradient(135deg, #f0622a 0%, #d4510e 100%);
  padding: 40px;
  border-radius: 24px;
  color: white;
  box-shadow: 0 20px 60px rgba(240, 98, 42, 0.3);
}

.visual-icon {
  width: 72px;
  height: 72px;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
  font-size: 2.1rem;
}

.visual-card h3 {
  font-size: 1.55rem;
  font-weight: 800;
  margin-bottom: 16px;
}

.visual-description {
  font-size: 1rem;
  opacity: 0.95;
  line-height: 1.7;
  margin-bottom: 20px;
}

.visual-card a,
.proof-links a {
  color: #ffffff;
  font-weight: 800;
  text-decoration: underline;
  text-underline-offset: 5px;
}

.buyer-fit-section {
  padding: 90px 0;
  background: #0d0f1a;
}

.buyer-fit-list {
  display: grid;
  gap: 18px;
}

.buyer-fit-list p {
  background: #131627;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 18px;
  padding: 22px;
  margin: 0;
}

.buyer-fit-list strong {
  color: #ffffff;
}

.process-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
  margin-top: 20px;
}

.process-box {
  padding: 40px 30px;
  border-radius: 20px;
  transition: all 0.3s ease;
  text-align: center;
}

.process-box.orange-bg {
  background: linear-gradient(135deg, #f0622a, #d4510e);
  color: white;
}

.process-box.white-bg {
  background: #131627;
  color: #ffffff;
  border: 2px solid rgba(255, 255, 255, 0.12);
}

.process-box:hover {
  transform: translateY(-8px);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
}

.process-box-icon {
  width: 70px;
  height: 70px;
  margin: 0 auto 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  border-radius: 16px;
}

