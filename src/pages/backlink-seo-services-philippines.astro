---
import MainLayout from '../layouts/MainLayout.astro';
import LegacyHeader from '../components/LegacyHeader.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';
import Hero from '../components/Hero.astro';
import ButtonPrimary from '../components/ButtonPrimary.astro';
import ButtonSecondary from '../components/ButtonSecondary.astro';

const proofItems = [
  {
    title: 'Risk-aware link building',
    copy: 'We build links around relevance, editorial quality, anchor text control and long-term site safety, not bulk packages that look impressive until Google takes a closer look.'
  },
  {
    title: 'Links tied to SEO strategy',
    copy: 'Backlinks work best when target pages, content quality, technical health and internal links are already strong enough to deserve authority.'
  },
  {
    title: 'Transparent reporting',
    copy: 'You see what was built, where it points, why it was chosen, what anchor text was used and how it supports ranking and enquiry growth.'
  }
];

const linkTypes = [
  {
    title: 'Editorial outreach links',
    copy: 'Relevant placements earned through outreach to publishers, resource owners, niche websites and businesses where the link makes sense for the reader.'
  },
  {
    title: 'Competitor link gap opportunities',
    copy: 'We review the links helping competitors rank, then separate useful opportunities from noise, spam and placements that would not suit your brand.'
  },
  {
    title: 'Resource and citation links',
    copy: 'Useful directories, association pages, local citations, supplier pages, partner pages and resource listings can support trust when they are relevant and properly vetted.'
  },
  {
    title: 'Lost link and mention reclamation',
    copy: 'We identify broken backlinks, lost links, redirected assets and unlinked brand mentions that can often be recovered before chasing brand-new placements.'
  },
  {
    title: 'Content-led link assets',
    copy: 'When outreach needs something worth referencing, we help shape guides, data pages, tools, case studies or resources that make the link request more credible.'
  },
  {
    title: 'Backlink profile cleanup guidance',
    copy: 'If a site already has messy links, we review patterns, risky anchors and obvious toxic sources before recommending disavow work or safer authority building.'
  }
];

const qualityChecks = [
  'Topical relevance between the linking page, linking site and target page',
  'Real indexable pages, not thin placements built only to sell links',
  'Evidence of organic visibility, audience value or niche authority',
  'Reasonable outbound link patterns without obvious link-farm behaviour',
  'Editorial context around the link, not a random footer or stuffed paragraph',
  'Natural anchor text that protects the domain from over-optimisation',
  'Clean target-page fit so authority points at pages that can convert',
  'Placement quality that a human client would not be embarrassed to see'
];

const avoidItems = [
  {
    title: 'No PBNs or link farms',
    copy: 'We do not build campaigns around private blog networks, spun sites, expired-domain farms or obvious paid-link footprints.'
  },
  {
    title: 'No bulk DA or DR packages',
    copy: 'Authority metrics can be useful signals, but they are not a strategy. We do not sell fixed bundles of suspicious high-metric links.'
  },
  {
    title: 'No exact-match anchor abuse',
    copy: 'Aggressive anchor text can create short-term movement and long-term risk. We plan anchors around brand, relevance, intent and safety.'
  },
  {
    title: 'No irrelevant placements',
    copy: 'A link from a random site in the wrong country, topic or language rarely helps the business. Relevance comes before easy volume.'
  }
];

const processSteps = [
  {
    label: '01',
    title: 'Backlink audit and baseline',
    copy: 'We review current referring domains, anchors, target pages, link quality, lost links, competitor strength and obvious risk patterns before recommending new links.'
  },
  {
    label: '02',
    title: 'Strategy and target mapping',
    copy: 'We decide which pages should earn authority, which keywords they support and whether content or technical fixes are needed before outreach starts.'
  },
  {
    label: '03',
    title: 'Prospecting and qualification',
    copy: 'We build a prospect list, check relevance and quality, remove risky sites and prioritise opportunities that fit the campaign, market and target pages.'
  },
  {
    label: '04',
    title: 'Outreach and placement review',
    copy: 'We handle outreach, content support and placement checks, then review each link for anchor text, target URL, page context and quality before reporting it.'
  },
  {
    label: '05',
    title: 'Reporting and adjustment',
    copy: 'We track links built, rankings, Search Console visibility, referral signals and campaign direction, then adjust the link mix as the site and market change.'
  }
];

const fitBlocks = [
  {
    title: 'Competitive SEO campaigns',
    copy: 'For businesses with decent content and technical foundations that are being outranked by stronger, more trusted competitor domains.'
  },
  {
    title: 'Service pages that need authority',
    copy: 'For core money pages where on-page SEO is already solid, but the page lacks enough external trust to compete.'
  },
  {
    title: 'Brands with messy backlink profiles',
    copy: 'For sites that have bought links in the past, inherited poor SEO work or need a clearer view of which links help and which create risk.'
  },
  {
    title: 'Agencies needing safe fulfilment',
    copy: 'For partners who need link building handled carefully, reported clearly and delivered without putting their client relationships at risk.'
  }
];

const reportFields = [
  'Linking URL and domain',
  'Target page on your site',
  'Anchor text used',
  'Placement type and context',
  'Relevance notes',
  'Quality and risk observations',
  'Date acquired or recovered',
  'Ranking and visibility movement where relevant'
];

const faqs = [
  { question: 'What are link building services?', answer: 'Link building services help a website earn or acquire relevant backlinks from other websites. The goal is to improve trust, authority and ranking potential without creating a risky link profile. Good link building includes audits, prospecting, outreach, anchor text planning, quality checks and reporting.' },
  { question: 'Are backlinks still important for SEO?', answer: 'Yes. Backlinks are still an important authority signal, especially in competitive markets. They work best when the site already has strong technical SEO, useful content, clear target pages and a sensible internal linking structure.' },
  { question: 'Do you use PBNs or link farms?', answer: 'No. We do not build campaigns around PBNs, expired-domain networks, link farms or bulk guest-post packages. Those shortcuts can create short-term movement, but they also create risk that serious businesses do not need.' },
  { question: 'How do you decide if a backlink is safe?', answer: 'We look at relevance, indexation, page quality, site quality, organic visibility, outbound link patterns, anchor text, placement context and whether the link would make sense to a real reader. No single metric is enough on its own.' },
  { question: 'How many backlinks do we need?', answer: 'It depends on the market, competitors, target pages and current authority gap. Some campaigns need a small number of strong relevant links. Others need sustained authority building over several months. We start with a backlink audit and competitor review rather than guessing a number.' },
  { question: 'Can bad backlinks hurt rankings?', answer: 'Yes, especially if the profile has obvious manipulation, irrelevant placements, aggressive exact-match anchors or links from poor-quality networks. Not every weak link needs panic, but risky patterns should be reviewed and handled carefully.' },
  { question: 'Do you provide backlink reports?', answer: 'Yes. Reports should show the linking URL, target page, anchor text, placement type, relevance notes, quality checks and campaign impact where measurable. Link building should never feel like a black box.' },
  { question: 'Should we build links before fixing content and technical SEO?', answer: 'Not always. If the target pages are thin, slow, poorly structured or misaligned with search intent, backlinks may be wasted. We usually check technical health, content quality and target-page readiness before scaling link acquisition.' }
];
---

<MainLayout
  title="Link Building Services Philippines | Safe SEO Backlinks"
  description="Link building services in the Philippines for safe backlink audits, outreach, authority growth, anchor text control and transparent SEO reporting."
  keywords="link building services Philippines, backlink services Philippines, SEO link building Philippines, white hat link building, backlink audit services"
  faqs={faqs}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://brightforge.com.ph/'
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Link Building Services Philippines',
          item: 'https://brightforge.com.ph/backlink-seo-services-philippines/'
        }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: 'Link Building Services Philippines',
      url: 'https://brightforge.com.ph/backlink-seo-services-philippines/',
      inLanguage: 'en',
      description: 'Link building services for safer backlink acquisition, backlink audits, outreach, anchor text planning and authority growth.',
      publisher: {
        '@type': 'Organization',
        name: 'Bright Forge SEO',
        url: 'https://brightforge.com.ph/'
      },
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: linkTypes.map((item, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: item.title,
          description: item.copy
        }))
      }
    })} />
  </Fragment>

  <LegacyHeader slot="header" />

  <Hero
    badgeIcon="fas fa-link"
    badgeText="Safe Link Building"
    title="Link Building Services Philippines for <span>Safer SEO Authority</span>"
    breadcrumbCurrent="Link Building Services Philippines"
  >
    <Fragment slot="story">
      <p>Backlinks can help a site compete for harder keywords, but bad links can also waste money, weaken trust and create cleanup work later. Link building needs judgement, not bulk packages or recycled guest-post lists.</p>
      <p>Bright Forge provides link building services in the Philippines for businesses and agency partners that need relevant backlinks, safer anchor text, cleaner reporting and authority growth that supports real SEO campaigns.</p>
    </Fragment>

    <Fragment slot="actions">
      <ButtonPrimary href="/contact/" text="Get a Backlink Audit" />
      <ButtonSecondary href="#safe-links" text="See How We Build Links" />
    </Fragment>

    <Fragment slot="stats">
      <div class="link-hero-stats">
        <div class="stat"><strong>Audit</strong><span>Current links, anchors, target pages, risk patterns and competitor gaps.</span></div>
        <div class="stat"><strong>Qualify</strong><span>Relevance, indexation, editorial context and outbound link quality.</span></div>
        <div class="stat"><strong>Report</strong><span>Link URLs, target pages, anchors, notes and impact signals.</span></div>
      </div>
    </Fragment>
  </Hero>

  <section class="intro-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="intro-layout">
        <div class="intro-copy">
          <span class="eyebrow">Why link building needs care</span>
          <h2><span>Backlinks</span> help rankings only when the links make sense</h2>
          <p>Search engines use links as a trust signal, but they also understand patterns. A relevant editorial link to a useful service page is very different from a batch of exact-match anchors on thin websites built to sell placements.</p>
          <p>That is why we start with the site, the target pages and the market. If the page is not strong enough to rank, or the backlink profile already has risk, building more links without diagnosis is just adding noise.</p>
        </div>
        <aside class="authority-panel" aria-label="Link building judgement points">
          <h3>Good link building should answer these questions</h3>
          <ul>
            <li>Which pages actually need authority?</li>
            <li>Which competitors have useful links worth studying?</li>
            <li>Which anchors are safe and natural?</li>
            <li>Which placements would we reject?</li>
            <li>How will link work connect to rankings and enquiries?</li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <section class="proof-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="proof-grid">
        {proofItems.map((item) => (
          <article class="proof-card">
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="safe-links" class="service-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-heading split-heading">
        <div>
          <span class="eyebrow">What we build</span>
          <h2><span>Backlink services</span> built around relevance, not volume</h2>
        </div>
        <p>Some campaigns need new editorial links. Others need lost links recovered, citations cleaned up, brand mentions claimed or content assets worth referencing. The right mix depends on the domain, competitors and target pages.</p>
      </div>
      <div class="service-grid">
        {linkTypes.map((item) => (
          <article class="service-card">
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="avoid-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="avoid-layout">
        <div class="avoid-copy">
          <span class="eyebrow">What we refuse to do</span>
          <h2>Cheap <span>links are usually expensive</span> later</h2>
          <p>A backlink service should not leave you wondering whether your domain is being used as a test subject. We avoid the shortcuts that make link reports look busy but create risk, weak relevance or poor-quality authority.</p>
          <p>If a placement cannot pass a common-sense review, it does not belong in a serious SEO campaign.</p>
        </div>
        <div class="avoid-grid">
          {avoidItems.map((item) => (
            <article class="avoid-card">
              <h3>{item.title}</h3>
              <p>{item.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="quality-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="quality-layout">
        <div class="quality-panel">
          <span class="eyebrow">Link quality framework</span>
          <h2>How we judge whether a backlink is <span>worth having</span></h2>
          <p>Metrics such as DA, DR or traffic estimates can help, but they are not enough. A link should be relevant, crawlable, editorially defensible and useful in the wider SEO plan.</p>
        </div>
        <ul class="quality-list">
          {qualityChecks.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="fit-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-heading centered">
        <span class="eyebrow">Who this is for</span>
        <h2><span>Link building makes</span> sense when the foundations are ready</h2>
        <p>Backlinks can push a strong SEO campaign forward. They are less useful when the target pages are thin, the site is technically messy or there is no clear commercial keyword strategy.</p>
      </div>
      <div class="fit-grid">
        {fitBlocks.map((item) => (
          <article class="fit-card">
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="process-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-heading split-heading">
        <div>
          <span class="eyebrow">Our process</span>
          <h2>From backlink audit to <span>safer authority growth</span></h2>
        </div>
        <p>We do not start by promising a fixed number of links. We start by understanding the authority gap, the risk profile and the pages that deserve support.</p>
      </div>
      <div class="process-rail">
        {processSteps.map((step) => (
          <article class="process-step">
            <span>{step.label}</span>
            <div>
              <h3>{step.title}</h3>
              <p>{step.copy}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="reporting-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="reporting-layout">
        <div>
          <span class="eyebrow">Reporting</span>
          <h2>Link building should not be a <span>black box</span></h2>
          <p>You should know what was built, why it was chosen and how it supports the campaign. A vague monthly count is not enough, especially when link quality and anchor text can affect long-term SEO safety.</p>
          <p>We report links in context, then connect the work back to target pages, ranking movement, Search Console visibility and the wider SEO roadmap.</p>
        </div>
        <ul class="report-list">
          {reportFields.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="internal-links-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="internal-panel">
        <div>
          <span class="eyebrow">Connected SEO work</span>
          <h2><span>Backlinks</span> work best with strong pages behind them</h2>
          <p>Link building is usually one part of a wider SEO campaign. If your service pages, content, technical health or local signals are weak, we will flag that before spending budget on authority.</p>
        </div>
        <div class="internal-links">
          <a href="/seo-services-philippines/">SEO services Philippines</a>
          <a href="/content-seo-services-philippines/">SEO content writing services</a>
          <a href="/technical-seo-services-philippines/">Technical SEO services</a>
          <a href="/seo-audit-services/">SEO audit services</a>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="max-w-4xl mx-auto px-6">
      <div class="section-heading centered">
        <span class="eyebrow">Questions buyers ask</span>
        <h2><span>Backlink and link building FAQs</span></h2>
      </div>
      <div class="faq-list">
        {faqs.map((item) => (
          <details class="faq-item">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="max-w-5xl mx-auto px-6">
      <div class="cta-panel">
        <span class="eyebrow">Start with the audit</span>
        <h2>Find out whether your <span>backlink profile</span> is helping or holding you back</h2>
        <p>We will review your current links, anchor text, target pages, competitor authority gap and obvious risk patterns, then show where link building fits into the wider SEO plan.</p>
        <div class="cta-actions">
          <ButtonPrimary href="/contact/" text="Get a Backlink Audit" />
          <ButtonSecondary href="/case-studies/" text="View Case Studies" />
        </div>
      </div>
    </div>
  </section>

  <ContactSection />
  <Footer slot="footer" />
</MainLayout>

<style>
.link-hero-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  margin-top: 1.5rem;
}

.stat {
  background: rgba(13, 15, 26, 0.74);
  border: 1px solid rgba(240, 98, 42, 0.24);
  border-radius: 18px;
  padding: 1rem;
}

.stat strong {
  display: block;
  color: #f0622a;
  font-size: 1.35rem;
  margin-bottom: 0.35rem;
}

.stat span {
  color: #dfe3f3;
  font-size: 0.92rem;
  line-height: 1.45;
}

section {
  background: #0d0f1a;
  color: #ffffff;
}

.intro-section,
.service-section,
.fit-section,
.reporting-section,
.faq-section {
  padding: 5.5rem 0;
  background: #131627;
}

.proof-section,
.avoid-section,
.quality-section,
.process-section,
.internal-links-section,
.cta-section {
  padding: 5.5rem 0;
  background: #0d0f1a;
}

.intro-layout,
.avoid-layout,
.quality-layout,
.reporting-layout {
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
  gap: 3rem;
  align-items: start;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  color: #f0622a;
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.11em;
  text-transform: uppercase;
  margin-bottom: 1rem;
}

h2 {
  color: #ffffff;
  font-size: clamp(2rem, 4vw, 3.35rem);
  line-height: 1.08;
  font-weight: 900;
  margin: 0 0 1.25rem;
}

h3 {
  color: #ffffff;
  font-weight: 800;
  margin: 0 0 0.75rem;
}

p {
  color: #dfe3f3;
  line-height: 1.75;
  font-size: 1rem;
}

.intro-copy p,
.avoid-copy p,
.quality-panel p,
.reporting-layout p,
.cta-panel p {
  font-size: 1.08rem;
}

.authority-panel,
.quality-panel,
.internal-panel,
.cta-panel {
  background: linear-gradient(135deg, rgba(240, 98, 42, 0.12), rgba(19, 22, 39, 0.95));
  border: 1px solid rgba(240, 98, 42, 0.26);
  border-radius: 28px;
  padding: 2rem;
  box-shadow: 0 28px 70px rgba(0, 0, 0, 0.24);
}

.authority-panel ul,
.quality-list,
.report-list {
  list-style: none;
  margin: 1.25rem 0 0;
  padding: 0;
}

.authority-panel li,
.quality-list li,
.report-list li {
  position: relative;
  padding: 0.85rem 0 0.85rem 1.8rem;
  color: #eef1ff;
  line-height: 1.55;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.authority-panel li::before,
.quality-list li::before,
.report-list li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 1.25rem;
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #f0622a;
  box-shadow: 0 0 0 5px rgba(240, 98, 42, 0.16);
}

.proof-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}

.proof-card,
.service-card,
.avoid-card,
.fit-card,
.process-step,
.faq-item {
  background: rgba(19, 22, 39, 0.92);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 22px;
  padding: 1.6rem;
}

.proof-card {
  border-color: rgba(240, 98, 42, 0.24);
}

.proof-card p,
.service-card p,
.avoid-card p,
.fit-card p,
.process-step p,
.faq-item p {
  margin: 0;
}

.section-heading {
  margin-bottom: 2.5rem;
}

.split-heading {
  display: grid;
  grid-template-columns: minmax(0, 0.95fr) minmax(320px, 0.75fr);
  gap: 3rem;
  align-items: end;
}

.split-heading p,
.centered p {
  margin: 0;
  font-size: 1.08rem;
}

.centered {
  text-align: center;
  max-width: 850px;
  margin-left: auto;
  margin-right: auto;
}

.service-grid,
.fit-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}

.service-card,
.fit-card {
  transition: transform 0.25s ease, border-color 0.25s ease;
}

.service-card:hover,
.fit-card:hover,
.proof-card:hover {
  transform: translateY(-4px);
  border-color: rgba(240, 98, 42, 0.38);
}

.avoid-grid {
  display: grid;
  gap: 1rem;
}

.avoid-card {
  background: rgba(11, 13, 24, 0.82);
}

.quality-list {
  background: rgba(19, 22, 39, 0.72);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 26px;
  padding: 1rem 1.5rem;
}

.process-rail {
  display: grid;
  gap: 1rem;
}

.process-step {
  display: grid;
  grid-template-columns: 90px minmax(0, 1fr);
  gap: 1.5rem;
  align-items: start;
}

.process-step span {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0622a, #d4510e);
  color: #ffffff;
  font-weight: 900;
}

.reporting-layout {
  align-items: center;
}

.report-list {
  background: #0d0f1a;
  border: 1px solid rgba(240, 98, 42, 0.2);
  border-radius: 26px;
  padding: 1rem 1.5rem;
}

.internal-panel {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(280px, 0.55fr);
  gap: 2rem;
  align-items: center;
}

.internal-links {
  display: grid;
  gap: 0.85rem;
}

.internal-links a {
  display: block;
  color: #ffffff;
  text-decoration: none;
  background: rgba(255, 255, 255, 0.07);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 1rem;
  font-weight: 700;
  transition: background 0.25s ease, border-color 0.25s ease;
}

.internal-links a:hover {
  background: rgba(240, 98, 42, 0.16);
  border-color: rgba(240, 98, 42, 0.34);
}

.faq-list {
  display: grid;
  gap: 1rem;
}

.faq-item {
  padding: 0;
  overflow: hidden;
}

.faq-item summary {
  cursor: pointer;
