---
import Layout from '../layouts/MainLayout.astro';
import LegacyHeader from '../components/LegacyHeader.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import ButtonPrimary from '../components/ButtonPrimary.astro';
import ButtonSecondary from '../components/ButtonSecondary.astro';

const title = "Request an SEO Review | Contact Bright Forge";
const description = "Contact Bright Forge SEO for a practical SEO review covering rankings, technical issues, service pages, AI search visibility and conversion blockers.";

const serviceOptions = [
  ['seo-services', 'Monthly SEO support'],
  ['seo-audit', 'SEO audit'],
  ['technical-seo', 'Technical SEO'],
  ['content-seo', 'Content SEO'],
  ['on-page-seo', 'On-page SEO'],
  ['local-seo', 'Local SEO'],
  ['backlink-seo', 'Backlink SEO'],
  ['keyword-research', 'Keyword research'],
  ['website-migration', 'Website migration SEO'],
  ['ai-search-readiness', 'AI search readiness'],
  ['white-label-seo', 'White label SEO'],
  ['cro', 'SEO and conversion improvement'],
  ['not-sure', 'Not sure yet']
];
---

<Layout title={title} description={description} disableContactPopup={true}>
  <LegacyHeader slot="header" />
  <Footer slot="footer" />

  <Hero
    title="Request an SEO Review That Gets to the Point"
    breadcrumbCurrent="Contact"
    badgeIcon="fas fa-search"
    badgeText="SEO Review"
  >
    <Fragment slot="story">
      <p>Tell us what you want SEO to fix: rankings, enquiries, technical issues, AI search visibility, weak service pages, a messy migration or traffic that is not turning into enough leads.</p>
      <p>We will look at the obvious SEO and conversion signals before replying, then recommend the most sensible next step. If more SEO work is not the answer yet, we will say so.</p>
    </Fragment>

    <Fragment slot="actions">
      <ButtonPrimary href="#contact-form" text="Request an SEO Review" />
      <ButtonSecondary href="tel:+639696206182" text="Call +63 969 620 6182" />
    </Fragment>

    <Fragment slot="stats">
      <div class="contact-hero-points" aria-label="What we review first">
        <span>Technical blockers</span>
        <span>Buyer-intent pages</span>
        <span>Search visibility</span>
      </div>
    </Fragment>

    <Fragment slot="visual">
      <div class="contact-review-card">
        <p class="card-eyebrow">What helps us reply properly</p>
        <ul>
          <li>Your website URL</li>
          <li>Your main target market</li>
          <li>The problem you want SEO to solve</li>
          <li>Any recent drop, migration or campaign concern</li>
        </ul>
        <p class="card-note">We usually reply within one business day.</p>
      </div>
    </Fragment>
  </Hero>

  <section id="contact-form" class="contact-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-intro">
        <p class="eyebrow">Send the useful context</p>
        <h2>Request a practical SEO review</h2>
        <p>Use the form for new campaigns, technical problems, content performance issues, AI search readiness, migration checks or existing SEO work that needs a sharper plan.</p>
      </div>

      <div class="contact-grid">
        <div class="contact-form-card">
          <div class="form-header">
            <h3>Tell us what needs fixing</h3>
            <p>Include the site URL, target market and what success should look like. Rankings are useful, but leads, enquiries and sales context matter too.</p>
          </div>

          <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thanks" id="contactForm">
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

            <div class="form-row">
              <div class="form-group">
                <label for="name">Full name *</label>
                <input type="text" id="name" name="name" required autocomplete="name" placeholder="Your name" />
              </div>

              <div class="form-group">
                <label for="email">Email address *</label>
                <input type="email" id="email" name="email" required autocomplete="email" placeholder="you@example.com" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="phone">Phone number</label>
                <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="Optional" />
              </div>

              <div class="form-group">
                <label for="service">What do you need help with?</label>
                <select id="service" name="service">
                  <option value="">Select a service</option>
                  {serviceOptions.map(([value, label]) => (
                    <option value={value}>{label}</option>
                  ))}
                </select>
              </div>
            </div>

            <div class="form-group">
              <label for="website">Website URL</label>
              <input type="url" id="website" name="website" placeholder="https://example.com" />
            </div>

            <div class="form-group">
              <label for="message">What should SEO fix? *</label>
              <textarea
                id="message"
                name="message"
                required
                rows="6"
                placeholder="Tell us the target market, what is not working, and whether you have seen ranking drops, weak enquiries, technical issues, content problems, migration risk or AI search visibility concerns."
              ></textarea>
            </div>

            <button type="submit" class="submit-btn">
              <span>Send SEO Review Request</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3.33 8h9.34M8.67 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <p class="form-footnote">We usually reply within one business day. If the enquiry needs a quick site check first, we will review the obvious signals before responding.</p>
          </form>
        </div>

        <aside class="contact-sidebar" aria-label="Contact details and fit guidance">
          <div class="fit-card">
            <p class="eyebrow">Good fit</p>
            <h3>This is worth sending if...</h3>
            <ul>
              <li>You already have a site and want SEO to produce clearer commercial outcomes.</li>
              <li>Traffic exists, but enquiries or sales are weaker than they should be.</li>
              <li>A migration, redesign or technical issue could put rankings at risk.</li>
              <li>You need senior SEO judgement before committing to a bigger campaign.</li>
            </ul>
          </div>

          <div class="fit-card muted-card">
            <p class="eyebrow">Probably not right if...</p>
            <ul>
              <li>You need guaranteed rankings by a fixed date.</li>
              <li>You want cheap link volume instead of clean authority work.</li>
              <li>You want AI visibility without fixing the SEO foundations first.</li>
            </ul>
          </div>

          <div class="contact-details-card">
            <h3>Contact details</h3>
            <div class="contact-item">
              <span class="contact-icon" aria-hidden="true">📍</span>
              <div>
                <strong>Office</strong>
                <p>Kathleen Place 4, Block 16, Lot 37, Armani Street, Novaliches, Quezon City, 1116 Metro Manila</p>
              </div>
            </div>
            <div class="contact-item">
              <span class="contact-icon" aria-hidden="true">✉</span>
              <div>
                <strong>Email</strong>
                <a href="mailto:seo@brightforgeseo.com">seo@brightforgeseo.com</a>
              </div>
            </div>
            <div class="contact-item">
              <span class="contact-icon" aria-hidden="true">☎</span>
              <div>
                <strong>Phone</strong>
                <a href="tel:+639696206182">(+63) 969 620 6182</a>
              </div>
            </div>
            <div class="contact-item">
              <span class="contact-icon" aria-hidden="true">◷</span>
              <div>
                <strong>Business hours</strong>
                <p>Monday to Friday: 9:00 AM to 6:00 PM<br />Saturday: 9:00 AM to 2:00 PM</p>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="next-steps-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="next-steps-card">
        <div>
          <p class="eyebrow">No mystery funnel</p>
          <h2>What happens after you enquire</h2>
          <p>We check the site, the search market and the obvious conversion path before recommending work. That keeps the conversation practical from the start.</p>
        </div>
        <ol class="next-steps-list">
          <li><strong>We review the site.</strong><span>Technical health, service pages, rankings, search demand, internal links and obvious conversion blockers.</span></li>
          <li><strong>We separate blockers from nice-to-have clean-up.</strong><span>Not every SEO issue deserves budget. We prioritise what is most likely to move visibility, enquiries or risk.</span></li>
          <li><strong>We recommend a sensible next step.</strong><span>That may be an audit, monthly SEO, technical clean-up, content improvement, migration support or AI search readiness work.</span></li>
        </ol>
      </div>
    </div>
  </section>

  <section class="proof-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="proof-grid">
        <div>
          <p class="eyebrow">Proof before pitch</p>
          <h2>Start with evidence, not guesswork</h2>
        </div>
        <div class="proof-copy">
          <p>Before we suggest work, we look for the patterns that usually explain underperformance: technical friction, weak intent matching, thin service pages, internal link gaps, missing trust signals, tracking problems and conversion leaks.</p>
          <a href="/case-studies/" class="text-link">View case studies</a>
        </div>
      </div>
    </div>
  </section>

  <section class="map-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="map-grid">
        <div class="map-copy">
          <p class="eyebrow">Quezon City based</p>
          <h2>Philippines SEO support with international search experience</h2>
          <p>We are based in Quezon City and work with Philippine and international businesses that need SEO handled properly, from technical clean-up to content, authority, migrations and AI search readiness.</p>
        </div>
        <div class="map-wrapper">
          <iframe
            title="Bright Forge SEO office map"
            src="https://www.google.com/maps?q=14.704227661571542,121.04448433671261&hl=en&z=16&output=embed"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  :global(body .hero-visual) {
    display: flex !important;
    visibility: visible !important;
  }

  :global(body .hero-visual *) {
    display: revert !important;
    visibility: visible !important;
  }

  .contact-review-card {
    width: min(100%, 430px);
    background: linear-gradient(145deg, rgba(19, 22, 39, 0.96), rgba(13, 15, 26, 0.98));
    border: 1px solid rgba(240, 98, 42, 0.28);
    border-radius: 2rem;
    padding: 2rem;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.32);
  }

  .card-eyebrow,
  .eyebrow {
    color: #f0622a;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 0.9rem;
  }

  .contact-review-card ul,
  .fit-card ul,
  .next-steps-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .contact-review-card li {
    color: #ffffff;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .contact-review-card li:last-child {
    border-bottom: 0;
  }

  .card-note {
    color: #c9cedd;
    margin: 1.25rem 0 0;
    line-height: 1.6;
  }

  .contact-hero-points {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .contact-hero-points span {
    padding: 0.85rem 0.9rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #ffffff;
    font-size: 0.88rem;
    font-weight: 700;
    text-align: center;
  }

  .contact-section,
  .next-steps-section,
  .proof-section,
  .map-section {
    content-visibility: visible !important;
  }

  .contact-section {
    padding: 5rem 0;
    background: #0d0f1a;
  }

  .section-intro {
    max-width: 760px;
    margin-bottom: 2.5rem;
  }

  .section-intro h2,
  .next-steps-card h2,
  .proof-grid h2,
  .map-copy h2 {
    color: #ffffff;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.08;
    margin: 0 0 1rem;
    letter-spacing: -0.03em;
  }

  .section-intro p,
  .form-header p,
  .fit-card li,
  .contact-details-card p,
  .contact-details-card a,
  .next-steps-card p,
  .next-steps-list span,
  .proof-copy p,
  .map-copy p,
  .form-footnote {
    color: #c9cedd;
    line-height: 1.65;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
    gap: 2rem;
    align-items: start;
  }

  .contact-form-card,
  .fit-card,
  .contact-details-card,
  .next-steps-card,
  .proof-grid,
  .map-grid {
    background: #131627;
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 2rem;
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.18);
  }

  .contact-form-card {
    padding: 2.5rem;
    border-color: rgba(240, 98, 42, 0.24);
  }

  .form-header {
    margin-bottom: 1.75rem;
  }

  .form-header h3,
  .fit-card h3,
  .contact-details-card h3 {
    color: #ffffff;
    font-size: 1.35rem;
    margin: 0 0 0.65rem;
    letter-spacing: -0.02em;
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 1.15rem;
  }

  .form-group label {
    display: block;
    color: #ffffff;
    font-size: 0.88rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.95rem 1rem;
    border-radius: 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.11);
    background: #0d0f1a;
    color: #ffffff;
    font-size: 0.95rem;
    line-height: 1.5;
    box-sizing: border-box;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(255, 255, 255, 0.48);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #f0622a;
    box-shadow: 0 0 0 3px rgba(240, 98, 42, 0.14);
  }

  .submit-btn {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    padding: 1rem 1.5rem;
    border-radius: 999px;
    border: 1px solid rgba(240, 98, 42, 0.9);
    background: #f0622a;
    color: #111421;
    font-weight: 900;
    font-size: 1rem;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px rgba(240, 98, 42, 0.25);
  }

  .form-footnote {
    margin: 1rem 0 0;
    font-size: 0.9rem;
  }

  .contact-sidebar {
    display: grid;
    gap: 1rem;
  }

  .fit-card,
  .contact-details-card {
    padding: 1.75rem;
  }

  .fit-card li {
    position: relative;
    padding: 0 0 0.85rem 1.35rem;
  }

  .fit-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62rem;
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 50%;
    background: #f0622a;
  }

  .muted-card {
    background: rgba(19, 22, 39, 0.72);
  }

  .contact-details-card {
    display: grid;
    gap: 1.15rem;
  }

  .contact-item {
    display: grid;
    grid-template-columns: 2.3rem 1fr;
    gap: 0.9rem;
    align-items: start;
  }

  .contact-icon {
    display: grid;
    place-items: center;
    width: 2.3rem;
    height: 2.3rem;
    border-radius: 0.8rem;
    background: rgba(240, 98, 42, 0.14);
    color: #f0622a;
  }

  .contact-item strong {
    display: block;
    color: #ffffff;
    margin-bottom: 0.25rem;
  }

  .contact-details-card a,
  .text-link {
    color: #ffffff;
    text-decoration: none;
    font-weight: 700;
  }

  .contact-details-card a:hover,
  .text-link:hover {
    color: #f0622a;
  }

  .next-steps-section,
  .proof-section,
  .map-section {
    padding: 5rem 0;
    background: #111421;
  }

  .next-steps-card,
  .proof-grid,
  .map-grid {
    padding: 3rem;
  }

  .next-steps-card {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 3rem;
  }

  .next-steps-list {
    display: grid;
    gap: 1rem;
    counter-reset: step;
  }

  .next-steps-list li {
    position: relative;
    display: grid;
    gap: 0.35rem;
    padding: 1.2rem 1.2rem 1.2rem 3.5rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.04);
    counter-increment: step;
  }

  .next-steps-list li::before {
    content: counter(step);
    position: absolute;
    left: 1rem;
    top: 1rem;
    width: 1.65rem;
    height: 1.65rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: #f0622a;
    color: #111421;
    font-weight: 900;
  }

  .next-steps-list strong {
    color: #ffffff;
  }

  .proof-grid,
  .map-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 3rem;
    align-items: center;
  }

  .proof-copy p,
  .map-copy p {
    margin-top: 0;
  }

  .map-section {
    background: #0d0f1a;
  }

  .map-grid {
    grid-template-columns: 0.85fr 1.15fr;
  }

  .map-wrapper {
    height: 360px;
    border-radius: 1.5rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: #0d0f1a;
  }

  .map-wrapper iframe {
    width: 100%;
    height: 100%;
  }

  .hidden {
    display: none;
  }

  @media (max-width: 1024px) {
    .contact-grid,
    .next-steps-card,
    .proof-grid,
    .map-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    :global(body .hero-visual) {
      display: none !important;
    }

    .contact-section,
    .next-steps-section,
    .proof-section,
    .map-section {
      padding: 3.5rem 0;
    }

    .contact-hero-points,
    .form-row {
      grid-template-columns: 1fr;
    }

    .contact-form-card,
    .fit-card,
    .contact-details-card,
    .next-steps-card,
    .proof-grid,
    .map-grid {
      padding: 1.5rem;
      border-radius: 1.4rem;
    }

    .section-intro h2,
    .next-steps-card h2,
    .proof-grid h2,
    .map-copy h2 {
      font-size: 2rem;
    }

    .map-wrapper {
      height: 300px;
    }
  }
</style>
