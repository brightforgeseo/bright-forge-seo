<script>
  // Tab functionality
  function showBFService(serviceName) {
    // Hide all service boxes
    const serviceBoxes = document.querySelectorAll('.bf-service-box');
    serviceBoxes.forEach(box => {
      box.classList.remove('active');
    });
    
    // Remove active class from all tabs
    const tabs = document.querySelectorAll('.tab-btn');
    tabs.forEach(tab => {
      tab.classList.remove('active');
    });
    
    // Show selected service box
    document.getElementById(serviceName).classList.add('active');
    
    // Add active class to clicked tab
    const clickedTab = document.querySelector(`[data-tab="${serviceName}"]`);
    if (clickedTab) {
      clickedTab.classList.add('active');
    }
  }
  
  // Add click event listeners to tabs
  document.addEventListener('DOMContentLoaded', function() {
    const tabLinks = document.querySelectorAll('.tab-btn');
    tabLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        const tabName = this.getAttribute('data-tab');
        showBFService(tabName);
      });
    });
    
    // Add minimal JavaScript to ensure audit form submission works correctly
    const auditForm = document.querySelector('.audit-form');
    if (auditForm) {
      auditForm.addEventListener('submit', function(e) {
        // Don't prevent default, just add loading state
        const submitBtn = this.querySelector('.audit-btn');
        if (submitBtn) {
          submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';
          submitBtn.disabled = true;
        }
        
        // Log form submission for debugging
        console.log('Form submitted to Netlify');
      });
    }
    
    // Add JavaScript for the contact form submission
    const contactForm = document.querySelector('.contact-form');
    if (contactForm) {
      contactForm.addEventListener('submit', function(e) {
        // Don't prevent default, just add loading state
        const submitBtn = this.querySelector('.form-submit-btn');
        if (submitBtn) {
          const btnText = submitBtn.querySelector('span');
          if (btnText) {
            btnText.textContent = 'Sending...';
          }
          submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';
          submitBtn.disabled = true;
        }
        
        // Log form submission for debugging
        console.log('Contact form submitted to Netlify');
      });
    }
  });
</script>

<script>
  const API_URL = 'https://seo-audit-tool-backend.onrender.com/api/analyze';
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('form[name="homepage-audit"]');
    const input = document.getElementById('website-url');
    const message = document.getElementById('audit-message');
    if (!form || !input) return;

    // Create modal container for detailed results
    const modalOverlay = document.createElement('div');
    modalOverlay.id = 'audit-modal-overlay';
    modalOverlay.className = 'fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center';
    modalOverlay.style.display = 'none';
    document.body.appendChild(modalOverlay);
    
    const modalContent = document.createElement('div');
    modalContent.id = 'audit-modal-content';
    modalContent.className = 'rounded-lg shadow-xl max-w-3xl w-full max-h-[90vh] overflow-y-auto p-6 relative';
    // Enforce site grey background to avoid white modal background
    modalContent.style.setProperty('background-color', '#131627', 'important');
    modalOverlay.appendChild(modalContent);
    
    const closeButton = document.createElement('button');
    closeButton.className = 'absolute top-4 right-4 text-[#d0d4e8] hover:text-[#e8eaf2]';
    closeButton.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>';
    closeButton.onclick = () => modalOverlay.style.display = 'none';
    modalContent.appendChild(closeButton);
    
    // Create results container (simplified version for the homepage)
    const resultsContainer = document.createElement('div');
    resultsContainer.id = 'audit-results';
    resultsContainer.className = 'mt-4 p-4 rounded-lg border border-[rgba(255,255,255,0.07)] hidden';
    // Force site grey background for summary block below the form
    resultsContainer.style.setProperty('background-color', '#1a1e32', 'important');
    form.parentNode.insertBefore(resultsContainer, form.nextSibling);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const url = input.value.trim();
      if (!url) {
        message.textContent = 'Please enter a valid URL.';
        return;
      }
      const submitBtn = form.querySelector('button[type="submit"]');
      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Analyzing...';
      message.textContent = 'Running SEO audit...';
      resultsContainer.classList.add('hidden');
      resultsContainer.innerHTML = '';
      
      try {
        const res = await fetch(API_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url })
        });
        if (!res.ok) {
          const text = await res.text();
          throw new Error(text || `Error ${res.status}`);
        }
        const data = await res.json();
        console.log('SEO Audit Result:', data);
        message.textContent = 'Audit complete!';
        
        // Display summary results on page
        displaySummaryResults(data, resultsContainer);
        resultsContainer.classList.remove('hidden');
        
        // Display detailed results in modal
        displayDetailedResults(data, modalContent);
        
        // Add "View Details" button to summary
        const detailsButton = document.createElement('button');
        detailsButton.className = 'mt-3 bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded';
        detailsButton.textContent = 'View Detailed Report';
        detailsButton.onclick = () => modalOverlay.style.display = 'flex';
        resultsContainer.appendChild(detailsButton);
      } catch (err) {
        console.error(err);
        message.textContent = 'Oops! Something went wrong. Please try again later.';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
    
    // Close modal when clicking outside content
    modalOverlay.addEventListener('click', (e) => {
      if (e.target === modalOverlay) {
        modalOverlay.style.display = 'none';
      }
    });

    // Close modal on ESC key press
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        modalOverlay.style.display = 'none';
      }
    });
    
    // Function to display summary results
    function displaySummaryResults(data, container) {
      container.innerHTML = '';
      
      // Create header
      const header = document.createElement('div');
      header.className = 'mb-4';
      header.innerHTML = `<h3 class="text-xl font-bold">SEO Audit Results for ${data.url || 'Website'}</h3>`;
      container.appendChild(header);
      
      // Calculate score and issues
      const { overallScore, issues } = calculateScoreAndIssues(data);
      
      // Create score section
      const scoreSection = document.createElement('div');
      scoreSection.className = 'mb-4 p-3 rounded shadow-[0_1px_3px_rgba(0,0,0,0.2)]';
      // Prevent white block for score container
      scoreSection.style.setProperty('background-color', '#1a1e32', 'important');
      scoreSection.innerHTML = `
        <div class="flex justify-between items-center">
          <span class="font-bold">Overall Score:</span>
          <span class="text-lg font-bold ${getScoreColorClass(overallScore)}">${overallScore}/100</span>
        </div>
      `;
      container.appendChild(scoreSection);
      
      // Create recommendations section
      const recommendationsSection = document.createElement('div');
      recommendationsSection.className = 'mt-4';
      recommendationsSection.innerHTML = `
        <p class="text-sm">For a detailed analysis and recommendations, please <a href="/contact/" class="text-blue-600 hover:underline">contact us</a>.</p>
      `;
      container.appendChild(recommendationsSection);
    }
    
    // Function to display detailed results in modal
    function displayDetailedResults(data, container) {
      container.innerHTML = '';
      
      // Create header
      const header = document.createElement('div');
      header.className = 'mb-6 border-b pb-4';
      header.innerHTML = `<h2 class="text-2xl font-bold">Detailed SEO Audit for ${data.url || 'Website'}</h2>`;
      container.appendChild(header);
      
      // Calculate score and issues
      const { overallScore, issues, analysis } = calculateScoreAndIssues(data);
      
      // Create score section
      const scoreSection = document.createElement('div');
      scoreSection.className = 'mb-6 p-4 bg-[#1a1e32] rounded-lg';
      scoreSection.innerHTML = `
        <div class="flex justify-between items-center mb-4">
          <span class="text-xl font-bold">Overall SEO Score:</span>
          <span class="text-2xl font-bold ${getScoreColorClass(overallScore)}">${overallScore}/100</span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2.5">
          <div class="${getScoreColorClass(overallScore).replace('text-', 'bg-')} h-2.5 rounded-full" style="width: ${overallScore}%"></div>
        </div>
      `;
      container.appendChild(scoreSection);
      
      // Create issues section
      if (issues.length > 0) {
        const issuesSection = document.createElement('div');
        issuesSection.className = 'mb-6';
        issuesSection.innerHTML = `<h3 class="text-xl font-bold mb-3">Issues Found</h3>`;
        
        const issuesList = document.createElement('ul');
        issuesList.className = 'space-y-2';
        
        issues.forEach(issue => {
          const item = document.createElement('li');
          item.className = 'p-3 bg-red-50 border border-red-100 rounded-md flex items-start';
          item.innerHTML = `
            <svg class="w-5 h-5 text-red-500 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <span>${issue}</span>
          `;
          issuesList.appendChild(item);
        });
        
        issuesSection.appendChild(issuesList);
        container.appendChild(issuesSection);
      }
      
      // Display detailed metrics if available
      if (data.analysis) {
        const metricsSection = document.createElement('div');
        metricsSection.className = 'mb-6';
        metricsSection.innerHTML = `<h3 class="text-xl font-bold mb-3">Detailed Metrics</h3>`;
        
        const metricsTable = document.createElement('div');
        metricsTable.className = 'grid grid-cols-1 md:grid-cols-2 gap-4';
        
        // Basic SEO Elements
        addMetricItem(metricsTable, 'Title', data.analysis.title || 'Not found', Boolean(data.analysis.title));
        addMetricItem(metricsTable, 'Meta Description', data.analysis.metaDescription || 'Not found', Boolean(data.analysis.metaDescription));
        addMetricItem(metricsTable, 'H1 Tags', data.analysis.h1Count || '0', data.analysis.h1Count === 1);
        
        // Images
        if (data.analysis.imgCount !== undefined) {
          const altTextPercentage = data.analysis.imgCount > 0 ? 
            Math.round((data.analysis.imgWithAltCount / data.analysis.imgCount) * 100) : 0;
          addMetricItem(metricsTable, 'Images with Alt Text', 
            `${data.analysis.imgWithAltCount || 0}/${data.analysis.imgCount} (${altTextPercentage}%)`, 
            altTextPercentage === 100);
        }
        
        // Technical SEO
        addMetricItem(metricsTable, 'HTTPS/SSL', data.analysis.hasSSL ? 'Yes' : 'No', data.analysis.hasSSL);
        addMetricItem(metricsTable, 'Mobile Viewport', data.analysis.hasMobileViewport ? 'Yes' : 'No', data.analysis.hasMobileViewport);
        addMetricItem(metricsTable, 'Canonical URL', data.analysis.canonicalUrl || 'Not found', Boolean(data.analysis.canonicalUrl));
        
        // Links
        if (data.analysis.internalLinks !== undefined) {
          addMetricItem(metricsTable, 'Internal Links', data.analysis.internalLinks, true);
        }
        if (data.analysis.externalLinks !== undefined) {
          addMetricItem(metricsTable, 'External Links', data.analysis.externalLinks, true);
        }
        
        metricsSection.appendChild(metricsTable);
        container.appendChild(metricsSection);
      }
      
      // Create CTA section
      const ctaSection = document.createElement('div');
      ctaSection.className = 'mt-8 p-4 bg-blue-50 border border-blue-100 rounded-lg text-center';
      ctaSection.innerHTML = `
        <h3 class="text-lg font-bold mb-2">Want a more comprehensive analysis?</h3>
        <p class="mb-4">Our SEO experts can provide a detailed audit with actionable recommendations.</p>
        <a href="/contact/" class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-6 rounded-md">Contact Us for Full Analysis</a>
      `;
      container.appendChild(ctaSection);
    }
    
    // Helper function to add metric items to the table
    function addMetricItem(container, label, value, isGood) {
      const item = document.createElement('div');
      item.className = 'flex justify-between items-center';
      item.innerHTML = `
        <span>${label}:</span>
        <span class="flex items-center">
          ${value}
          ${isGood ? 
            '<svg class="w-5 h-5 text-green-500 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>' : 
            '<svg class="w-5 h-5 text-yellow-500 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>'}
        </span>
      `;
      container.appendChild(item);
    }
    
    // Helper function to calculate score and issues
    function calculateScoreAndIssues(data) {
      let overallScore = 'N/A';
      let issues = [];
      let analysis = null;
      
      // Check if we have analysis data
      if (data.analysis) {
        analysis = data.analysis;
        let totalPoints = 0;
        let maxPoints = 0;
        
        // Title check
        if (analysis.title) {
          maxPoints += 10;
          const titleLength = analysis.title.length;
          if (titleLength >= 30 && titleLength <= 60) {
            totalPoints += 10;
          } else {
            totalPoints += 5;
            issues.push('Title length is not optimal (30-60 characters recommended)');
          }
        }
        
        // Meta description check
        if (analysis.metaDescription !== undefined) {
          maxPoints += 10;
          if (analysis.metaDescription) {
            const descLength = analysis.metaDescription.length;
            if (descLength >= 120 && descLength <= 160) {
              totalPoints += 10;
            } else {
              totalPoints += 5;
              issues.push('Meta description length is not optimal (120-160 characters recommended)');
            }
          } else {
            issues.push('Missing meta description');
          }
        }
        
        // H1 check
        if (analysis.h1Count !== undefined) {
          maxPoints += 10;
          if (analysis.h1Count === 1) {
            totalPoints += 10;
          } else if (analysis.h1Count > 1) {
            totalPoints += 5;
            issues.push('Multiple H1 tags found (only one recommended)');
          } else {
            issues.push('Missing H1 tag');
          }
        }
        
        // Image alt text check
        if (analysis.imgCount > 0 && analysis.imgWithAltCount !== undefined) {
          maxPoints += 10;
          const altTextPercentage = (analysis.imgWithAltCount / analysis.imgCount) * 100;
          totalPoints += Math.round(altTextPercentage / 10);
          
          if (altTextPercentage < 100) {
            issues.push(`${Math.round(100 - altTextPercentage)}% of images missing alt text`);
          }
        }
        
        // SSL check
        if (analysis.hasSSL !== undefined) {
          maxPoints += 10;
          if (analysis.hasSSL) {
            totalPoints += 10;
          } else {
            issues.push('Site is not using HTTPS/SSL');
          }
        }
        
        // Mobile viewport check
        if (analysis.hasMobileViewport !== undefined) {
          maxPoints += 10;
          if (analysis.hasMobileViewport) {
            totalPoints += 10;
          } else {
            issues.push('Missing mobile viewport meta tag');
          }
        }
        
        // Calculate final score if we have points
        if (maxPoints > 0) {
          overallScore = Math.round((totalPoints / maxPoints) * 100);
        }
      }
      
      return { overallScore, issues, analysis };
    }
    
    // Helper function for score colors
    function getScoreColorClass(score) {
      if (score === 'N/A') return 'text-[#d0d4e8]';
      if (score >= 80) return 'text-green-600';
      if (score >= 50) return 'text-yellow-600';
      return 'text-red-600';
    }
  });
</script>

<script>
  // FAQ Accordion functionality
  document.addEventListener('DOMContentLoaded', () => {
    const faqDetails = document.querySelectorAll('.faq-details');
    
    // Add click event listeners to all FAQ items
    faqDetails.forEach(detail => {
      detail.addEventListener('click', (e) => {
        // Close all other open FAQ items when opening a new one
        if (e.target.closest('summary') && !detail.open) {
          faqDetails.forEach(otherDetail => {
            if (otherDetail !== detail && otherDetail.open) {
              otherDetail.open = false;
            }
          });
        }
      });
    });
  });
</script>
