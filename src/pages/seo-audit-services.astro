---
import MainLayout from '../layouts/MainLayout.astro';
import LegacyHeader from '../components/LegacyHeader.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';
import Hero from '../components/Hero.astro';
import ButtonPrimary from '../components/ButtonPrimary.astro';
import ButtonSecondary from '../components/ButtonSecondary.astro';

const proofItems = [
  {
    title: 'Evidence before recommendations',
    copy: 'We review crawl data, Search Console signals, rankings, page performance, content quality, internal links and conversion paths before we tell you what to change.'
  },
  {
    title: 'Prioritised by commercial impact',
    copy: 'An audit should not bury your team in a huge issue list. We separate urgent blockers, growth opportunities, quick wins and low-value noise.'
  },
  {
    title: 'Built for implementation',
    copy: 'The output is written for owners, marketers, developers and content teams, with clear next steps rather than generic tool exports.'
  }
];

const auditTriggers = [
  'Organic traffic has dropped and the cause is not obvious',
  'Important keywords are stuck despite ongoing SEO work',
  'The site gets impressions but not enough clicks or leads',
  'A redesign, migration, CMS change or domain move is planned',
  'Google Search Console is showing crawl, indexing or page experience warnings',
  'Content is being published but the right pages are not moving',
  'A developer or agency has changed the site and rankings have shifted',
  'You need a clear SEO roadmap before spending more on content, links or technical work'
];

const auditAreas = [
  {
    title: 'Crawlability and indexation',
    copy: 'We check whether Google can discover, crawl, render and index the right URLs, including robots.txt, noindex tags, canonicals, sitemap quality, redirects and crawl waste.'
  },
  {
    title: 'Site architecture and internal links',
    copy: 'We review how authority and relevance move through the site, whether priority pages are buried and whether internal anchors support the right topics.'
  },
  {
    title: 'Technical SEO and performance',
    copy: 'We assess Core Web Vitals, mobile usability, status codes, duplicate URLs, JavaScript risks, schema fit, structured data errors and page template problems.'
  },
  {
    title: 'Content quality and search intent',
    copy: 'We check whether key pages match the SERP, answer the buyer properly, avoid cannibalisation and provide enough depth, proof and clarity to compete.'
  },
  {
    title: 'Keyword and opportunity mapping',
    copy: 'We compare current rankings, missing opportunities and competitor coverage so every recommendation is tied to actual search demand and business value.'
  },
  {
    title: 'Authority and backlink profile',
    copy: 'We review backlink quality, risky patterns, lost links, anchor text, competitor authority gaps and the pages most likely to benefit from safer link growth.'
  },
  {
    title: 'Local and service-page signals',
    copy: 'For Philippine and local service businesses, we review location relevance, service clarity, trust signals, NAP consistency and local conversion paths.'
  },
  {
    title: 'Conversion and enquiry path',
    copy: 'SEO traffic has to become leads. We check CTAs, proof, form paths, contact clarity, page flow and whether the visitor has enough reason to act.'
  }
];

const toolLimits = [
  {
    title: 'Automated scans report symptoms',
    copy: 'A tool can flag missing metadata, slow pages or duplicate titles. It cannot always tell whether the page matters commercially or whether the fix should be done now.'
  },
  {
    title: 'Context changes priority',
    copy: 'A technical warning on a blocked tag page may be irrelevant. A weaker issue on a core service page may be urgent because it affects rankings and enquiries.'
  },
  {
    title: 'SEO judgement matters',
    copy: 'The value of an audit is not the number of warnings found. It is knowing which fixes will move the campaign and which ones are only report padding.'
  }
];

const priorityFramework = [
  {
    label: 'Blockers',
    title: 'Fix first',
    copy: 'Indexation failures, broken templates, redirect errors, canonical conflicts, critical crawl issues and tracking problems that stop performance from being judged properly.'
  },
  {
    label: 'Growth fixes',
    title: 'Fix next',
    copy: 'Pages with search demand, existing impressions, ranking potential or conversion value where technical, content or internal-link improvements can support growth.'
  },
  {
    label: 'Campaign support',
    title: 'Plan into the roadmap',
    copy: 'Content gaps, authority gaps, architecture improvements and template changes that should be handled as part of a wider SEO campaign.'
  },
  {
    label: 'Low-value noise',
    title: 'Ignore or park',
    copy: 'Warnings that look dramatic in tools but have little commercial upside, low risk or no meaningful connection to organic performance.'
  }
];

const processSteps = [
  {
    label: '01',
    title: 'Access and baseline',
    copy: 'We confirm the business goals, priority pages, analytics setup, Search Console data, current rankings and the problem the audit needs to answer.'
  },
  {
    label: '02',
    title: 'Crawl and technical diagnosis',
    copy: 'We crawl the site, review indexation signals, inspect templates, test performance, check structured data and look for technical blockers.'
  },
  {
    label: '03',
    title: 'Content, intent and competitor review',
    copy: 'We assess priority pages against search intent, SERP competitors, keyword mapping, content depth, proof, internal links and conversion clarity.'
  },
  {
    label: '04',
    title: 'Authority and risk review',
    copy: 'We examine backlink quality, authority gaps, anchor patterns, lost links and off-page risks that may affect rankings or future growth.'
  },
  {
    label: '05',
    title: 'Roadmap and handover',
    copy: 'We deliver a prioritised roadmap with findings, evidence, recommended fixes, responsible teams and the order work should happen in.'
  }
];

const deliverables = [
  {
    title: 'Audit summary for decision makers',
    copy: 'A plain-English overview of what is holding the site back, which fixes matter most and what the business should do next.'
  },
  {
    title: 'Technical and content findings',
    copy: 'Evidence-backed findings across crawlability, indexation, site structure, performance, content quality, on-page SEO and conversion paths.'
  },
  {
    title: 'Prioritised implementation roadmap',
    copy: 'A practical task list grouped by impact, urgency, complexity and likely owner, so developers, content teams and stakeholders know what to do first.'
  },
  {
    title: 'Strategic next-step recommendations',
    copy: 'Clear guidance on whether the site needs technical SEO, content improvement, link building, local SEO, migration support or wider campaign work.'
  }
];

const avoidItems = [
  {
    title: 'No fake scores',
    copy: 'We do not pretend a random website score explains SEO performance. Scores can help with triage, but they are not strategy.'
  },
  {
    title: 'No issue dumping',
    copy: 'A 200-item export is not useful if nobody knows what matters. We cut through the noise and focus on the work that deserves attention.'
  },
  {
    title: 'No guaranteed ranking claims',
    copy: 'An audit can uncover blockers and opportunities. It cannot honestly guarantee rankings, traffic or leads without implementation and measurement.'
  },
  {
    title: 'No one-size-fits-all checklist',
    copy: 'An ecommerce site, a local service site and a national B2B site need different audit priorities. The diagnosis should fit the business.'
  }
];

const connectedServices = [
  {
    title: 'Technical SEO services',
    href: '/technical-seo-services-philippines/',
    copy: 'For crawl, indexation, rendering, performance, schema and architecture fixes found during the audit.'
  },
  {
    title: 'On-page SEO services',
    href: '/on-page-seo-services-philippines/',
    copy: 'For improving page structure, metadata, content depth, internal links, FAQs and conversion flow.'
  },
  {
    title: 'Keyword research services',
    href: '/keyword-research-services/',
    copy: 'For mapping search demand, intent and opportunity before content or page changes are planned.'
  },
  {
    title: 'Link building services',
    href: '/backlink-seo-services-philippines/',
    copy: 'For authority growth once the site has the right technical and content foundations in place.'
  },
  {
    title: 'Website migration services',
    href: '/website-migration-services/',
    copy: 'For pre-migration and post-migration audits when redesigns, CMS changes or URL moves are risky.'
  },
  {
    title: 'SEO services Philippines',
    href: '/seo-services-philippines/',
    copy: 'For turning audit findings into an ongoing SEO campaign across technical, content, authority and reporting.'
  }
];

const faqs = [
  { question: 'What is included in an SEO audit?', answer: 'A proper SEO audit reviews technical SEO, crawlability, indexation, site structure, internal links, content quality, search intent, keyword opportunities, backlink profile, local signals where relevant and the conversion path from organic landing pages.' },
  { question: 'Is this different from an automated website scan?', answer: 'Yes. Automated scans are useful for finding surface-level warnings, but they do not understand commercial priority. We use tools as evidence, then apply SEO judgement to decide which issues matter and which ones can wait.' },
  { question: 'Do you need access to Google Search Console and GA4?', answer: 'Read-only access is strongly recommended because it lets us connect findings to impressions, clicks, traffic, engagement and conversion data. We can still perform a crawl-led audit without access, but the recommendations will be less complete.' },
  { question: 'Can you audit a site before a redesign or migration?', answer: 'Yes. Pre-migration audits are often the best time to prevent ranking loss. We review URL structure, redirects, templates, content risk, tracking, internal links and launch QA before major site changes go live.' },
  { question: 'Will you help implement the recommendations?', answer: 'Yes. We can support implementation directly, work with your developer or content team, or turn the findings into an ongoing SEO campaign. The audit makes the priorities clear before implementation starts.' },
  { question: 'How long does an SEO audit take?', answer: 'Most small to mid-sized business audits take one to two weeks depending on site size, data access and complexity. Larger ecommerce, marketplace or multi-location sites may need a longer audit window.' },
  { question: 'Do you audit content and backlinks as well as technical SEO?', answer: 'Yes. Technical issues are only part of SEO performance. We also review content quality, search intent, keyword mapping, internal links, authority signals, backlink quality and competitor gaps.' },
  { question: 'What happens after the audit?', answer: 'You receive a prioritised roadmap. From there, the next step may be technical fixes, page rewrites, internal linking, content planning, link building, migration support or a wider SEO campaign.' }
];
---

<MainLayout
  title="SEO Audit Services Philippines | Clear SEO Roadmaps"
  description="SEO audit services in the Philippines for technical issues, content gaps, rankings, traffic drops, backlink risks and clear implementation roadmaps."
  keywords="SEO audit services Philippines, SEO audit services, website SEO audit, technical SEO audit, SEO site audit"
  faqs={faqs}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://brightforge.com.ph/'
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'SEO Audit Services Philippines',
          item: 'https://brightforge.com.ph/seo-audit-services/'
        }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: 'SEO Audit Services Philippines',
      url: 'https://brightforge.com.ph/seo-audit-services/',
      inLanguage: 'en',
      description: 'SEO audit services for diagnosing ranking drops, technical SEO issues, content gaps, backlink risks and conversion problems.',
      publisher: {
        '@type': 'Organization',
        name: 'Bright Forge SEO',
        url: 'https://brightforge.com.ph/'
      },
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: auditAreas.map((item, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: item.title,
          description: item.copy
        }))
      }
    })} />
  </Fragment>

  <LegacyHeader slot="header" />

  <Hero
    badgeIcon="fas fa-search-plus"
    badgeText="SEO Audit Specialists"
    title="SEO Audit Services Philippines for <span>Clearer Rankings, Traffic and Lead Growth</span>"
    breadcrumbCurrent="SEO Audit Services Philippines"
  >
    <Fragment slot="story">
      <p>An SEO audit should do more than list warnings from a tool. It should explain what is blocking rankings, traffic and enquiries, then show which fixes deserve attention first.</p>
      <p>Bright Forge provides SEO audit services in the Philippines for businesses that need a practical diagnosis before investing more in content, links, development or a wider SEO campaign.</p>
    </Fragment>

    <Fragment slot="actions">
      <ButtonPrimary href="/contact/" text="Request an SEO Audit Review" />
      <ButtonSecondary href="#audit-coverage" text="See What We Check" />
    </Fragment>

    <Fragment slot="stats">
      <div class="audit-hero-stats">
        <div class="stat"><strong>Diagnose</strong><span>Crawl, indexation, content, links and conversion issues.</span></div>
        <div class="stat"><strong>Prioritise</strong><span>Separate urgent blockers from low-value noise.</span></div>
        <div class="stat"><strong>Roadmap</strong><span>Turn findings into implementation-ready next steps.</span></div>
      </div>
    </Fragment>
  </Hero>

  <section class="intro-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="intro-layout">
        <div class="intro-copy">
          <span class="eyebrow">Why audit first</span>
          <h2>More SEO activity does not help if the site has the wrong problem</h2>
          <p>Many sites do not need more random blog posts, another backlink package or another round of cosmetic metadata edits. They need to understand why organic performance is stuck, dropping or failing to convert.</p>
          <p>A proper SEO audit gives that clarity. It connects technical evidence, content quality, search demand, authority signals and buyer behaviour into a roadmap your team can actually use.</p>
        </div>
        <aside class="diagnosis-panel" aria-label="SEO audit diagnosis questions">
          <h3>We start with diagnosis, not assumptions</h3>
          <ul>
            <li>Can Google crawl and index the right pages?</li>
            <li>Do priority pages match real search intent?</li>
            <li>Are rankings held back by technical, content or authority gaps?</li>
            <li>Is organic traffic reaching pages that can convert?</li>
            <li>Which fixes should happen first?</li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <section class="proof-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="proof-grid">
        {proofItems.map((item) => (
          <article class="proof-card">
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="triggers-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="triggers-layout">
        <div class="triggers-copy">
          <span class="eyebrow">When to audit</span>
          <h2>An audit is useful when the next SEO move is not obvious</h2>
          <p>If a site has a clear technical blocker, fix it. If the business already has a strong roadmap, execute it. But when rankings, traffic, leads or stakeholder confidence are unclear, an audit prevents expensive guesswork.</p>
        </div>
        <ul class="trigger-list">
          {auditTriggers.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section id="audit-coverage" class="coverage-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-heading split-heading">
        <div>
          <span class="eyebrow">What we audit</span>
          <h2>Technical, content, authority and conversion issues in one SEO diagnosis</h2>
        </div>
        <p>SEO problems rarely sit in one neat bucket. A ranking issue can be caused by crawl waste, weak content, poor internal linking, thin authority, poor intent match or a landing page that fails to convert.</p>
      </div>
      <div class="coverage-grid">
        {auditAreas.map((item) => (
          <article class="coverage-card">
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="tool-limits-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-heading centered">
        <span class="eyebrow">What tools miss</span>
        <h2>An automated scan is not an SEO strategy</h2>
        <p>SEO tools are useful. We use them. But a tool export is evidence, not a decision. The valuable part is interpreting what matters for the site, the market and the business.</p>
      </div>
      <div class="tool-grid">
        {toolLimits.map((item) => (
          <article class="tool-card">
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="priority-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-heading split-heading">
        <div>
          <span class="eyebrow">Prioritisation</span>
          <h2>The audit should make the next 90 days clearer</h2>
        </div>
        <p>The same issue can be urgent on one site and irrelevant on another. We prioritise by risk, business value, search demand, implementation effort and likely SEO upside.</p>
      </div>
      <div class="priority-grid">
        {priorityFramework.map((item) => (
          <article class="priority-card">
            <span>{item.label}</span>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="process-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-heading split-heading">
        <div>
          <span class="eyebrow">Audit process</span>
          <h2>From raw SEO evidence to a practical implementation roadmap</h2>
        </div>
        <p>We do not start by hunting for the biggest number of errors. We start by understanding what the site needs to achieve and what is preventing that from happening.</p>
      </div>
      <div class="process-rail">
        {processSteps.map((step) => (
          <article class="process-step">
            <span>{step.label}</span>
            <div>
              <h3>{step.title}</h3>
              <p>{step.copy}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="deliverables" class="deliverables-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-heading centered">
        <span class="eyebrow">What you receive</span>
        <h2>Clear findings, evidence and next steps</h2>
        <p>The output is designed to help the business make decisions and help the people doing the work implement the right fixes in the right order.</p>
      </div>
      <div class="deliverables-grid">
        {deliverables.map((item) => (
          <article class="deliverable-card">
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="avoid-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="avoid-layout">
        <div class="avoid-copy">
          <span class="eyebrow">What we do not do</span>
          <h2>An SEO audit should build trust, not inflate a report</h2>
          <p>Poor audits make the issue list longer so the service feels bigger. Better audits make the decision clearer, even if that means telling you some warnings are not worth acting on.</p>
        </div>
        <div class="avoid-grid">
          {avoidItems.map((item) => (
            <article class="avoid-card">
              <h3>{item.title}</h3>
              <p>{item.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="internal-links-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-heading split-heading">
        <div>
          <span class="eyebrow">After the audit</span>
          <h2>The roadmap decides which SEO service comes next</h2>
        </div>
        <p>Some audits lead to technical fixes. Others show the need for page rewrites, content planning, safer link building or migration support. The point is to stop guessing.</p>
      </div>
      <div class="connected-grid">
        {connectedServices.map((service) => (
          <a class="connected-card" href={service.href}>
            <h3>{service.title}</h3>
            <p>{service.copy}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="max-w-4xl mx-auto px-6">
      <div class="section-heading centered">
        <span class="eyebrow">Questions buyers ask</span>
        <h2>SEO audit services FAQs</h2>
      </div>
      <div class="faq-list">
        {faqs.map((item) => (
          <details class="faq-item">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="max-w-5xl mx-auto px-6">
      <div class="cta-panel">
        <span class="eyebrow">Start with diagnosis</span>
        <h2>Send us the site and we’ll show what is actually holding it back</h2>
        <p>We will review the site, confirm the likely audit scope and explain what type of SEO diagnosis would be most useful before any implementation work begins.</p>
        <div class="cta-actions">
          <ButtonPrimary href="/contact/" text="Request an SEO Audit Review" />
          <ButtonSecondary href="/seo-services-philippines/" text="See Our SEO Services" />
        </div>
      </div>
    </div>
  </section>

  <ContactSection />
  <Footer slot="footer" />
</MainLayout>

<style>
:root {
  --bf-bg: #0d0f1a;
  --bf-panel: #131627;
  --bf-panel-2: #181c30;
  --bf-text: #e8eaf2;
  --bf-muted: #b9bed4;
  --bf-orange: #f0622a;
  --bf-border: rgba(255, 255, 255, 0.1);
}

.audit-hero-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  margin-top: 1.5rem;
}

.stat {
  background: rgba(13, 15, 26, 0.74);
  border: 1px solid rgba(240, 98, 42, 0.24);
  border-radius: 18px;
  padding: 1rem;
}

.stat strong {
  display: block;
  color: var(--bf-orange);
  font-size: 1.35rem;
  margin-bottom: 0.35rem;
}

.stat span {
  color: #dfe3f3;
  font-size: 0.92rem;
  line-height: 1.45;
}

.intro-section,
.proof-section,
.triggers-section,
.coverage-section,
.tool-limits-section,
.priority-section,
.process-section,
.deliverables-section,
.avoid-section,
.internal-links-section,
.faq-section,
.cta-section,
:global(.contact-cta-section) {
  content-visibility: visible !important;
  background: var(--bf-bg);
  color: var(--bf-text);
}

.intro-section,
.coverage-section,
.priority-section,
.deliverables-section,
.faq-section {
  padding: 5.5rem 0;
  background: var(--bf-panel);
}

.proof-section,
.triggers-section,
.tool-limits-section,
.process-section,
.avoid-section,
.internal-links-section,
.cta-section {
  padding: 5.5rem 0;
  background: var(--bf-bg);
}

.intro-layout,
.triggers-layout,
.avoid-layout {
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
  gap: 3rem;
  align-items: start;
}

.eyebrow {
  display: inline-flex;
  color: var(--bf-orange);
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.11em;
  text-transform: uppercase;
  margin-bottom: 1rem;
}

h2 {
  color: #ffffff;
  font-size: clamp(2rem, 4vw, 3.35rem);
  line-height: 1.08;
  font-weight: 900;
  margin: 0 0 1.25rem;
}

h3 {
  color: #ffffff;
  font-weight: 800;
  margin: 0 0 0.75rem;
}

p {
  color: #dfe3f3;
  line-height: 1.75;
  font-size: 1rem;
}

.intro-copy p,
.triggers-copy p,
.avoid-copy p,
.cta-panel p {
  font-size: 1.08rem;
}

.diagnosis-panel,
.cta-panel {
  background: linear-gradient(135deg, rgba(240, 98, 42, 0.12), rgba(19, 22, 39, 0.95));
  border: 1px solid rgba(240, 98, 42, 0.26);
  border-radius: 28px;
  padding: 2rem;
  box-shadow: 0 28px 70px rgba(0, 0, 0, 0.24);
}

.diagnosis-panel ul,
.trigger-list {
  list-style: none;
  margin: 1.25rem 0 0;
  padding: 0;
}

.diagnosis-panel li,
.trigger-list li {
  position: relative;
  padding: 0.85rem 0 0.85rem 1.8rem;
  color: #eef1ff;
  line-height: 1.55;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.diagnosis-panel li::before,
.trigger-list li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 1.25rem;
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: var(--bf-orange);
  box-shadow: 0 0 0 5px rgba(240, 98, 42, 0.16);
}

.proof-grid,
.tool-grid,
.connected-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border-top: 1px solid var(--bf-border);
  border-bottom: 1px solid var(--bf-border);
}

.coverage-grid,
.deliverables-grid,
.avoid-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background: var(--bf-border);
