---
import MainLayout from '../layouts/MainLayout.astro';
import LegacyHeader from '../components/LegacyHeader.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';
import Hero from '../components/Hero.astro';
import ButtonPrimary from '../components/ButtonPrimary.astro';
import ButtonSecondary from '../components/ButtonSecondary.astro';
---

<MainLayout
  title="On-Page SEO Services In The Philippines - Bright Forge SEO"
  description="On-page SEO services in the Philippines for search intent, metadata, internal links, page structure, content depth and conversion-focused landing page improvements."
  faqs={[
    { question: "What is included in on-page SEO?", answer: "On-page SEO usually covers search intent, page titles, meta descriptions, headings, copy structure, internal links, image alt text, schema, content depth and conversion messaging. We treat the page as both a ranking asset and a sales asset." },
    { question: "Is on-page SEO just keyword placement?", answer: "No. Keyword placement matters, but modern on-page SEO is more about matching intent, answering the buyer's real questions, making the page easy to understand and giving search engines clear topic signals." },
    { question: "Can you improve existing pages instead of writing new ones?", answer: "Yes. Many campaigns need better money pages before they need more blog posts. We improve existing service pages, category pages, local pages and landing pages where there is already search demand or traffic potential." },
    { question: "How does on-page SEO help conversions?", answer: "Clearer page structure, better CTAs, stronger proof, sharper FAQs and stronger internal links help visitors understand the offer faster. That means SEO traffic has a better chance of becoming a lead." }
  ]}
>
  <LegacyHeader slot="header" />

  <!-- Hero Section -->
  <Hero
    badgeIcon="fas fa-edit"
    badgeText="On-Page SEO Specialists"
    title="On-Page SEO Services In The Philippines"
    breadcrumbCurrent="On-Page SEO Services Philippines"
  >
    <Fragment slot="story">
      <p>Search intent, page structure and conversion copy should work together. If a service page has the right keywords but vague copy, weak internal links or no clear next step, it can rank without producing enough enquiries.</p>
      <p>We improve the pages that need to earn money: titles, metadata, headings, FAQs, internal links, content depth, trust signals and calls to action. The aim is simple: make the page easier for Google to understand and easier for buyers to act on.</p>
    </Fragment>

    <Fragment slot="actions">
      <ButtonPrimary href="/contact/" text="Optimize Your Pages" />
      <ButtonSecondary href="#services" text="View Our Services" />
    </Fragment>

    <Fragment slot="visual">
      <div class="hero-image-container">
        <div class="onpage-icon-grid">
          <div class="onpage-icon"><i class="fas fa-heading"></i></div>
          <div class="onpage-icon"><i class="fas fa-align-left"></i></div>
          <div class="onpage-icon"><i class="fas fa-image"></i></div>
          <div class="onpage-icon"><i class="fas fa-link"></i></div>
          <div class="onpage-icon"><i class="fas fa-search"></i></div>
          <div class="onpage-icon"><i class="fas fa-chart-line"></i></div>
        </div>
      </div>
    </Fragment>
  </Hero>

  <!-- Core Services Section -->
  <section id="services" class="services-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="services-layout">
        <div class="services-content">
          <h2>Our On-Page SEO <span>Services</span></h2>

          <div class="service-list">
            <div class="service-item">
              <h3>Title & Meta Optimization</h3>
              <p>Search-led page titles, sharper meta descriptions and heading structures that match buyer intent while keeping the page readable and commercially useful.</p>
            </div>

            <div class="service-item">
              <h3>Content Enhancement</h3>
              <p>Better page copy, stronger answers, improved readability, useful supporting sections and content gaps mapped to what buyers actually search before they enquire.</p>
            </div>

            <div class="service-item">
              <h3>Media Optimization</h3>
              <p>Complete image alt text optimization, schema markup implementation, video SEO optimization, and strategic multimedia content planning.</p>
            </div>

            <div class="service-item">
              <h3>Internal Linking</h3>
              <p>Strategic link placement with optimized anchor text, content siloing, navigation enhancement, and smart link equity distribution across your site.</p>
            </div>
          </div>
        </div>

        <div class="services-visual">
          <div class="visual-card">
            <div class="visual-icon">
              <i class="fas fa-edit"></i>
            </div>
            <h3>Page Priorities</h3>
            <p class="visual-stat">Rank + convert</p>
            <p class="visual-label">Intent, copy, internal links, proof and CTAs working together</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Process Section -->
  <section class="process-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="process-header">
        <h2>Our On-Page SEO <span>Process</span></h2>
        <p>We improve the page around the searcher, the offer and the action you want them to take.</p>
      </div>

      <div class="process-grid">
        <div class="process-box orange-bg">
          <div class="process-box-icon">
            <i class="fas fa-search-plus"></i>
          </div>
          <h3>Page Analysis</h3>
          <p>We conduct a thorough analysis of your existing pages, identifying strengths, weaknesses, and opportunities for improvement.</p>
        </div>

        <div class="process-box white-bg">
          <div class="process-box-icon">
            <i class="fas fa-key"></i>
          </div>
          <h3>Keyword Research</h3>
          <p>Using advanced tools, we identify the most valuable keywords that your target audience is actively searching for.</p>
        </div>

        <div class="process-box orange-bg">
          <div class="process-box-icon">
            <i class="fas fa-lightbulb"></i>
          </div>
          <h3>Content Strategy</h3>
          <p>We develop a content strategy that aligns with search intent while maintaining your brand's unique voice and message.</p>
        </div>

        <div class="process-box white-bg">
          <div class="process-box-icon">
            <i class="fas fa-code"></i>
          </div>
          <h3>On-Page Implementation</h3>
          <p>Our team implements all necessary on-page optimizations, from meta tags to content structure and internal linking.</p>
        </div>

        <div class="process-box orange-bg">
          <div class="process-box-icon">
            <i class="fas fa-user-check"></i>
          </div>
          <h3>User Experience Enhancement</h3>
          <p>We optimize the user experience to increase engagement, reduce bounce rates, and improve conversion rates.</p>
        </div>

        <div class="process-box white-bg">
          <div class="process-box-icon">
            <i class="fas fa-chart-line"></i>
          </div>
          <h3>Performance Monitoring</h3>
          <p>We continuously monitor your pages' performance and make data-driven adjustments to improve rankings.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="benefits-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="benefits-header">
        <h2>The Impact of Professional <span>On-Page SEO</span></h2>
        <p>See how our on-page optimization services can transform your website's performance.</p>
      </div>

      <div class="benefits-layout">
        <div class="benefits-visual">
          <img
            src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&q=80"
            alt="Analytics and data showing on-page SEO improvements"
            class="benefits-image"
          />
        </div>

        <div class="benefits-grid">
          <div class="benefit-card">
            <div class="benefit-icon">
              <i class="fas fa-search"></i>
            </div>
            <h3>Higher Rankings</h3>
            <p>Well-optimized pages have a better chance of ranking higher in search results for your target keywords.</p>
          </div>

          <div class="benefit-card">
            <div class="benefit-icon">
              <i class="fas fa-users"></i>
            </div>
            <h3>More Targeted Traffic</h3>
            <p>Attract more qualified visitors who are actively searching for your products or services.</p>
          </div>

          <div class="benefit-card">
            <div class="benefit-icon">
              <i class="fas fa-chart-line"></i>
            </div>
            <h3>Better Conversion Rates</h3>
            <p>Optimized content and improved user experience lead to higher conversion rates and more sales.</p>
          </div>

          <div class="benefit-card">
            <div class="benefit-icon">
              <i class="fas fa-trophy"></i>
            </div>
            <h3>Competitive Edge</h3>
            <p>Stand out in the Philippine market with professionally optimized content that outperforms your competitors.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="commercial-proof-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="commercial-proof-layout">
        <div>
          <p class="eyebrow">What changes</p>
          <h2>On-page SEO questions businesses usually ask when traffic is not converting</h2>
          <p>We look at the page as a search result, a landing page and a sales conversation. If one of those jobs is weak, rankings alone will not do enough.</p>
        </div>
        <ul class="proof-list">
          <li><strong>Does the page match intent?</strong><span>The offer, headings and copy need to answer the searcher's real question.</span></li>
          <li><strong>Can Google understand the topic?</strong><span>Titles, headings, entities, schema and internal links should be clear.</span></li>
          <li><strong>Does the visitor trust it?</strong><span>Proof, examples, practical language and FAQs reduce hesitation.</span></li>
          <li><strong>Is there a clear next step?</strong><span>Better CTAs and page flow help organic traffic become leads.</span></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="faq-section-commercial">
    <div class="max-w-7xl mx-auto px-4">
      <h2>On-page SEO questions businesses usually ask</h2>
      <div class="faq-list-commercial">
        <article><h3>Is on-page SEO just keyword placement?</h3><p>No. Keywords matter, but the bigger job is matching intent, making the page useful and giving search engines clear signals about the service.</p></article>
        <article><h3>Can you improve existing pages?</h3><p>Yes. Improving money pages is often more valuable than publishing more blogs, especially when a page already has impressions or rankings.</p></article>
        <article><h3>How does on-page SEO help conversions?</h3><p>Clearer copy, stronger proof, better FAQs and stronger CTAs make it easier for visitors to understand the offer and enquire.</p></article>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <ContactSection />

  <Footer slot="footer" />
</MainLayout>

<style>
/* On-Page Icon Grid (used in Hero visual slot) */
.hero-image-container {
  position: relative;
  width: 100%;
  max-width: 500px;
}

.onpage-icon-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  padding: 2rem;
}

.onpage-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80px;
  height: 80px;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 20px;
  color: white;
  font-size: 2rem;
  transition: all 0.3s ease;
  animation: float 4s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-10px); }
}

.onpage-icon:nth-child(odd) {
  animation-delay: 1s;
}

.onpage-icon:nth-child(even) {
  animation-delay: 2s;
}

.onpage-icon:hover {
  transform: translateY(-5px) scale(1.05);
  background: rgba(255, 255, 255, 0.25);
  border-color: rgba(255, 255, 255, 0.4);
}

@media (max-width: 1024px) {
  .onpage-icon-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
}

@media (max-width: 768px) {
  .onpage-icon-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .onpage-icon {
    width: 60px;
    height: 60px;
    font-size: 1.5rem;
  }
}

/* Services Section */
.services-section {
  padding: 5rem 0;
  background: #131627;
}

.services-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: start;
}

.services-content h2 {
  font-size: 2.5rem;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 2.5rem;
  line-height: 1.2;
}

.services-content h2 span {
  background: linear-gradient(135deg, #f0622a, #d4510e);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.service-item {
  background: #0d0f1a;
  border-left: 4px solid #f0622a;
  padding: 1.5rem 2rem;
  border-radius: 8px;
  transition: all 0.3s ease;
}

.service-item:hover {
  background: #1a1e32;
  transform: translateX(5px);
}

.service-item h3 {
  font-size: 1.125rem;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 0.5rem;
}

.service-item p {
  font-size: 0.95rem;
  color: #ffffff;
  line-height: 1.6;
  margin: 0;
}

.services-visual {
  position: sticky;
  top: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 400px;
}

.visual-card {
  background: linear-gradient(135deg, rgba(240, 98, 42, 0.05), rgba(255, 107, 53, 0.05));
  border-radius: 20px;
  padding: 3rem 2rem;
  text-align: center;
  border: 1px solid rgba(240, 98, 42, 0.2);
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.visual-icon {
  width: 80px;
  height: 80px;
  background: linear-gradient(135deg, #f0622a, #d4510e);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 1.5rem;
  color: white;
  font-size: 2rem;
}

.visual-card h3 {
  font-size: 1.25rem;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 1.5rem;
}

.visual-stat {
  font-size: 4rem;
  font-weight: 900;
  background: linear-gradient(135deg, #f0622a, #d4510e);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin: 1rem 0 0.5rem;
  line-height: 1;
}

.visual-label {
  color: #ffffff;
  font-size: 1rem;
  font-weight: 600;
  margin: 0;
}

@media (max-width: 1024px) {
  .services-layout {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .services-visual {
    position: static;
  }
}

/* Process Section */
.process-section {
  padding: 5rem 0;
  background: #0d0f1a;
}

.process-header {
  text-align: center;
  margin-bottom: 3rem;
}

.process-header h2 {
  font-size: 2.5rem;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 1rem;
  line-height: 1.2;
}

.process-header h2 span {
  background: linear-gradient(135deg, #f0622a, #d4510e);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.process-header p {
  color: #ffffff;
  font-size: 1.1rem;
  max-width: 800px;
  margin: 0 auto;
  line-height: 1.6;
}

.process-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
}

.process-box {
  padding: 3rem 2rem;
  text-align: center;
  transition: all 0.3s ease;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.process-box:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  z-index: 10;
}

.process-box.orange-bg {
  background: linear-gradient(135deg, #f0622a, #d4510e);
}

.process-box.orange-bg h3,
.process-box.orange-bg p {
  color: white;
}

.process-box.white-bg {
  background: #131627;
}

.process-box.white-bg h3 {
  color: #ffffff;
}

.process-box.white-bg p {
  color: #ffffff;
}

.process-box-icon {
  width: 80px;
  height: 80px;
  margin: 0 auto 1.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.5rem;
  transition: all 0.3s ease;
}

.process-box.orange-bg .process-box-icon {
  color: white;
}

.process-box.white-bg .process-box-icon {
  background: linear-gradient(135deg, #f0622a, #d4510e);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.process-box:hover .process-box-icon {
  transform: scale(1.1);
}

.process-box h3 {
  font-size: 1.25rem;
  font-weight: 700;
  margin-bottom: 1rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.process-box p {
  font-size: 0.95rem;
  line-height: 1.6;
  margin: 0;
}

@media (max-width: 1024px) {
  .process-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .process-grid {
    grid-template-columns: 1fr;
  }
}

/* Benefits Section */
.benefits-section {
  padding: 5rem 0;
  background: #131627;
}

.benefits-header {
  text-align: center;
  margin-bottom: 3rem;
}

.benefits-header h2 {
  font-size: 2.5rem;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 1rem;
  line-height: 1.2;
}

.benefits-header h2 span {
  background: linear-gradient(135deg, #f0622a, #d4510e);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.benefits-header p {
  color: #ffffff;
  font-size: 1.1rem;
  max-width: 700px;
  margin: 0 auto;
}

.benefits-layout {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 4rem;
  align-items: center;
}

.benefits-visual {
  display: flex;
  align-items: center;
  justify-content: center;
}

.benefits-image {
  width: 100%;
  max-width: 400px;
  height: 500px;
  object-fit: cover;
  border-radius: 20px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.15);
}

.benefits-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2rem;
}

.benefit-card {
  background: #131627;
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 12px;
  padding: 2rem 1.5rem;
  text-align: center;
  transition: all 0.3s ease;
}

.benefit-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
}

.benefit-icon {
  width: 70px;
  height: 70px;
  background: linear-gradient(135deg, #f0622a, #d4510e);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 1.25rem;
  color: white;
  font-size: 1.75rem;
}

.benefit-card h3 {
  font-size: 1.25rem;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 0.75rem;
}

.benefit-card p {
  color: #ffffff;
  line-height: 1.6;
  font-size: 0.95rem;
}

@media (max-width: 1024px) {
  .benefits-layout {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .benefits-image {
    height: 400px;
    max-width: 100%;
  }
}

@media (max-width: 768px) {
  .benefits-grid {
    grid-template-columns: 1fr;
  }
}

.commercial-proof-section {
  padding: 5rem 0;
  background: #0d0f1a;
}

.commercial-proof-layout {
  display: grid;
  grid-template-columns: 0.95fr 1.05fr;
  gap: 3rem;
  align-items: start;
  background: #131627;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 2rem;
  padding: 3rem;
}

.eyebrow {
  color: #f0622a;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 1rem;
}

.commercial-proof-layout h2,
.faq-section-commercial h2 {
  color: white;
  font-size: clamp(2rem, 4vw, 3rem);
  line-height: 1.08;
  margin-bottom: 1.5rem;
}

.commercial-proof-layout p {
  color: #d4d8e6;
  font-size: 1.08rem;
  line-height: 1.7;
}

.proof-list {
  list-style: none;
  display: grid;
  gap: 1rem;
  margin: 0;
  padding: 0;
}

.proof-list li {
  display: grid;
  gap: 0.35rem;
  padding: 1.2rem 0 1.2rem 1.2rem;
  border-left: 3px solid #f0622a;
  background: rgba(255, 255, 255, 0.035);
  border-radius: 0 1rem 1rem 0;
}

.proof-list strong {
  color: white;
  font-size: 1.05rem;
}

.proof-list span {
  color: #c9cedd;
  line-height: 1.55;
}

.faq-section-commercial {
  padding: 5rem 0;
  background: #111421;
}

.faq-list-commercial {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.faq-list-commercial article {
  background: #171b2d;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 1.4rem;
  padding: 1.5rem;
}

.faq-list-commercial h3 {
  color: white;
  font-size: 1.15rem;
  margin-bottom: 0.8rem;
}

.faq-list-commercial p {
  color: #c9cedd;
  line-height: 1.6;
}

@media (max-width: 900px) {
  .commercial-proof-layout,
  .faq-list-commercial {
    grid-template-columns: 1fr;
  }
}

</style>
