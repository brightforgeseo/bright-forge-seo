---
import MainLayout from '../layouts/MainLayout.astro';
import LegacyHeader from '../components/LegacyHeader.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';
import Hero from '../components/Hero.astro';
import ButtonPrimary from '../components/ButtonPrimary.astro';
import ButtonSecondary from '../components/ButtonSecondary.astro';

const aiSearchFaqs = [
  {
    question: 'Is AI search optimisation different from SEO?',
    answer: 'AI search optimisation is not a replacement for SEO. It is an extra layer that makes your technical setup, content, proof, reviews and service pages easier for Google, AI Overviews and answer-led systems to understand, verify and cite.'
  },
  {
    question: 'Can you guarantee that our business appears in ChatGPT or Google AI Overviews?',
    answer: 'No agency can guarantee inclusion in AI answers or Google AI Overviews. We improve the signals that make a business easier to understand, trust and cite: crawlability, entity clarity, structured content, useful answers, reviews, authority and strong service pages.'
  },
  {
    question: 'What makes a page more likely to be cited in AI search?',
    answer: 'Clear answers, accurate entities, visible proof, consistent business information, useful service detail, structured headings, strong internal links, relevant schema, reviews and external authority all help. Thin pages, vague claims and unclear service positioning make citation less likely.'
  },
  {
    question: 'Do we need new content or can existing pages be improved?',
    answer: 'Most campaigns start by improving existing priority pages. We tighten service copy, add direct answers, strengthen proof, clean up schema, improve internal links and fix technical issues. New content is added when the site has unanswered buyer questions or missing topical coverage.'
  },
  {
    question: 'How do you measure AI search visibility?',
    answer: 'We measure traditional SEO signals first, including rankings, impressions, clicks, landing pages and conversions. We can also monitor whether the brand, competitors and priority pages appear in answer-led SERPs, Google AI Overviews and AI-assisted research results where tracking is practical.'
  },
  {
    question: 'Is AI SEO useful for Philippine businesses?',
    answer: 'Yes, especially for service businesses, ecommerce brands, B2B companies and local firms where buyers compare options before enquiring. The Philippine search market is still early for AI SEO, which makes this a positioning opportunity rather than a saturated channel.'
  }
];
---

<MainLayout
  title="AI SEO Services Philippines | Bright Forge SEO"
  description="Improve visibility across Google, AI Overviews, ChatGPT and answer-led search with SEO-first AI search optimisation for Philippine businesses."
  canonical="https://brightforge.com.ph/ai-search-optimization-services-philippines/"
  type="service"
  faqs={aiSearchFaqs}
>
  <LegacyHeader slot="header" />

  <Hero
    badgeIcon="fas fa-brain"
    badgeText="SEO-First AI Search Optimisation"
    title="AI SEO Services for Philippine Businesses"
    breadcrumbCurrent="AI SEO Services Philippines"
  >
    <Fragment slot="story">
      <p>SEO-first optimisation for Google AI Overviews, answer-led search, featured snippets and AI-assisted discovery.</p>

      <p>AI search is not a magic replacement for SEO. It rewards the same things serious SEO has always worked toward: technically accessible pages, clear entities, useful answers, strong proof, real authority and content that helps buyers make decisions.</p>

      <p>We help Philippine businesses make their priority pages easier for Google, AI Overviews, ChatGPT-style answers, Perplexity-style citations and direct-answer search experiences to understand, verify and cite.</p>

      <p>That means we do not chase acronyms for the sake of it. We strengthen the search foundations that make your business clearer, more trusted and more likely to be chosen.</p>
    </Fragment>

    <Fragment slot="actions">
      <ButtonPrimary href="/contact/" text="Request an AI Search Visibility Audit" />
      <ButtonSecondary href="#ai-search-audit" text="See What We Check" />
    </Fragment>

    <Fragment slot="visual">
      <div class="ai-hero-system" aria-label="AI search visibility system diagram">
        <div class="signal-card google-card">
          <span>Google</span>
          <strong>AI Overviews</strong>
        </div>
        <div class="signal-card answer-card">
          <span>Answer Engines</span>
          <strong>Direct Answers</strong>
        </div>
        <div class="core-orb">
          <i class="fas fa-search"></i>
          <strong>SEO</strong>
          <span>Foundation</span>
        </div>
        <div class="signal-card proof-card">
          <span>Proof</span>
          <strong>Reviews + Authority</strong>
        </div>
        <div class="signal-card content-card">
          <span>Content</span>
          <strong>Clear Service Pages</strong>
        </div>
      </div>
    </Fragment>
  </Hero>

  <section class="proof-strip" aria-label="AI SEO service proof points">
    <div class="max-w-7xl mx-auto px-4">
      <div class="proof-grid">
        <div>
          <strong>SEO-first</strong>
          <span>No “SEO is dead” nonsense</span>
        </div>
        <div>
          <strong>Answer-ready</strong>
          <span>Built for snippets, AI Overviews and direct answers</span>
        </div>
        <div>
          <strong>Evidence-led</strong>
          <span>Technical SEO, content, reviews and authority together</span>
        </div>
        <div>
          <strong>Commercial</strong>
          <span>Focused on enquiries, not vanity AI mentions</span>
        </div>
      </div>
    </div>
  </section>

  <section class="dark-section" id="why-ai-search">
    <div class="max-w-7xl mx-auto px-4">
      <div class="section-header left-header">
        <div class="section-badge">The Shift</div>
        <h2>Why AI Search Visibility Starts With <span>Strong SEO</span></h2>
        <p>Search is becoming more answer-led. Buyers still use Google, but they also see AI summaries, featured snippets, People Also Ask, review-led SERPs and AI-assisted research before they contact a business.</p>
      </div>

      <div class="split-layout">
        <div class="copy-block">
          <p>When someone asks which company to trust, which service provider to compare, or what solution fits their situation, search systems need clear source material. If your pages are vague, thin or technically messy, they are harder to include.</p>

          <p>AI search optimisation makes your best pages easier to interpret. It clarifies who you are, what you do, where you serve, why you are credible and what answer your page provides.</p>

          <p><strong>The goal is not to manipulate AI systems. The goal is to remove ambiguity.</strong></p>
        </div>

        <div class="issue-panel">
          <h3>Common gaps we find</h3>
          <ul>
            <li>Services described in agency language instead of buyer language</li>
            <li>Pages with claims but no evidence, reviews or examples</li>
            <li>Weak internal links between services, content and proof assets</li>
            <li>Schema that exists but does not clarify the page properly</li>
            <li>Content that answers definitions but avoids buying questions</li>
            <li>Competitors being cited where your site is absent or unclear</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="audit-section" id="ai-search-audit">
    <div class="max-w-7xl mx-auto px-4">
      <div class="section-header">
        <div class="section-badge">Diagnostic Layer</div>
        <h2>What We Check in an <span>AI Search Audit</span></h2>
        <p>Before rewriting pages or adding schema, we check whether your business is clear enough to be understood, trusted and cited.</p>
      </div>

      <div class="audit-grid">
        <div class="audit-card">
          <i class="fas fa-sitemap"></i>
          <h3>Entity clarity</h3>
          <p>We check whether Google can clearly connect your brand, services, locations, people, reviews, social profiles and source pages.</p>
        </div>
        <div class="audit-card">
          <i class="fas fa-file-alt"></i>
          <h3>Answer readiness</h3>
          <p>We identify whether priority pages answer direct buyer questions in a format that works for humans, snippets and answer-led search.</p>
        </div>
        <div class="audit-card">
          <i class="fas fa-code"></i>
          <h3>Technical access</h3>
          <p>We review crawlability, indexation, rendering, canonical signals, schema, internal links and page structure for interpretation issues.</p>
        </div>
        <div class="audit-card">
          <i class="fas fa-medal"></i>
          <h3>Proof and trust</h3>
          <p>We check whether reviews, case studies, credentials, examples and commercial proof are visible enough to support recommendations.</p>
        </div>
        <div class="audit-card">
          <i class="fas fa-users"></i>
          <h3>Competitor citations</h3>
          <p>We look at where competitors appear in AI-influenced SERPs, snippets, review blocks and answer results so we can close the gap.</p>
        </div>
        <div class="audit-card">
          <i class="fas fa-chart-line"></i>
          <h3>Commercial impact</h3>
          <p>We connect AI search work to rankings, impressions, clicks, qualified enquiries and the service pages most likely to generate revenue.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="method-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="section-header left-header">
        <div class="section-badge">Method</div>
        <h2>How We Make Pages Easier to <span>Understand, Trust and Cite</span></h2>
        <p>We improve AI search visibility by fixing the same practical issues that hold back organic performance.</p>
      </div>

      <div class="method-list">
        <div class="method-item">
          <span>01</span>
          <div>
            <h3>Clarify the service offer</h3>
            <p>We rewrite vague service copy into clear buyer language: who the service is for, what problem it solves, what work is included and when it makes sense.</p>
          </div>
        </div>
        <div class="method-item">
          <span>02</span>
          <div>
            <h3>Build answer-ready sections</h3>
            <p>We add concise summaries, comparison blocks, FAQs, process explanations and decision-support content that can answer specific queries directly.</p>
          </div>
        </div>
        <div class="method-item">
          <span>03</span>
          <div>
            <h3>Strengthen technical and structured signals</h3>
            <p>We clean up crawlability, schema, headings, internal links, canonical signals and content structure so search systems can interpret the page accurately.</p>
          </div>
        </div>
        <div class="method-item">
          <span>04</span>
          <div>
            <h3>Connect proof to priority pages</h3>
            <p>We surface reviews, examples, case studies, locations, team expertise and trust signals where buyers and search systems need them.</p>
          </div>
        </div>
        <div class="method-item">
          <span>05</span>
          <div>
            <h3>Monitor visibility and refine</h3>
            <p>We track traditional SEO performance first, then layer in AI-influenced visibility checks where they can produce useful business intelligence.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="platform-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="section-header">
        <div class="section-badge">Where It Applies</div>
        <h2>AI Search Optimisation Is Bigger Than <span>One Platform</span></h2>
        <p>We focus on the search surfaces that influence discovery, research and enquiries.</p>
      </div>

      <div class="platform-grid">
        <div class="platform-card">
          <h3>Google AI Overviews</h3>
          <p>Improve the clarity, usefulness and authority of pages that may support AI-assisted summaries and answer-led SERPs.</p>
        </div>
        <div class="platform-card">
          <h3>Featured snippets and PAA</h3>
          <p>Structure content around direct answers, definitions, comparisons and useful next steps for high-intent queries.</p>
        </div>
        <div class="platform-card">
          <h3>ChatGPT-style research</h3>
          <p>Make the business easier to describe accurately through clearer service positioning, proof, entity consistency and crawlable source pages.</p>
        </div>
        <div class="platform-card">
          <h3>Perplexity-style citations</h3>
          <p>Improve the quality of source pages that can support cited answers, competitor comparisons and commercial research queries.</p>
        </div>
        <div class="platform-card">
          <h3>Local and review-led discovery</h3>
          <p>Connect local SEO, reviews, service areas and proof so answer-led discovery has stronger trust signals to work with.</p>
        </div>
        <div class="platform-card">
          <h3>Voice and mobile answers</h3>
          <p>Support concise, useful answers for searches where users want a recommendation, direction, explanation or immediate next step.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="fit-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="fit-card">
        <div>
          <div class="section-badge">Best Fit</div>
          <h2>Who This Service Is For</h2>
          <p>AI SEO is most useful when a business already needs organic visibility, trust and better service-page conversion. It is not a shortcut around weak SEO. It is a way to make good SEO clearer and more resilient.</p>
        </div>
        <div class="fit-list">
          <ul>
            <li>Service businesses competing on expertise and trust</li>
            <li>Local companies that need stronger discovery in Google and AI-assisted results</li>
            <li>B2B firms where buyers research before enquiring</li>
            <li>Ecommerce brands with complex products or comparison journeys</li>
            <li>Businesses with good services but vague, underpowered website content</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="investment-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="section-header">
        <div class="section-badge">Investment</div>
        <h2>AI Search Optimisation <span>Retainers</span></h2>
        <p>Pricing depends on the strength of your existing SEO foundation, the number of priority services, technical requirements and monitoring scope.</p>
      </div>

      <div class="investment-grid">
        <div class="investment-card">
          <i class="fas fa-search-dollar"></i>
          <h3>Starting investment</h3>
          <p>AI search optimisation retainers start from <strong>$480 USD per month</strong> for focused audit, implementation and monitoring work.</p>
        </div>
        <div class="investment-card">
          <i class="fas fa-calendar-check"></i>
          <h3>Minimum term</h3>
          <p>We recommend a <strong>six-month commitment</strong> because technical, content, authority and visibility improvements need time to compound.</p>
        </div>
        <div class="investment-card">
          <i class="fas fa-clipboard-list"></i>
          <h3>What is included</h3>
          <p>Audit work, technical recommendations, content optimisation, answer-ready page improvements, competitor checks and practical reporting.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="timeline-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="section-header">
        <div class="section-badge">Timeline</div>
        <h2>What You Can <span>Expect</span></h2>
        <p>AI search work should be measured alongside traditional SEO performance. The early wins usually come from cleaner structure, better answers and stronger priority pages.</p>
      </div>

      <div class="timeline-grid">
        <div class="timeline-card">
          <span>1 to 3 months</span>
          <h3>Foundation</h3>
          <p>Audit, technical fixes, schema cleanup, priority page improvements and baseline visibility checks.</p>
        </div>
        <div class="timeline-card">
          <span>3 to 6 months</span>
          <h3>Expansion</h3>
          <p>More answer-ready content, stronger internal links, better proof placement and refined service-page targeting.</p>
        </div>
        <div class="timeline-card">
          <span>6 to 12 months</span>
          <h3>Authority</h3>
          <p>Compounding topical authority, stronger citation potential and a clearer footprint across organic and answer-led discovery.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="difference-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="section-header left-header">
        <div class="section-badge">The Difference</div>
        <h2>Why Bright Forge Approaches AI Search <span>Differently</span></h2>
        <p>We treat AI search as an SEO operating layer, not a new buzzword product bolted onto weak fundamentals.</p>
      </div>

      <div class="difference-grid">
        <div>
          <h3>We do not sell AI magic</h3>
          <p>No one can force Google AI Overviews or ChatGPT to recommend a business. We improve the evidence and structure that make inclusion more plausible.</p>
        </div>
        <div>
          <h3>We keep conversion in the frame</h3>
          <p>Visibility is only useful if the page can turn attention into enquiries. AI SEO still needs persuasive service copy, trust signals and strong calls to action.</p>
        </div>
        <div>
          <h3>We use senior SEO judgement</h3>
          <p>With more than 15 years of SEO experience behind the process, we separate useful AI-search changes from fashionable busywork.</p>
        </div>
        <div>
          <h3>We understand the Philippine market</h3>
          <p>The category is still early locally. That gives serious businesses a chance to build clarity and authority before the SERPs get noisier.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="section-header">
        <div class="section-badge">FAQ</div>
        <h2>AI Search Optimisation <span>FAQs</span></h2>
      </div>

      <div class="faq-list">
        {aiSearchFaqs.map((faq) => (
          <details class="faq-item">
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="max-w-7xl mx-auto px-4">
      <div class="cta-container">
        <div class="section-badge">Next Step</div>
        <h2>Request an AI Search Visibility Audit</h2>
        <p>We will review how clearly your business, services, proof and priority pages are understood across Google, AI-assisted results and answer-led search.</p>
        <a href="/contact/" class="cta-button">Request Your Audit</a>
      </div>
    </div>
  </section>

  <ContactSection />

  <Footer slot="footer" />
</MainLayout>

<style>
:root {
  --bf-bg: #0d0f1a;
  --bf-panel: #131627;
  --bf-panel-2: #1a1e32;
  --bf-orange: #f0622a;
  --bf-orange-dark: #d4510e;
  --bf-text: #ffffff;
  --bf-muted: #d0d4e8;
  --bf-border: rgba(255, 255, 255, 0.08);
}

.ai-hero-system {
  position: relative;
  min-height: 460px;
  width: min(520px, 100%);
  margin: 0 auto;
}

.core-orb {
  position: absolute;
  inset: 50% auto auto 50%;
  transform: translate(-50%, -50%);
  width: 190px;
  height: 190px;
  border-radius: 999px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  background: radial-gradient(circle at 30% 25%, rgba(255,255,255,0.22), rgba(240,98,42,0.96));
  border: 1px solid rgba(255,255,255,0.28);
  box-shadow: 0 24px 80px rgba(240, 98, 42, 0.34);
  color: white;
  text-align: center;
}

.core-orb i {
  font-size: 2.2rem;
}

.core-orb strong {
  font-size: 2.2rem;
  line-height: 1;
}

.core-orb span {
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
}

.signal-card {
  position: absolute;
  width: 190px;
  padding: 18px;
  border-radius: 18px;
  background: rgba(19, 22, 39, 0.86);
  border: 1px solid rgba(255,255,255,0.16);
  color: white;
  backdrop-filter: blur(18px);
  box-shadow: 0 18px 50px rgba(0,0,0,0.25);
}

.signal-card span {
  display: block;
  color: var(--bf-orange);
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 5px;
}

.signal-card strong {
  display: block;
  font-size: 1rem;
  line-height: 1.25;
}

.google-card { top: 20px; left: 30px; }
.answer-card { top: 75px; right: 0; }
.proof-card { bottom: 72px; left: 0; }
.content-card { bottom: 20px; right: 35px; }

.proof-strip {
  background: #090b13;
  padding: 28px 0;
  border-top: 1px solid var(--bf-border);
  border-bottom: 1px solid var(--bf-border);
}

.proof-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  border-top: 1px solid var(--bf-border);
  border-bottom: 1px solid var(--bf-border);
}

.proof-grid div {
  padding: 20px 24px;
  border: 0;
  border-right: 1px solid var(--bf-border);
  border-radius: 0;
  background: transparent;
}

.proof-grid div:first-child {
  padding-left: 0;
}

.proof-grid div:last-child {
  border-right: 0;
  padding-right: 0;
}

.proof-grid strong,
.proof-grid span {
  display: block;
}

.proof-grid strong {
  color: var(--bf-orange);
  font-size: 1.05rem;
  margin-bottom: 4px;
}

.proof-grid span {
  color: var(--bf-muted);
  font-size: 0.95rem;
  line-height: 1.45;
}

.dark-section,
.audit-section,
.platform-section,
.timeline-section,
.faq-section {
  padding: 86px 0;
  background: var(--bf-bg);
}

.method-section,
.fit-section,
.investment-section,
.difference-section,
.cta-section {
  padding: 86px 0;
  background: var(--bf-panel);
}

.section-header {
  text-align: center;
  max-width: 850px;
  margin: 0 auto 48px;
}

.left-header {
  text-align: left;
  margin-left: 0;
}

.section-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  background: linear-gradient(135deg, rgba(240, 98, 42, 0.14), rgba(240, 98, 42, 0.05));
  border: 1px solid rgba(240, 98, 42, 0.22);
  color: var(--bf-orange);
  border-radius: 100px;
  font-size: 12px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 1rem;
}

.section-header h2,
.fit-card h2,
.cta-container h2 {
  color: white;
  font-size: clamp(2rem, 4vw, 3rem);
  line-height: 1.12;
  font-weight: 800;
  margin: 0 0 18px;
}

.section-header h2 span {
  color: var(--bf-orange);
}

.section-header p,
.copy-block p,
.fit-card p,
.cta-container p {
  color: var(--bf-muted);
  font-size: 1.08rem;
  line-height: 1.7;
}

.split-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 42px;
  align-items: start;
}

.copy-block {
  padding: 34px;
  border-radius: 22px;
  background: var(--bf-panel);
  border: 1px solid var(--bf-border);
}

.copy-block strong {
  color: white;
}

.issue-panel,
.fit-card,
.cta-container {
  padding: 38px;
  border-radius: 24px;
  background: linear-gradient(135deg, rgba(240, 98, 42, 0.11), rgba(255,255,255,0.03));
  border: 1px solid rgba(240, 98, 42, 0.22);
}

.issue-panel h3,
.fit-list h3 {
  color: white;
  font-size: 1.5rem;
  margin-bottom: 18px;
}

.issue-panel ul,
.fit-list ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.issue-panel li,
.fit-list li {
  position: relative;
  color: var(--bf-muted);
  padding: 0 0 14px 28px;
  line-height: 1.55;
}

.issue-panel li::before,
.fit-list li::before {
  content: '✓';
  position: absolute;
  left: 0;
  top: 0;
  color: var(--bf-orange);
  font-weight: 800;
}

.audit-grid,
.platform-grid,
.investment-grid,
.difference-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--bf-border);
  border: 1px solid var(--bf-border);
}

.audit-grid,
.platform-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.difference-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.audit-card,
.platform-card,
.investment-card,
.difference-grid > div,
.faq-item,
.timeline-card {
  background: var(--bf-panel);
  border: 0;
  border-radius: 0;
  padding: 28px;
  color: white;
  transition: none;
}

.audit-card:hover,
.platform-card:hover,
.investment-card:hover,
.difference-grid > div:hover,
.timeline-card:hover {
  transform: none;
  border-color: transparent;
