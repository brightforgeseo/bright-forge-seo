---
import MainLayout from '../layouts/MainLayout.astro';
import LegacyHeader from '../components/LegacyHeader.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';
import Hero from '../components/Hero.astro';
import ButtonPrimary from '../components/ButtonPrimary.astro';
import ButtonSecondary from '../components/ButtonSecondary.astro';

const proofItems = [
  {
    title: 'Search demand mapped to pages',
    copy: 'We do not stop at keyword lists. We decide which terms belong on service pages, category pages, local pages, articles, FAQs and supporting assets.'
  },
  {
    title: 'Priorities, not noise',
    copy: 'Every recommendation is filtered by intent, realistic ranking potential, commercial value, existing visibility and the work needed to win the query.'
  },
  {
    title: 'A roadmap your team can use',
    copy: 'You get clear page targets, content actions, internal-link opportunities and implementation notes, not a raw export from a keyword tool.'
  }
];

const researchDeliverables = [
  {
    title: 'Keyword opportunity set',
    copy: 'A cleaned and grouped keyword set with search intent, commercial relevance, difficulty signals, volume context and priority notes.'
  },
  {
    title: 'Page mapping',
    copy: 'Primary and secondary terms mapped to existing URLs or recommended new pages, with clear action labels such as create, rewrite, merge, expand or monitor.'
  },
  {
    title: 'Competitor keyword gaps',
    copy: 'Competitor terms reviewed for business fit, not blindly copied. We separate genuine opportunities from brand noise, weak-fit queries and vanity rankings.'
  },
  {
    title: 'Search intent and SERP notes',
    copy: 'SERP checks that identify whether Google wants a service page, collection page, guide, comparison, local result, video, FAQ or another page type.'
  },
  {
    title: 'Quick-win targets',
    copy: 'Queries where existing pages already have enough relevance or impressions to justify focused on-page, content or internal-link improvements.'
  },
  {
    title: 'Content and page roadmap',
    copy: 'A practical roadmap showing which pages should be built or improved first, how they connect and what each page is meant to achieve.'
  }
];

const mappingFields = [
  'Primary keyword and close variants',
  'Search intent and buyer stage',
  'Existing URL or new page recommendation',
  'Recommended page type',
  'Priority level and reason',
  'Content action required',
  'Supporting FAQ or article ideas',
  'Internal-link opportunities',
  'Competitor or SERP notes',
  'Measurement notes for rankings, impressions and enquiries'
];

const siteTypes = [
  {
    title: 'Service businesses',
    copy: 'We map core services, location modifiers, comparison queries, pricing questions, problem-led searches and supporting articles around the pages most likely to generate enquiries.'
  },
  {
    title: 'Ecommerce and catalogue sites',
    copy: 'We separate category, subcategory, product, buying-guide and comparison intent so the site is not trying to rank the wrong type of page.'
  },
  {
    title: 'Local SEO campaigns',
    copy: 'We identify service-area, suburb, city, Google Business Profile, review and local-intent opportunities without creating doorway-style location pages.'
  },
  {
    title: 'Agencies and white-label teams',
    copy: 'We build keyword maps that give content teams, developers and account managers a clear brief without exposing clients to messy research exports.'
  }
];

const avoidItems = [
  {
    title: 'No raw keyword dumps',
    copy: 'A long spreadsheet is not a strategy. We remove duplicates, irrelevant variants, weak-fit topics and terms that do not justify a page or content action.'
  },
  {
    title: 'No volume chasing',
    copy: 'High-volume keywords are not always the best target. We prioritise intent, business fit, SERP reality and the page type needed to compete.'
  },
  {
    title: 'No competitor copying',
    copy: 'A competitor ranking for a keyword does not automatically make it a good opportunity. We check relevance, buyer fit and whether the client can actually serve that search.'
  },
  {
    title: 'No cannibalisation traps',
    copy: 'We avoid recommending multiple pages for the same intent unless there is a clear reason. Strong mapping protects the site from competing with itself.'
  }
];

const processSteps = [
  {
    label: '01',
    title: 'Business and site context',
    copy: 'We review the offer, ideal customers, priority services, locations, margins, current pages, conversion goals and any existing Search Console or ranking data.'
  },
  {
    label: '02',
    title: 'Keyword discovery and cleanup',
    copy: 'We collect candidate terms from multiple sources, then remove noise, duplicates, impossible terms and anything that does not fit the business.'
  },
  {
    label: '03',
    title: 'SERP and intent validation',
    copy: 'We check what Google is actually rewarding so the recommendation matches the right page type, format, depth and searcher expectation.'
  },
  {
    label: '04',
    title: 'Page mapping and prioritisation',
    copy: 'We group terms into page targets, flag existing-page opportunities, identify missing pages and order the work by likely commercial impact.'
  },
  {
    label: '05',
    title: 'Roadmap and handoff',
    copy: 'You receive a usable keyword map with actions, priorities, page notes and next steps for content, on-page SEO, internal links and tracking.'
  }
];

const connectedServices = [
  {
    title: 'SEO services Philippines',
    href: '/seo-services-philippines/',
    copy: 'For the wider campaign that turns research into technical fixes, page improvements, content, links and reporting.'
  },
  {
    title: 'SEO content writing services',
    href: '/content-seo-services-philippines/',
    copy: 'For writing or rewriting the pages, articles and FAQs identified in the keyword map.'
  },
  {
    title: 'On-page SEO services',
    href: '/on-page-seo-services-philippines/',
    copy: 'For improving mapped pages with stronger metadata, structure, copy, internal links, proof and CTAs.'
  },
  {
    title: 'SEO audit services',
    href: '/seo-audit-services/',
    copy: 'For diagnosing why existing pages are not ranking, converting or supporting the wider SEO campaign properly.'
  },
  {
    title: 'Technical SEO services',
    href: '/technical-seo-services-philippines/',
    copy: 'For crawl, indexation, rendering, schema and architecture issues that affect whether keyword targets can perform.'
  },
  {
    title: 'Local SEO services',
    href: '/local-seo-services-philippines/',
    copy: 'For mapping service, location and Google Maps intent into local landing pages, GBP work and citation strategy.'
  }
];

const faqs = [
  { question: 'What is included in keyword research services?', answer: 'Keyword research should include more than a keyword list. We usually include keyword discovery, search intent checks, competitor gap review, page mapping, priority scoring, existing-page opportunities, new-page recommendations, FAQ ideas and a practical SEO roadmap.' },
  { question: 'How is this different from exporting keywords from Ahrefs or SEMrush?', answer: 'Tool exports show possible terms. Strategy decides which terms matter, which page should target them, whether the site can realistically compete and what work is needed. We filter the data into decisions your team can actually use.' },
  { question: 'Do you map keywords to existing pages?', answer: 'Yes. We review existing URLs and decide whether each priority keyword should be mapped to a current page, a rewritten page, a merged page or a new page. This helps avoid duplication and keyword cannibalisation.' },
  { question: 'Can you find competitor keyword gaps?', answer: 'Yes. We compare relevant competitors, then filter the gaps for business fit. We do not recommend a keyword just because a competitor ranks for it. It has to match the offer, market, page type and commercial opportunity.' },
  { question: 'How do you prioritise keywords?', answer: 'We look at search intent, volume context, keyword difficulty signals, current rankings, Search Console visibility, commercial value, page fit, competitor strength and the amount of work needed to compete.' },
  { question: 'Do you include a content plan?', answer: 'Yes, when content is the right action. Some keywords need new articles, but others need stronger service pages, category pages, location pages, FAQs or internal links. We separate those actions clearly.' },
  { question: 'Can our content team use the keyword map directly?', answer: 'Yes. The keyword map is built for implementation. It gives page targets, priority terms, intent notes, page actions and supporting topics so writers, SEOs and developers know what to do next.' },
  { question: 'Do you help implement the keyword research?', answer: 'Yes. Keyword research can feed into our SEO services, content SEO, on-page SEO, local SEO and technical SEO work. We can also hand the roadmap to your internal team if you only need the research.' }
];
---

<MainLayout
  title="Keyword Research Services Philippines | SEO Keyword Mapping"
  description="Keyword research services in the Philippines for SEO keyword mapping, content planning, competitor gaps and practical page-by-page search strategy."
  keywords="keyword research services Philippines, SEO keyword research services, keyword mapping services, keyword analysis services, SEO content planning"
  faqs={faqs}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://brightforge.com.ph/'
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Keyword Research Services Philippines',
          item: 'https://brightforge.com.ph/keyword-research-services/'
        }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: 'Keyword Research Services Philippines',
      url: 'https://brightforge.com.ph/keyword-research-services/',
      description: 'Keyword research services in the Philippines for SEO keyword mapping, content planning, competitor gaps and practical page-by-page search strategy.',
      isPartOf: {
        '@type': 'WebSite',
        name: 'Bright Forge SEO',
        url: 'https://brightforge.com.ph/'
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Service',
      name: 'Keyword Research Services Philippines',
      serviceType: 'SEO keyword research and keyword mapping',
      provider: {
        '@type': 'LocalBusiness',
        name: 'Bright Forge SEO',
        url: 'https://brightforge.com.ph/',
        telephone: '+63-969-620-6182',
        address: {
          '@type': 'PostalAddress',
          addressCountry: 'PH'
        }
      },
      areaServed: ['Philippines', 'Australia', 'United Kingdom', 'United States'],
      url: 'https://brightforge.com.ph/keyword-research-services/',
      description: 'SEO keyword research, keyword mapping, competitor gap analysis and content roadmap planning for businesses that need practical search strategy.'
    })} />
  </Fragment>

  <LegacyHeader slot="header" />

  <Hero
    badgeIcon="fas fa-map-signs"
    badgeText="SEO Keyword Mapping"
    title="Keyword Research Services Philippines for <span>SEO Roadmaps That Get Used</span>"
    breadcrumbCurrent="Keyword Research Services"
  >
    <Fragment slot="story">
      <p>Keyword research should not end with a spreadsheet nobody uses.</p>
      <p>We turn search demand into a practical SEO roadmap: which pages to build, which existing pages to improve, which keywords are worth chasing and which ones should be ignored.</p>
      <p>Our keyword research services help businesses, agencies and content teams plan SEO work around real search intent, commercial value and page-level priorities.</p>
    </Fragment>

    <Fragment slot="actions">
      <ButtonPrimary href="/contact/" text="Request a Keyword Map" />
      <ButtonSecondary href="#deliverables" text="See What You Get" />
    </Fragment>

    <Fragment slot="stats">
      <div class="keyword-hero-proof">
        {proofItems.map((item) => (
          <article>
            <strong>{item.title}</strong>
            <span>{item.copy}</span>
          </article>
        ))}
      </div>
    </Fragment>

    <Fragment slot="visual">
      <div class="keyword-map-panel" aria-label="Keyword map example">
        <div class="panel-header">
          <span>Keyword map</span>
          <strong>Priority view</strong>
        </div>
        <div class="map-row high">
          <span>SEO services Philippines</span>
          <strong>Service page</strong>
        </div>
        <div class="map-row medium">
          <span>SEO pricing Philippines</span>
          <strong>Guide or sales page</strong>
        </div>
        <div class="map-row medium">
          <span>local SEO consultant Manila</span>
          <strong>Local service page</strong>
        </div>
        <div class="map-row low">
          <span>what is SEO</span>
          <strong>Support content</strong>
        </div>
      </div>
    </Fragment>
  </Hero>

  <section class="intro-section visible-section">
    <div class="content-wrap split-layout">
      <div>
        <p class="eyebrow">Search demand into decisions</p>
        <h2>Good <span>keyword research</span> tells you what to do next</h2>
        <p>Most keyword research fails because it treats every phrase like a content idea. That creates bloated spreadsheets, duplicate pages, weak blog plans and service pages that never get the focus they need.</p>
        <p>We use keyword research to make decisions. Some terms need a dedicated landing page. Some belong inside an existing service page. Some are FAQ opportunities. Some should be ignored because the intent is wrong or the SERP is unrealistic.</p>
        <p>The output is a roadmap for SEO work, not just a list of words.</p>
      </div>
      <aside class="statement-card">
        <span>Bright Forge approach</span>
        <strong>Research only matters when it changes the page plan.</strong>
        <p>We connect keywords to URLs, page types, content actions and measurable SEO priorities.</p>
      </aside>
    </div>
  </section>

  <section id="deliverables" class="deliverables-section visible-section">
    <div class="content-wrap">
      <div class="section-heading">
        <p class="eyebrow">What you get</p>
        <h2><span>Keyword research</span> deliverables built for implementation</h2>
        <p>These are the pieces that turn research into page strategy, content planning and campaign direction.</p>
      </div>
      <div class="deliverable-grid">
        {researchDeliverables.map((item) => (
          <article class="deliverable-card">
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="mapping-section visible-section">
    <div class="content-wrap mapping-layout">
      <div>
        <p class="eyebrow">Keyword mapping</p>
        <h2>The <span>keyword map</span> is the commercial bit</h2>
        <p>A keyword map shows where each search opportunity belongs. Without that step, research turns into guesswork and content teams end up creating pages that overlap, miss the intent or chase the wrong terms.</p>
        <p>We map keywords to the structure of the site, then prioritise the work around commercial value, ranking potential and what the business can realistically implement.</p>
        <a class="text-link" href="/on-page-seo-services-philippines/">See how this connects to on-page SEO</a>
      </div>
      <div class="field-panel">
        <h3>Typical keyword map fields</h3>
        <ul>
          {mappingFields.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="site-types-section visible-section">
    <div class="content-wrap">
      <div class="section-heading narrow">
        <p class="eyebrow">Different sites need different maps</p>
        <h2>We do not use the <span>same keyword logic</span> for every campaign</h2>
        <p>A local service site, ecommerce catalogue and agency client campaign need different research filters. The page type matters as much as the keyword.</p>
      </div>
      <div class="type-list">
        {siteTypes.map((item) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="avoid-section visible-section">
    <div class="content-wrap split-layout reverse">
      <div class="avoid-list">
        {avoidItems.map((item) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
      <div>
        <p class="eyebrow">What we refuse to do</p>
        <h2><span>Keyword research</span> should reduce waste, not create more of it</h2>
        <p>Bad keyword research makes every term look like an opportunity. Senior SEO means knowing what not to do.</p>
        <p>We filter aggressively so the roadmap focuses on pages and content that can support rankings, enquiries and long-term search visibility.</p>
      </div>
    </div>
  </section>

  <section class="process-section visible-section">
    <div class="content-wrap">
      <div class="section-heading narrow">
        <p class="eyebrow">Process</p>
        <h2>How we turn <span>keyword data</span> into an SEO roadmap</h2>
      </div>
      <div class="process-list">
        {processSteps.map((step) => (
          <article>
            <span>{step.label}</span>
            <div>
              <h3>{step.title}</h3>
              <p>{step.copy}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="implementation-section visible-section">
    <div class="content-wrap split-layout">
      <div>
        <p class="eyebrow">After the research</p>
        <h2>The next step is usually <span>page work</span></h2>
        <p>Keyword research is most useful when it feeds directly into implementation. That might mean rewriting a service page, building a new location page, improving internal links, creating supporting articles or fixing technical issues that block the target pages.</p>
        <p>If you only need the research, we can hand over the roadmap. If you want execution, we can turn the plan into content, on-page improvements, technical fixes and campaign tracking.</p>
      </div>
      <div class="implementation-links">
        {connectedServices.map((service) => (
          <a href={service.href}>
            <strong>{service.title}</strong>
            <span>{service.copy}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band visible-section">
    <div class="content-wrap cta-inner">
      <div>
        <p class="eyebrow">Start with the map</p>
        <h2>Need a clearer <span>SEO content plan</span>?</h2>
        <p>Send us the site, the market and the main services you want to grow. We will review whether keyword research, an SEO audit or page-level optimisation is the right first step.</p>
      </div>
      <ButtonPrimary href="/contact/" text="Request a Keyword Map" />
    </div>
  </section>

  <section class="faq-section visible-section">
    <div class="content-wrap narrow">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2><span>Keyword research</span> questions, answered properly</h2>
      </div>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <ContactSection id="contact" />
  <Footer slot="footer" />
</MainLayout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    background: #0d0f1a;
    color: #e8eaf2;
  }

  .visible-section,
  .intro-section,
  .deliverables-section,
  .mapping-section,
  .site-types-section,
  .avoid-section,
  .process-section,
  .implementation-section,
  .cta-band,
  .faq-section {
    content-visibility: visible !important;
    contain-intrinsic-size: auto !important;
    padding: 5.5rem 0;
    background: #0d0f1a;
    color: #e8eaf2;
  }

  .deliverables-section,
  .site-types-section,
  .implementation-section,
  .faq-section {
    background: #131627;
  }

  .content-wrap {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .content-wrap.narrow,
  .section-heading.narrow {
    max-width: 860px;
  }

  .split-layout,
  .mapping-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: 3rem;
    align-items: center;
  }

  .split-layout.reverse {
    grid-template-columns: minmax(320px, 0.95fr) minmax(0, 1.05fr);
  }

  .eyebrow {
    color: #f0622a;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    margin: 0 0 0.9rem;
    text-transform: uppercase;
  }

  h2 {
    color: #fff;
    font-size: clamp(2rem, 4vw, 3.15rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin: 0 0 1.2rem;
  }

  h3 {
    color: #fff;
    font-size: 1.12rem;
    line-height: 1.25;
    margin: 0 0 0.65rem;
  }

  p {
    color: #c9cedd;
    font-size: 1.02rem;
    line-height: 1.75;
    margin: 0 0 1rem;
  }

  .keyword-hero-proof {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.85rem;
    margin-top: 1.5rem;
  }

  .keyword-hero-proof article {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 18px;
    padding: 1rem;
  }

  .keyword-hero-proof strong,
  .keyword-hero-proof span {
    display: block;
  }

  .keyword-hero-proof strong {
    color: #fff;
    font-size: 0.92rem;
    margin-bottom: 0.45rem;
  }

  .keyword-hero-proof span {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .keyword-map-panel {
    background: linear-gradient(145deg, rgba(19, 22, 39, 0.96), rgba(13, 15, 26, 0.96));
    border: 1px solid rgba(240, 98, 42, 0.28);
    border-radius: 26px;
    box-shadow: 0 28px 90px rgba(0, 0, 0, 0.42);
    padding: 1.4rem;
    width: min(100%, 460px);
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: #fff;
    margin-bottom: 1rem;
  }

  .panel-header span {
    color: #f0622a;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.76rem;
  }

  .map-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: center;
    background: rgba(255, 255, 255, 0.055);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-left: 4px solid #f0622a;
    border-radius: 16px;
    color: #fff;
    margin-top: 0.75rem;
    padding: 0.95rem;
  }

  .map-row strong {
    background: rgba(240, 98, 42, 0.15);
    border-radius: 999px;
    color: #ffb18e;
    font-size: 0.75rem;
    padding: 0.35rem 0.65rem;
    white-space: nowrap;
  }

  .map-row.medium {
    border-left-color: #f59e0b;
  }

  .map-row.low {
    border-left-color: #64748b;
  }

  .statement-card,
  .field-panel {
    background: linear-gradient(145deg, rgba(240, 98, 42, 0.13), rgba(255, 255, 255, 0.04));
    border: 1px solid rgba(240, 98, 42, 0.24);
    border-radius: 26px;
    padding: 2rem;
  }

  .statement-card span {
    color: #f0622a;
    display: block;
    font-weight: 800;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .statement-card strong {
    color: #fff;
    display: block;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    line-height: 1.12;
    margin-bottom: 1rem;
  }

  .section-heading {
    margin: 0 auto 3rem;
    max-width: 860px;
    text-align: center;
  }

  .section-heading p:last-child {
    margin-left: auto;
    margin-right: auto;
    max-width: 680px;
  }

  .deliverable-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .deliverable-card,
  .type-list article,
  .avoid-list article {
    background: rgba(255, 255, 255, 0.045);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 22px;
    padding: 1.5rem;
  }

  .deliverable-card p,
  .type-list p,
  .avoid-list p {
    font-size: 0.96rem;
    margin-bottom: 0;
  }

  .field-panel ul {
    display: grid;
    gap: 0.75rem;
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
  }

  .field-panel li {
    color: #dfe3ee;
    padding-left: 1.4rem;
    position: relative;
  }

  .field-panel li::before {
    color: #f0622a;
    content: '•';
    font-weight: 900;
    left: 0;
    position: absolute;
  }

  .text-link {
    color: #ff9a6e;
    display: inline-flex;
    font-weight: 800;
    margin-top: 0.5rem;
    text-decoration: none;
  }

  .text-link:hover {
    color: #fff;
  }

  .type-list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .avoid-list {
    display: grid;
    gap: 1rem;
  }

  .process-list {
    display: grid;
    gap: 1rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .process-list article {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
