  border-radius: 2rem;
  padding: 3rem;
}

.eyebrow {
  color: #f0622a;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 1rem;
}

.commercial-proof-layout h2,
.faq-section-commercial h2 {
  color: white;
  font-size: clamp(2rem, 4vw, 3rem);
