  font-size: 0.95rem;
}

@media (max-width: 1024px) {
  .benefits-layout {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .benefits-image {
    height: 400px;
    max-width: 100%;
  }
}

@media (max-width: 768px) {
  .benefits-grid {
    grid-template-columns: 1fr;
  }
}

.commercial-proof-section {
  padding: 5rem 0;
