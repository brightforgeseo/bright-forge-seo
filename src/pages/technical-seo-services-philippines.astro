  display: grid;
  gap: 1rem;
  margin: 0;
  padding: 0;
}

.proof-list li {
  display: grid;
  gap: 0.35rem;
  padding: 1.2rem 0 1.2rem 1.2rem;
  border-left: 3px solid #f0622a;
  background: rgba(255, 255, 255, 0.035);
  border-radius: 0 1rem 1rem 0;
}

.proof-list strong {
  color: white;
  font-size: 1.05rem;
}

.proof-list span {
  color: #c9cedd;
  line-height: 1.55;
}

.faq-section-commercial {
  padding: 5rem 0;
  background: #111421;
}

.faq-list-commercial {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.faq-list-commercial article {
  background: #171b2d;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 1.4rem;
  padding: 1.5rem;
}

.faq-list-commercial h3 {
  color: white;
  font-size: 1.15rem;
  margin-bottom: 0.8rem;
}

.faq-list-commercial p {
  color: #c9cedd;
  line-height: 1.6;
}

@media (max-width: 900px) {
  .commercial-proof-layout,
  .faq-list-commercial {
    grid-template-columns: 1fr;
  }
}

</style>

<style>
/* Why Technical SEO Section */
.why-technical-section {
  padding: 80px 0;
  background: #131627;
}

.section-header {
  text-align: center;
  margin-bottom: 50px;
}

.section-header h2 {
  font-size: 2.5rem;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 20px;
