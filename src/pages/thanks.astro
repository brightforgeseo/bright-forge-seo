---
import Layout from '../layouts/MainLayout.astro';
import LegacyHeader from '../components/LegacyHeader.astro';
import Footer from '../components/Footer.astro';
const title = "Thank You | Bright Forge SEO";
const description = "Thank you for contacting Bright Forge SEO. We'll get back to you shortly.";
---

<Layout title={title} description={description} noindex={true}>
  <LegacyHeader slot="header" />

  <section class="min-h-screen flex flex-col items-center justify-center text-center px-4">
    <h1 class="text-4xl md:text-5xl font-bold mb-6 text-[#f0622a]">
      Message Sent Successfully
    </h1>
    <p class="text-lg text-[#d0d4e8] max-w-xl mb-8">
      Thank you for reaching out! Our team will review your message and connect with you as soon as possible.
    </p>
    <a href="/" class="inline-flex items-center gap-2 px-8 py-4 rounded-full font-bold text-xs uppercase tracking-widest text-[#f0622a] border border-[rgba(240,98,42,0.15)] hover:border-[rgba(240,98,42,0.4)] transition-all" style="background:linear-gradient(135deg,rgba(240,98,42,0.1),rgba(240,98,42,0.05))">
      Back to Home
    </a>
  </section>

  <Footer slot="footer" />
</Layout>
