---
import MainLayout from '../layouts/MainLayout.astro';
import LegacyHeader from '../components/LegacyHeader.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';
import Hero from '../components/Hero.astro';
import ButtonPrimary from '../components/ButtonPrimary.astro';
import ButtonSecondary from '../components/ButtonSecondary.astro';

const servicePillars = [
  {
    title: 'Technical SEO',
    href: '/technical-seo-services-philippines/',
    kicker: 'Crawl, indexation and site health',
    copy: 'We fix the technical issues that stop Google understanding, crawling and trusting the site. That includes crawl waste, indexation problems, site architecture, redirects, canonicals, Core Web Vitals and structured data.'
  },
  {
    title: 'On-Page SEO',
    href: '/on-page-seo-services-philippines/',
    kicker: 'Relevance and page quality',
    copy: 'We improve titles, headings, internal links, content structure, search intent alignment and conversion signals so important pages are clearer for users and search engines.'
  },
  {
    title: 'Content SEO',
    href: '/content-seo-services-philippines/',
    kicker: 'Pages that deserve to rank',
    copy: 'We plan, brief and improve content around real search demand, buyer intent and topical gaps. The aim is not publishing for the sake of it. It is building useful pages that support rankings and enquiries.'
  },
  {
    title: 'Local SEO',
    href: '/local-seo-services-philippines/',
    kicker: 'Maps, locations and local trust',
    copy: 'We strengthen Google Business Profile signals, local landing pages, citations, reviews, service-area relevance and local organic visibility for businesses that need nearby customers.'
  },
  {
    title: 'SEO Audits',
    href: '/seo-audit-services/',
    kicker: 'Clear priorities, not 80 pages of fog',
    copy: 'We diagnose the technical, content, authority and conversion issues holding the site back, then turn the findings into a practical action plan with priorities, impact and implementation notes.'
  },
  {
    title: 'Keyword Research',
    href: '/keyword-research-services/',
    kicker: 'Search demand mapped to pages',
    copy: 'We map commercial keywords, informational demand, local modifiers, page intent and competitor gaps so the site targets searches that can actually bring qualified visitors.'
  },
  {
    title: 'Link Building',
    href: '/backlink-seo-services-philippines/',
    kicker: 'Authority without spam packages',
    copy: 'We focus on relevance, quality and risk control. Links should support authority and trust, not create a future clean-up job because someone bought cheap placements by the kilo.'
  },
  {
    title: 'AI Search Readiness',
    href: '/ai-search-optimization-services-philippines/',
    kicker: 'SEO foundations for AI answers',
    copy: 'We make important business information clearer for Google, AI answers and agentic search tools. This sits on top of SEO basics: crawlability, structured content, authority, entity clarity and useful pages.'
  }
];

const processSteps = [
  {
    label: 'Days 1 to 15',
    title: 'Diagnosis and commercial mapping',
    copy: 'We review crawl data, GSC, GA4, rankings, competitors, conversion paths and priority pages. The output is a practical map of what needs fixing first and why it matters.'
  },
  {
    label: 'Days 16 to 30',
    title: 'Technical and on-page foundations',
    copy: 'We handle the fixes that remove friction: indexation, metadata, page structure, internal links, schema, tracking gaps and obvious conversion blockers on money pages.'
  },
  {
    label: 'Days 31 to 60',
    title: 'Content and authority building',
    copy: 'We improve existing pages, brief new content, close topic gaps and start building stronger authority signals around the pages that can create leads or sales.'
  },
  {
    label: 'Days 61 to 90',
    title: 'Testing, reporting and next-stage growth',
    copy: 'We review movement in rankings, clicks, enquiries and page performance, then refine the campaign around what the data shows instead of repeating a fixed task list.'
  }
];

const engagementModels = [
  {
    title: 'SEO Audit Sprint',
    copy: 'Best when the site needs a senior diagnosis before committing to a campaign. Useful for technical problems, traffic drops, migration checks and unclear performance issues.'
  },
  {
    title: 'Monthly SEO Campaign',
    copy: 'Best for businesses that need ongoing technical, content, authority and reporting work. This is the main fit for competitive commercial SEO.'
  },
  {
    title: 'Local SEO Campaign',
    copy: 'Best for service-area businesses, clinics, trades, professional services and location-led brands that need maps visibility and local enquiries.'
  },
  {
    title: 'SEO + CRO Growth Campaign',
    copy: 'Best when rankings or traffic already exist but the website is not turning enough visitors into enquiries, calls, bookings or sales.'
  }
];

const proofItems = [
  {
    sector: 'Bridal Fashion',
    result: '+137.5% organic traffic',
    copy: 'Improved visibility and search traffic for a bridal dress designer through stronger organic targeting and page improvements.',
    href: '/case-studies/'
  },
  {
    sector: 'Ecommerce',
    result: '+49.3% organic clicks',
    copy: 'Lifted organic clicks for a leather wallet brand by improving search relevance, page performance and commercial SEO focus.',
    href: '/case-studies/'
  },
  {
    sector: 'Sports',
    result: '+34% organic traffic',
    copy: 'Grew organic traffic for a football app with a clearer search strategy and consistent optimisation across priority pages.',
    href: '/case-studies/'
  }
];

const faqs = [
  { question: 'What SEO services do Philippine businesses usually need first?', answer: 'Most campaigns start with technical SEO, keyword mapping, on-page improvements, internal linking and content gap work. Local businesses also need Google Business Profile optimisation and location signals, while national or ecommerce sites usually need stronger architecture, category content and authority building.' },
  { question: 'How much do SEO services cost in the Philippines?', answer: 'SEO pricing depends on the size of the site, the competitiveness of the market, the amount of implementation needed and whether the campaign includes content, local SEO, link building or CRO. We scope the work around the growth problem rather than forcing every business into the same package.' },
  { question: 'What is included in monthly SEO services?', answer: 'A monthly campaign can include technical fixes, keyword research, on-page optimisation, internal linking, content briefs, content improvements, local SEO, authority building, reporting and conversion recommendations. The exact mix depends on what will move rankings, leads and revenue fastest.' },
  { question: 'How long does SEO take to work?', answer: 'Technical fixes and on-page improvements can show movement within weeks, but meaningful commercial growth usually takes 3 to 6 months. Competitive markets often need 6 to 12 months of consistent technical, content and authority work.' },
  { question: 'Do you guarantee rankings?', answer: 'No serious SEO agency can honestly guarantee fixed rankings because Google controls the results and competitors keep moving. We can guarantee transparent work, clear priorities, evidence-led recommendations and reporting that shows what changed and what happened next.' },
  { question: 'Can you work with businesses outside the Philippines?', answer: 'Yes. Bright Forge works with Philippine businesses and international companies that need SEO strategy, technical implementation, content support, local SEO or an offshore SEO partner with senior experience.' },
  { question: 'Do we still need SEO if AI search is changing Google?', answer: 'Yes. AI search still depends on clear, crawlable, trustworthy source material. We treat AI readiness as a layer on top of SEO, not a replacement for technical health, strong content, links, reviews and conversion-focused pages.' },
  { question: 'What makes Bright Forge different from cheap SEO packages?', answer: 'We do not sell mystery tasks or thin monthly busywork. We prioritise the fixes that can affect rankings, leads and revenue, then show what changed, what the data says and what should happen next.' }
];
---

<MainLayout
  title="SEO Services Philippines for Rankings & Leads | Bright Forge"
  description="SEO services in the Philippines for businesses that need stronger rankings, better leads and clearer growth. Technical SEO, content, local SEO and CRO."
  faqs={faqs}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://brightforge.com.ph/'
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'SEO Services Philippines',
          item: 'https://brightforge.com.ph/seo-services-philippines/'
        }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: 'SEO Services Philippines for Rankings and Leads',
      url: 'https://brightforge.com.ph/seo-services-philippines/',
      inLanguage: 'en',
      description: 'Commercial SEO services in the Philippines covering technical SEO, content, local SEO, authority building, AI search readiness and conversion-focused optimisation.',
      publisher: {
        '@type': 'Organization',
        name: 'Bright Forge SEO',
        url: 'https://brightforge.com.ph/'
      },
      mainEntity: {
        '@type': 'ItemList',
        itemListOrder: 'https://schema.org/ItemListOrderAscending',
        itemListElement: servicePillars.map((service, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: service.title,
          url: `https://brightforge.com.ph${service.href}`
        }))
      }
    })} />
  </Fragment>

  <LegacyHeader slot="header" />

  <Hero
    badgeIcon="fas fa-chart-line"
    badgeText="Commercial SEO Services"
    title="SEO Services Philippines for <span>Rankings, Leads and Growth</span>"
    breadcrumbCurrent="SEO Services Philippines"
  >
    <Fragment slot="story">
      <p>SEO should not feel like a bag of disconnected tasks. We fix the technical, content, authority and conversion issues that stop a website becoming a reliable source of enquiries.</p>
      <p>Bright Forge provides SEO services for Philippine businesses and international teams that need clearer rankings, stronger pages and honest reporting. AI search readiness is part of the work, but the foundation is still the same: crawlable websites, useful content, trusted signals and pages that help visitors take action.</p>
    </Fragment>

    <Fragment slot="actions">
      <ButtonPrimary href="/contact/" text="Get a Free SEO Growth Audit" />
      <ButtonSecondary href="#included" text="See What Is Included" />
    </Fragment>

    <Fragment slot="stats">
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number">15+</span>
          <span class="stat-label">Years SEO Experience</span>
        </div>
        <div class="stat">
          <span class="stat-number">1000+</span>
          <span class="stat-label">Websites Ranked</span>
        </div>
        <div class="stat">
          <span class="stat-number">SEO+CRO</span>
          <span class="stat-label">Rankings to Enquiries</span>
        </div>
      </div>
    </Fragment>
  </Hero>

  <section class="commercial-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="commercial-layout">
        <div class="commercial-copy">
          <span class="eyebrow">The point of SEO</span>
          <h2>Rankings are only useful when they help the business grow</h2>
          <p>Search visibility matters, but traffic alone is not the win. A good SEO campaign should make the right pages easier to find, easier to trust and easier to act on.</p>
          <p>That is why our work goes beyond keyword placement. We look at crawlability, page structure, content quality, internal links, local signals, authority, tracking and conversion friction. If a page ranks but does not create enquiries, the job is not finished.</p>
        </div>
        <aside class="commercial-panel" aria-label="SEO campaign focus areas">
          <div class="panel-row">
            <strong>Technical clarity</strong>
            <span>Search engines can crawl, index and understand the site.</span>
          </div>
          <div class="panel-row">
            <strong>Commercial intent</strong>
            <span>Priority pages target searches that can lead to revenue.</span>
          </div>
          <div class="panel-row">
            <strong>Trust signals</strong>
            <span>Content, links, reviews and entity signals support credibility.</span>
          </div>
          <div class="panel-row">
            <strong>Conversion focus</strong>
            <span>The site gives visitors a clear next step after they arrive.</span>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="fit-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="fit-layout">
        <div>
          <span class="eyebrow">Who it is for</span>
          <h2>SEO support for businesses that need more than monthly busywork</h2>
        </div>
        <div class="fit-list">
          <article>
            <h3>Businesses with traffic but weak enquiries</h3>
            <p>We review page intent, CTAs, trust signals and conversion paths so existing organic visits have a better chance of turning into leads.</p>
          </article>
          <article>
            <h3>Local service businesses</h3>
            <p>We improve Google Business Profile signals, location pages, service pages, reviews and local relevance for searchers ready to call or book.</p>
          </article>
          <article>
            <h3>Ecommerce and category-led sites</h3>
            <p>We strengthen architecture, category content, technical foundations, internal links and product discovery for organic growth.</p>
          </article>
          <article>
            <h3>Teams that need senior SEO direction</h3>
            <p>We give internal teams, founders and marketing managers clear priorities instead of vague reports and generic package tasks.</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section id="included" class="included-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-heading">
        <span class="eyebrow">What is included</span>
        <h2>Fully managed SEO services, joined up properly</h2>
        <p>Each campaign uses the mix of SEO work the site actually needs. Some sites need technical fixes first. Others need stronger service pages, local trust, content depth, authority or better conversion paths.</p>
      </div>

      <div class="pillar-list">
        {servicePillars.map((service, index) => (
          <a class="pillar-item" href={service.href}>
            <span class="pillar-number">{String(index + 1).padStart(2, '0')}</span>
            <div>
              <span class="pillar-kicker">{service.kicker}</span>
              <h3>{service.title}</h3>
              <p>{service.copy}</p>
            </div>
            <span class="pillar-arrow">View service</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="process-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="process-grid">
        <div class="process-intro">
          <span class="eyebrow">First 90 days</span>
          <h2>What happens after an SEO campaign starts</h2>
          <p>The first stage should not be random tasks. It should create clarity, fix the biggest blockers and build momentum around the pages most likely to drive enquiries.</p>
        </div>
        <div class="timeline">
          {processSteps.map((step) => (
            <article class="timeline-item">
              <span>{step.label}</span>
              <h3>{step.title}</h3>
              <p>{step.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="engagement-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-heading left">
        <span class="eyebrow">Engagement options</span>
        <h2>SEO packages should match the problem, not force the same checklist on every site</h2>
        <p>Some businesses need a one-off audit. Others need monthly execution, local SEO, technical implementation, content improvement or SEO plus CRO. We scope around the growth problem and the level of competition.</p>
      </div>
      <div class="engagement-grid">
        {engagementModels.map((model) => (
          <article class="engagement-card">
            <h3>{model.title}</h3>
            <p>{model.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="proof-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="proof-header">
        <div>
          <span class="eyebrow">Proof of work</span>
          <h2>SEO needs evidence, not theatre</h2>
        </div>
        <p>We use rankings, GSC data, traffic, enquiries and commercial context to judge progress. The goal is to explain what changed, what the data shows and what should happen next.</p>
      </div>
      <div class="proof-grid">
        {proofItems.map((item) => (
          <a class="proof-card" href={item.href}>
            <span>{item.sector}</span>
            <strong>{item.result}</strong>
            <p>{item.copy}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="difference-section">
    <div class="max-w-7xl mx-auto px-6">
      <div class="difference-layout">
        <div class="difference-main">
          <span class="eyebrow">Why Bright Forge</span>
          <h2>Senior SEO judgement, practical implementation and honest reporting</h2>
          <p>Cheap SEO packages often hide behind activity: a few backlinks, a few posts, a ranking chart and a PDF. That is not enough when organic clicks are more valuable and search results are more crowded.</p>
          <p>Bright Forge works from evidence. We identify the pages that matter, the blockers that hold them back, the content that needs strengthening and the conversion gaps that waste traffic. Then we prioritise the work that can move the business.</p>
        </div>
        <div class="difference-points">
          <div>
            <h3>No mystery tasks</h3>
            <p>You should know what changed and why it was worth doing.</p>
          </div>
          <div>
            <h3>SEO-first AI readiness</h3>
            <p>AI visibility is treated as an operating layer on top of strong SEO foundations.</p>
          </div>
          <div>
            <h3>Technical capability</h3>
            <p>We can diagnose implementation problems instead of only writing recommendations.</p>
          </div>
          <div>
            <h3>Conversion awareness</h3>
            <p>Rankings get visitors in. The page still needs to earn the enquiry.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="max-w-4xl mx-auto px-6">
      <div class="section-heading">
        <span class="eyebrow">SEO questions</span>
        <h2>What businesses usually ask before starting SEO</h2>
        <p>Clear answers before the proposal stage, because good SEO should not feel like buying fog in a jar.</p>
      </div>
      <div class="faq-list">
        {faqs.map((faq) => (
          <article class="faq-item">
            <h3>{faq.question}</h3>
            <p>{faq.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="final-cta-section">
    <div class="max-w-5xl mx-auto px-6">
      <div class="final-cta-panel">
        <span class="eyebrow">Start with clarity</span>
        <h2>Get a free SEO growth audit</h2>
        <p>We will review your site, search visibility and biggest growth blockers, then show where SEO can realistically move the needle.</p>
        <div class="final-actions">
          <ButtonPrimary href="/contact/" text="Request Your SEO Audit" />
          <ButtonSecondary href="mailto:seo@brightforgeseo.com" text="Email Bright Forge" />
        </div>
      </div>
    </div>
  </section>

  <ContactSection id="contact" />
  <Footer slot="footer" />
</MainLayout>

<style>
:root {
  --bf-bg: #0d0f1a;
  --bf-panel: #131627;
  --bf-panel-2: #181c30;
  --bf-text: #e8eaf2;
  --bf-muted: #b9bed4;
  --bf-soft: #8e94ad;
  --bf-orange: #f0622a;
  --bf-orange-dark: #b73510;
  --bf-border: rgba(255, 255, 255, 0.1);
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1rem;
}

.stat {
  padding: 1rem;
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 1rem;
  background: rgba(255, 255, 255, 0.06);
}

.stat-number {
  display: block;
  color: #fff;
  font-size: clamp(1.35rem, 2vw, 1.8rem);
  font-weight: 900;
  letter-spacing: -0.03em;
  line-height: 1;
  margin-bottom: .5rem;
}

.stat-label {
  color: rgba(255, 255, 255, 0.78);
  font-size: .83rem;
  line-height: 1.35;
}

.commercial-section,
.fit-section,
.included-section,
.process-section,
.engagement-section,
.proof-section,
.difference-section,
.faq-section,
.final-cta-section,
:global(.contact-cta-section) {
  content-visibility: visible !important;
  background: var(--bf-bg);
  color: var(--bf-text);
}

.commercial-section,
.included-section,
.engagement-section,
.difference-section,
.final-cta-section {
  padding: 6rem 0;
}

.fit-section,
.process-section,
.proof-section,
.faq-section {
  padding: 6rem 0;
  background: var(--bf-panel);
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: .45rem;
  color: var(--bf-orange);
  font-size: .78rem;
  font-weight: 800;
  letter-spacing: .09em;
  text-transform: uppercase;
  margin-bottom: 1rem;
}

.commercial-layout {
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(320px, .95fr);
  gap: 4rem;
  align-items: center;
}

.commercial-copy h2,
.fit-layout h2,
.section-heading h2,
.process-intro h2,
.proof-header h2,
.difference-main h2,
.final-cta-panel h2 {
  color: var(--bf-text);
  font-size: clamp(2.1rem, 4vw, 3.4rem);
  line-height: 1.08;
  letter-spacing: -0.04em;
  font-weight: 900;
  margin: 0 0 1.25rem;
}

.commercial-copy p,
.fit-layout p,
.section-heading p,
.process-intro p,
.proof-header p,
.difference-main p,
.final-cta-panel p {
  color: var(--bf-muted);
  font-size: 1.06rem;
  line-height: 1.75;
  margin: 0 0 1rem;
}

.commercial-panel {
  background: linear-gradient(145deg, var(--bf-orange), var(--bf-orange-dark));
  border-radius: 2rem;
  padding: 2rem;
  box-shadow: 0 25px 80px rgba(240, 98, 42, 0.22);
  transform: rotate(1deg);
}

.panel-row {
  padding: 1.15rem 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.22);
}

.panel-row:last-child {
  border-bottom: 0;
}

.panel-row strong {
  display: block;
  color: #fff;
  font-size: 1.1rem;
  margin-bottom: .35rem;
}

.panel-row span {
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.55;
}

.fit-layout {
  display: grid;
  grid-template-columns: .78fr 1.22fr;
  gap: 4rem;
}

.fit-list {
  display: grid;
  gap: 1rem;
}

.fit-list article {
  padding: 1.5rem 0 1.5rem 1.5rem;
  border-left: 2px solid rgba(240, 98, 42, 0.55);
}

.fit-list h3,
.timeline-item h3,
.engagement-card h3,
.difference-points h3,
.faq-item h3 {
  color: #fff;
  font-size: 1.18rem;
  font-weight: 800;
  margin: 0 0 .55rem;
}

.section-heading {
  max-width: 820px;
  text-align: center;
  margin: 0 auto 3.5rem;
}

.section-heading.left {
  text-align: left;
  margin-left: 0;
}

.pillar-list {
  display: grid;
  gap: 1rem;
}

.pillar-item {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  gap: 1.25rem;
  align-items: start;
  padding: 1.5rem;
  background: rgba(255, 255, 255, 0.035);
  border: 1px solid var(--bf-border);
  border-radius: 1.25rem;
  text-decoration: none;
  transition: border-color .25s ease, transform .25s ease, background .25s ease;
}

.pillar-item:hover {
  transform: translateY(-2px);
  border-color: rgba(240, 98, 42, 0.55);
  background: rgba(240, 98, 42, 0.055);
}

.pillar-number {
  color: var(--bf-orange);
  font-size: .9rem;
  font-weight: 900;
  letter-spacing: .08em;
}

.pillar-kicker {
  display: block;
  color: var(--bf-soft);
  font-size: .78rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .08em;
  margin-bottom: .4rem;
}

.pillar-item h3 {
  color: #fff;
  font-size: 1.35rem;
  margin: 0 0 .45rem;
}

.pillar-item p,
.engagement-card p,
.timeline-item p,
.difference-points p,
.faq-item p,
.proof-card p {
  color: var(--bf-muted);
  line-height: 1.7;
  margin: 0;
}

.pillar-arrow {
  color: var(--bf-orange);
  font-weight: 800;
  font-size: .9rem;
  white-space: nowrap;
  padding-top: .15rem;
}

.process-grid {
  display: grid;
  grid-template-columns: .8fr 1.2fr;
  gap: 4rem;
  align-items: start;
}

.timeline {
  position: relative;
  display: grid;
  gap: 1rem;
}

.timeline-item {
  position: relative;
  padding: 1.5rem 1.5rem 1.5rem 2rem;
  background: rgba(255, 255, 255, 0.035);
  border: 1px solid var(--bf-border);
  border-radius: 1.25rem;
}

.timeline-item span {
  display: inline-block;
  color: var(--bf-orange);
