---
import MainLayout from '../layouts/MainLayout.astro';
import LegacyHeader from '../components/LegacyHeader.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';
import Hero from '../components/Hero.astro';
import ButtonPrimary from '../components/ButtonPrimary.astro';
import ButtonSecondary from '../components/ButtonSecondary.astro';

const proofItems = [
  {
    title: 'Migration risk mapped before launch',
    copy: 'We review existing URLs, traffic, rankings, backlinks, templates, metadata, canonicals, redirects, tracking and indexation rules before anything goes live.'
  },
  {
    title: 'Redirects planned with evidence',
    copy: 'Legacy URLs are matched to the most relevant new destinations, with priority given to pages that have rankings, backlinks, conversions or meaningful organic traffic.'
  },
  {
    title: 'Launch support, not blind handoff',
    copy: 'We check the live site after release, monitor Search Console and analytics, and help your developers triage issues while the migration is still fresh.'
  }
];

const migrationRisks = [
  {
    title: 'Important URLs disappear',
    copy: 'High-value pages can be removed, renamed, blocked or redirected to weak destinations. We build a URL inventory so priority pages are not lost in the rebuild.'
  },
  {
    title: 'Redirects leak relevance',
    copy: 'Bulk redirects to the homepage, chains, loops and irrelevant destination mapping can damage organic performance. We map old URLs to the closest useful replacement.'
  },
  {
    title: 'Metadata and headings change by accident',
    copy: 'New templates often overwrite titles, descriptions, H1s, copy blocks, schema and internal links. We compare old and new templates before launch.'
  },
  {
    title: 'Indexation controls are wrong',
    copy: 'Robots.txt, noindex tags, canonicals, sitemap files and staging rules can block or confuse search engines. We check these before and after go-live.'
  },
  {
    title: 'Tracking breaks during the move',
    copy: 'Analytics, form tracking, conversion events, Google Search Console and Tag Manager can be missed during rebuilds. We verify measurement so impact can be judged properly.'
  },
  {
    title: 'Internal links point to the past',
    copy: 'Navigation, body links, breadcrumbs and XML sitemaps can keep pointing at old URLs. We check internal links so authority flows to the live pages.'
  }
];

const migrationTypes = [
  {
    title: 'Website redesigns',
    copy: 'For design refreshes where templates, page copy, headings, internal links or conversion paths may change even if the CMS stays the same.'
  },
  {
    title: 'CMS changes',
    copy: 'For moves between WordPress, Shopify, Webflow, Magento, Drupal, custom builds, static sites or headless CMS setups.'
  },
  {
    title: 'Domain changes',
    copy: 'For rebrands, domain moves, HTTP to HTTPS work, subdomain changes, international domain changes and consolidation projects.'
  },
  {
    title: 'Ecommerce replatforming',
    copy: 'For product, category, filter and collection migrations where URL handling, faceted navigation and templates need careful SEO controls.'
  },
  {
    title: 'URL structure changes',
    copy: 'For sites changing slugs, folders, service pages, location pages, category structures, blog paths or information architecture.'
  },
  {
    title: 'Site consolidation',
    copy: 'For merging multiple websites, old microsites, subdomains or duplicate brands into one stronger structure without losing useful equity.'
  }
];

const preMigrationChecks = [
  'Organic traffic and landing-page baseline',
  'Keyword rankings and priority URL list',
  'Backlink URLs and externally linked pages',
  'Full crawl of the existing website',
  'Indexable URL inventory',
  'Title, meta, H1 and content template review',
  'Canonical, robots and sitemap checks',
  'Internal-link and navigation review',
  'Analytics, events and form tracking review',
  'Known technical issues that should not be carried forward'
];

const launchChecks = [
  {
    label: '01',
    title: 'Baseline and URL inventory',
    copy: 'We crawl the current site, export priority URLs, identify traffic and ranking pages, and separate URLs that must be preserved, redirected, merged or removed.'
  },
  {
    label: '02',
    title: 'Redirect and destination mapping',
    copy: 'We prepare the redirect map, check destination relevance, flag weak matches and provide implementation notes for the CMS, server or development team.'
  },
  {
    label: '03',
    title: 'Staging SEO review',
    copy: 'We crawl the staging site and compare templates, metadata, content, canonicals, structured data, internal links, sitemaps and indexation controls.'
  },
  {
    label: '04',
    title: 'Launch checklist and sign-off',
    copy: 'We confirm that the site is ready from an SEO risk perspective, with launch-day checks for redirects, tracking, robots rules, sitemaps and core page templates.'
  },
  {
    label: '05',
    title: 'Post-launch crawl and monitoring',
    copy: 'We crawl the live site, test redirects, check important pages, review Search Console signals and monitor organic movement after the release.'
  },
  {
    label: '06',
    title: 'Triage and recovery actions',
    copy: 'If issues appear, we help prioritise fixes by risk and commercial impact so your team handles the right problems first.'
  }
];

const deliverables = [
  {
    title: 'Migration risk review',
    copy: 'A practical summary of the pages, templates, rankings, traffic sources and technical controls that need protection during the move.'
  },
  {
    title: 'URL and redirect map',
    copy: 'A mapped list of old URLs, recommended new destinations, redirect notes and priority flags for pages with rankings, traffic or backlinks.'
  },
  {
    title: 'Staging SEO QA notes',
    copy: 'Findings from the staging crawl, including indexation settings, metadata, page templates, canonical handling, internal links, schema and tracking gaps.'
  },
  {
    title: 'Launch-day SEO checklist',
    copy: 'A clear checklist for go-live covering redirects, robots rules, sitemap files, analytics, Search Console, tracking, priority pages and developer handoff.'
  },
  {
    title: 'Post-launch monitoring summary',
    copy: 'A follow-up review of crawl issues, redirect behaviour, Search Console coverage, rankings, organic landing pages and urgent fixes after launch.'
  },
  {
    title: 'Developer-ready implementation notes',
    copy: 'Clear instructions your development team can act on, including what matters most, where the evidence is and how to verify each fix.'
  }
];

const noPromiseItems = [
  {
    title: 'No promise of zero movement',
    copy: 'Any meaningful migration can cause short-term movement. Honest migration SEO is about reducing avoidable risk, spotting problems early and protecting the strongest pages.'
  },
  {
    title: 'No bulk homepage redirects',
    copy: 'Redirecting everything to one generic page is usually lazy and risky. We map URLs by relevance and business value.'
  },
  {
    title: 'No launch without measurement',
    copy: 'A migration cannot be judged properly if analytics, forms, events and Search Console are not checked. Tracking is part of the migration plan.'
  },
  {
    title: 'No checklist theatre',
    copy: 'A migration checklist only helps if it is tied to the actual site, its rankings, its CMS and its launch constraints. We focus on what can affect performance.'
  }
];

const connectedServices = [
  {
    title: 'Technical SEO services',
    href: '/technical-seo-services-philippines/',
    copy: 'For crawl, indexation, performance, rendering, schema and architecture fixes before or after a migration.'
  },
  {
    title: 'SEO audit services',
    href: '/seo-audit-services/',
    copy: 'For diagnosing wider SEO issues before deciding whether a migration, rebuild or technical cleanup is the right move.'
  },
  {
    title: 'On-page SEO services',
    href: '/on-page-seo-services-philippines/',
    copy: 'For preserving and improving page-level titles, headings, copy, internal links, proof and conversion paths during a redesign.'
  },
  {
    title: 'Keyword research services',
    href: '/keyword-research-services/',
    copy: 'For mapping search demand to the new site structure before URLs and navigation are locked in.'
  },
  {
    title: 'SEO services Philippines',
    href: '/seo-services-philippines/',
    copy: 'For ongoing SEO work after the migration, including content, technical fixes, links, reporting and growth planning.'
  },
  {
    title: 'Content SEO services',
    href: '/content-seo-services-philippines/',
    copy: 'For rewriting or improving pages that need stronger search intent, better proof and clearer conversion paths after the move.'
  }
];

const faqs = [
  { question: 'What is website migration SEO?', answer: 'Website migration SEO is the planning, QA and monitoring work used to reduce organic traffic risk during a redesign, CMS move, domain change, URL restructure or site consolidation. It covers redirects, indexation controls, metadata, internal links, tracking, sitemaps, templates and post-launch monitoring.' },
  { question: 'Will a website migration affect rankings?', answer: 'It can. Some short-term movement is normal when URLs, templates, content or platform signals change. The goal is to reduce avoidable losses by mapping important URLs, preserving relevant content and signals, checking redirects and monitoring the site after launch.' },
  { question: 'When should SEO be involved in a migration?', answer: 'SEO should be involved before the new structure and templates are finalised. The best time is during planning, before developers lock in URLs, navigation, content templates, redirect logic and tracking setup.' },
  { question: 'Do you create redirect maps?', answer: 'Yes. We can create or review redirect maps using crawl data, ranking pages, traffic pages, backlink URLs and the planned new structure. The aim is to match old URLs to the most relevant live destination, not just redirect everything to the homepage.' },
  { question: 'Can you work with our developers?', answer: 'Yes. We often work alongside internal teams, web developers, designers and ecommerce specialists. We provide SEO requirements, QA notes, redirect guidance, staging feedback and post-launch checks so the development team has clear actions.' },
  { question: 'Do you handle ecommerce migrations?', answer: 'Yes. Ecommerce migrations need extra care around product URLs, category pages, collections, filters, canonicals, discontinued products, faceted navigation, schema and internal links. We review those areas before and after launch.' },
  { question: 'What do you check after launch?', answer: 'We usually check live redirects, priority pages, crawl errors, robots.txt, noindex tags, canonicals, XML sitemaps, analytics, conversion tracking, Search Console coverage, ranking movement and organic landing-page behaviour.' },
  { question: 'Can you fix a migration that has already gone wrong?', answer: 'Yes, depending on the issue. We can audit the old and new site data, identify lost URLs, redirect mistakes, indexation problems, content changes, tracking gaps and technical blockers, then prioritise recovery actions.' }
];
---

<MainLayout
  title="Website Migration SEO Services Philippines | Bright Forge"
  description="Website migration SEO services for safer redesigns, CMS moves, domain changes, redirect mapping, staging QA and post-launch search monitoring."
  keywords="website migration SEO, SEO migration services, site migration SEO, website migration services Philippines, domain migration SEO, ecommerce migration SEO"
  faqs={faqs}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://brightforge.com.ph/'
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Website Migration SEO Services',
          item: 'https://brightforge.com.ph/website-migration-services/'
        }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: 'Website Migration SEO Services Philippines',
      url: 'https://brightforge.com.ph/website-migration-services/',
      description: 'Website migration SEO services for safer redesigns, CMS moves, domain changes, redirect mapping, staging QA and post-launch search monitoring.',
      isPartOf: {
        '@type': 'WebSite',
        name: 'Bright Forge SEO',
        url: 'https://brightforge.com.ph/'
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Service',
      name: 'Website Migration SEO Services Philippines',
      serviceType: 'Website migration SEO, redirect mapping and launch QA',
      provider: {
        '@type': 'LocalBusiness',
        name: 'Bright Forge SEO',
        url: 'https://brightforge.com.ph/',
        telephone: '+63-969-620-6182',
        email: 'seo@brightforgeseo.com'
      },
      areaServed: {
        '@type': 'Country',
        name: 'Philippines'
      },
      url: 'https://brightforge.com.ph/website-migration-services/',
      description: 'SEO support for website migrations, including pre-migration audits, redirect mapping, staging QA, launch checks and post-launch monitoring.'
    })} />
  </Fragment>

  <LegacyHeader slot="header" />

  <Hero
    badgeIcon="fas fa-route"
    badgeText="Migration SEO"
    title="Website Migration SEO Services for Safer Site Launches"
    breadcrumbCurrent="Website Migration Services"
  >
    <Fragment slot="story">
      <p>A redesign, CMS move or domain change can improve the business, but it can also damage organic traffic if URLs, redirects, templates, tracking and indexation controls are handled late.</p>
      <p>We help businesses plan and QA migrations with SEO involved before launch, not after rankings have already moved.</p>
      <p>The aim is simple: protect the pages that matter, reduce avoidable risk and give your development team clear checks before and after go-live.</p>
    </Fragment>

    <Fragment slot="actions">
      <ButtonPrimary href="/contact/" text="Plan a Safer Migration" />
      <ButtonSecondary href="#migration-process" text="Review the Process" />
    </Fragment>

    <Fragment slot="stats">
      <div class="migration-hero-stats">
        <div>
          <strong>Before</strong>
          <span>baseline, crawl and URL inventory</span>
        </div>
        <div>
          <strong>During</strong>
          <span>redirect, staging and launch checks</span>
        </div>
        <div>
          <strong>After</strong>
          <span>crawl, GSC and traffic monitoring</span>
        </div>
      </div>
    </Fragment>

    <Fragment slot="visual">
      <div class="migration-visual" aria-label="Website migration SEO workflow">
        <div class="migration-node old-site">Old site</div>
        <div class="migration-line"></div>
        <div class="migration-node controls">SEO controls</div>
        <div class="migration-line"></div>
        <div class="migration-node new-site">New site</div>
        <div class="migration-checklist">
          <span>URL inventory</span>
          <span>Redirect map</span>
          <span>Staging crawl</span>
          <span>Launch QA</span>
        </div>
      </div>
    </Fragment>
  </Hero>

  <section class="proof-strip" style="content-visibility: visible !important;">
    <div class="container-narrow">
      {proofItems.map((item) => (
        <article class="proof-card">
          <h2>{item.title}</h2>
          <p>{item.copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="intro-section" style="content-visibility: visible !important;">
    <div class="container-grid two-col">
      <div>
        <span class="section-kicker">Why migration SEO matters</span>
        <h2>Most migration losses are preventable</h2>
      </div>
      <div class="rich-copy">
        <p>Search engines do not understand your project plan. They see changed URLs, new templates, different internal links, altered content, new status codes and different indexation signals.</p>
        <p>If the migration is planned only as a design or development project, SEO risk usually appears too late. The safer approach is to identify the pages and signals that already drive visibility, then protect them before the new site launches.</p>
      </div>
    </div>
  </section>

  <section class="risk-section" style="content-visibility: visible !important;">
    <div class="container-wide">
      <div class="section-heading">
        <span class="section-kicker">What can go wrong</span>
        <h2>Migration risks we check before they become traffic problems</h2>
        <p>These are the problems we look for when a business is redesigning, replatforming, restructuring URLs or moving domains.</p>
      </div>
      <div class="card-grid three-col">
        {migrationRisks.map((risk) => (
          <article class="content-card">
            <h3>{risk.title}</h3>
            <p>{risk.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="types-section" style="content-visibility: visible !important;">
    <div class="container-wide">
      <div class="section-heading">
        <span class="section-kicker">Migration scenarios</span>
        <h2>Support for the moves that affect organic search</h2>
        <p>Different migration types carry different SEO risks. We shape the checks around the actual move, not a generic launch checklist.</p>
      </div>
      <div class="card-grid three-col">
        {migrationTypes.map((type) => (
          <article class="content-card subtle-card">
            <h3>{type.title}</h3>
            <p>{type.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="checklist-section" style="content-visibility: visible !important;">
    <div class="container-grid two-col align-start">
      <div>
        <span class="section-kicker">Before the move</span>
        <h2>What we audit before URLs and templates are locked in</h2>
        <p class="section-lede">A migration plan should start with evidence. We identify which pages, signals and conversion paths need protection before design or development decisions make SEO harder to fix.</p>
      </div>
      <div class="checklist-panel">
        {preMigrationChecks.map((check) => (
          <div class="check-row">
            <span class="check-icon">✓</span>
            <span>{check}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="migration-process" class="process-section" style="content-visibility: visible !important;">
    <div class="container-wide">
      <div class="section-heading">
        <span class="section-kicker">Migration process</span>
        <h2>A practical SEO process for safer launches</h2>
        <p>We work before, during and after launch so SEO requirements are clear to the people building the site.</p>
      </div>
      <div class="process-grid">
        {launchChecks.map((step) => (
          <article class="process-card">
            <span class="process-label">{step.label}</span>
            <h3>{step.title}</h3>
            <p>{step.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="deliverables-section" style="content-visibility: visible !important;">
    <div class="container-wide">
      <div class="section-heading">
        <span class="section-kicker">What you get</span>
        <h2>Migration deliverables built for implementation</h2>
        <p>The output should help owners, marketers, developers and stakeholders make safer launch decisions.</p>
      </div>
      <div class="card-grid three-col">
        {deliverables.map((item) => (
          <article class="content-card deliverable-card">
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="honest-section" style="content-visibility: visible !important;">
    <div class="container-grid two-col align-start">
      <div>
        <span class="section-kicker">Honest migration SEO</span>
        <h2>What we will not promise</h2>
        <p class="section-lede">Migration SEO should be careful, specific and honest. Overpromising is dangerous because every site, CMS, dev team and launch constraint is different.</p>
      </div>
      <div class="honest-grid">
        {noPromiseItems.map((item) => (
          <article class="honest-card">
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="connected-section" style="content-visibility: visible !important;">
    <div class="container-wide">
      <div class="section-heading">
        <span class="section-kicker">Connected SEO work</span>
        <h2>Migration SEO sits between technical, content and growth work</h2>
        <p>A safe launch often depends on more than redirects. These services connect with migration planning and post-launch improvement.</p>
      </div>
      <div class="connected-grid">
        {connectedServices.map((service) => (
          <a class="connected-card" href={service.href}>
            <h3>{service.title}</h3>
            <p>{service.copy}</p>
            <span>View service</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="faq-section" style="content-visibility: visible !important;">
    <div class="container-narrow single-column">
      <div class="section-heading">
        <span class="section-kicker">FAQ</span>
        <h2>Website migration SEO questions</h2>
        <p>Clear answers before a redesign, CMS move, domain change or replatforming project.</p>
      </div>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="final-cta" style="content-visibility: visible !important;">
    <div class="container-narrow single-column">
      <span class="section-kicker">Planning a move?</span>
      <h2>Get SEO involved before launch day</h2>
      <p>If your site is being redesigned, replatformed, moved to a new domain or restructured, we can review the migration risk before developers lock in the launch plan.</p>
      <div class="cta-actions">
        <ButtonPrimary href="/contact/" text="Request a Migration SEO Review" />
        <ButtonSecondary href="/technical-seo-services-philippines/" text="Explore Technical SEO" />
      </div>
    </div>
  </section>

  <ContactSection id="contact" />
  <Footer slot="footer" />
</MainLayout>

<style>
  :root {
    --migration-bg: #0d0f1a;
    --migration-panel: #131627;
    --migration-panel-soft: #181c31;
    --migration-border: rgba(255, 255, 255, 0.08);
    --migration-text: #ffffff;
    --migration-muted: rgba(255, 255, 255, 0.78);
    --migration-accent: #f0622a;
    --migration-accent-dark: #d4510e;
  }

  section {
    background: var(--migration-bg);
    color: var(--migration-text);
    padding: 5rem 0;
  }

  .container-wide,
  .container-narrow,
  .container-grid {
    width: min(1180px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .container-narrow {
    width: min(960px, calc(100% - 2rem));
  }

  .single-column {
    text-align: center;
  }

  .container-grid {
    display: grid;
    gap: 3rem;
  }

  .two-col {
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    align-items: center;
  }

  .align-start {
    align-items: start;
  }

  .section-kicker {
    display: inline-flex;
    color: var(--migration-accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.9rem;
  }

  h2 {
    color: #ffffff;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0;
  }

  h3 {
    color: #ffffff;
    margin: 0 0 0.75rem;
    font-size: 1.18rem;
    line-height: 1.25;
  }

  p {
    color: var(--migration-muted);
    line-height: 1.7;
  }

  .section-heading {
    max-width: 780px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .section-heading p,
  .section-lede {
    font-size: 1.08rem;
    margin-top: 1rem;
  }

  .rich-copy p:first-child {
    margin-top: 0;
  }

  .migration-hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .migration-hero-stats div {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 16px;
    padding: 1rem;
  }

  .migration-hero-stats strong {
    display: block;
    color: #ffffff;
    font-size: 0.95rem;
    margin-bottom: 0.35rem;
  }

  .migration-hero-stats span {
    display: block;
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  :global(body .hero-visual) {
    display: flex !important;
    visibility: visible !important;
  }

  :global(body .hero-visual *) {
    display: revert !important;
    visibility: visible !important;
  }

  :global(body .migration-visual),
  :global(body .migration-visual *) {
    visibility: visible !important;
  }

  .migration-visual {
    display: flex !important;
    width: min(420px, 100%);
    min-height: 420px;
    border: 1px solid rgba(240, 98, 42, 0.25);
    background: radial-gradient(circle at 50% 20%, rgba(240, 98, 42, 0.22), rgba(19, 22, 39, 0.7) 45%, rgba(13, 15, 26, 0.95));
    border-radius: 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.35);
  }

  .migration-node {
    width: 160px;
    text-align: center;
    border-radius: 999px;
    padding: 0.85rem 1rem;
    color: #ffffff;
    font-weight: 800;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.09);
  }

  .migration-node.controls {
    background: linear-gradient(135deg, var(--migration-accent), var(--migration-accent-dark));
  }

  .migration-line {
    width: 2px;
    height: 34px;
    background: linear-gradient(180deg, transparent, rgba(240, 98, 42, 0.8), transparent);
  }

  .migration-checklist {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.6rem;
    margin-top: 1.5rem;
    width: 100%;
  }

  .migration-checklist span {
    background: rgba(255, 255, 255, 0.08);
